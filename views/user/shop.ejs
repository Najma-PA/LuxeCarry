<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Shop - LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>

<body>

<%- include('../partials/navbar') %>

<div class="container mt-4">

<!-- HEADER -->
<h3 class="fw-bold">Shop All Bags</h3>
<p class="text-muted">
Discover our curated collection of premium luxury handbags crafted for elegance and timeless style.
</p>

<div class="row mt-4">

<!-- FILTERS -->
<div class="col-md-3 filters">

<form method="GET" id="filterForm">
  <!-- Top header -->
  <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h5 class="mb-0 fw-bold" style="color: #111827; font-size: 18px;">Filters</h5>
    <a href="/user/shop" class="text-decoration-none fw-bold" style="color: #c98a2c; font-size: 11px; letter-spacing: 0.5px;">CLEAR ALL</a>
  </div>
  <hr style="border-color: #e5e7eb; margin-bottom: 24px; opacity: 1;">


  <!-- CATEGORY -->
  <h6 class="mb-3 text-uppercase fw-bold text-muted" style="font-size: 12px; letter-spacing: 1.5px; color: #798b9e !important;">Category</h6>
  <div class="mb-4">
    <% if(typeof categories !== 'undefined' && categories && categories.length){ %>
      <% categories.forEach(cat => { %>
        <div class="form-check mb-2 d-flex align-items-center">
          <input class="form-check-input mt-0"
            type="radio"
            name="category"
            id="cat_<%= cat._id %>"
            value="<%= cat._id %>"
            <%= query.category == cat._id ? 'checked' : '' %>
            style="width: 18px; height: 18px; border: 1px solid #d1d5db; box-shadow: none; cursor: pointer; accent-color: #c98a2c; margin-right: 8px;">
          <label class="form-check-label" for="cat_<%= cat._id %>" style="color: #111827; font-size: 14px; cursor: pointer;"><%= cat.name %></label>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- PRICE RANGE -->
  <h6 class="mb-3 text-uppercase fw-bold text-muted" style="font-size: 12px; letter-spacing: 1.5px; color: #798b9e !important;">Price Range</h6>
  <div class="mb-4">
    <input type="range" class="form-range" name="maxPrice" min="0" max="50000" step="500" value="<%= query.maxPrice || 50000 %>" id="priceRange" style="accent-color: #ebd5b3; height: 6px; cursor: pointer;">
    <div class="d-flex justify-content-between mt-1">
      <span class="fw-bold" style="font-size: 12px;">0₹</span>
      <span class="fw-bold" style="font-size: 12px;" id="priceLabel"><%= query.maxPrice ? query.maxPrice + '₹' : '50,000₹' %></span>
    </div>
    
    <script>
      document.getElementById('priceRange').addEventListener('input', function(e) {
        document.getElementById('priceLabel').innerText = Number(e.target.value).toLocaleString() + '₹';
      });
    </script>
  </div>

  <!-- COLOR -->
  <h6 class="mb-3 text-uppercase fw-bold text-muted" style="font-size: 12px; letter-spacing: 1.5px; color: #798b9e !important;">Color</h6>
  <div class="d-flex gap-2 flex-wrap align-items-center mb-4">
    <% if(typeof colors !== 'undefined' && colors && colors.length){ %>
      <% colors.forEach(c => { %>
        <label style="cursor:pointer; display: flex; align-items: center; justify-content: center;" class="m-1">
          <input type="radio"
                 name="color"
                 value="<%= c %>"
                 hidden
                 <%= query.color === c ? 'checked' : '' %>>
          <span style="
            display:inline-block;
            width:26px;
            height:26px;
            border-radius:50%;
            background-color:<%= c %>;
            box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08); /* slight border */
            <%= query.color === c ? 'outline: 2px solid #CFA360; outline-offset: 3px;' : '' %>
          ">
          </span>
        </label>
      <% }) %>
    <% } %>
  </div>

  <!-- RATING 
  <h6 class="mb-3 text-uppercase fw-bold text-muted" style="font-size: 12px; letter-spacing: 1.5px; color: #798b9e !important;">Rating</h6>
  <div class="mb-4">
    <div class="form-check mb-2 d-flex align-items-center">
      <input class="form-check-input mt-0"
        type="radio"
        name="rating"
        id="rating4"
        value="4"
        <%= query.rating == '4' ? 'checked' : '' %>
        style="width: 18px; height: 18px; border: 1px solid #d1d5db; box-shadow: none; cursor: pointer; accent-color: #c98a2c; margin-right: 8px;">
      <label class="form-check-label pt-1" for="rating4" style="color: #798b9e; font-size: 14px; cursor: pointer;">
         <span style="color: #c98a2c; font-size: 14px;"><i class="fa-regular fa-star"></i><i class="fa-regular fa-star"></i><i class="fa-regular fa-star"></i><i class="fa-regular fa-star"></i><i class="fa-regular fa-star"></i></span> & Up
      </label>
    </div>
  </div>
-->
  <!-- SORT -->
  <h6 class="mb-3 text-uppercase fw-bold text-muted" style="font-size: 12px; letter-spacing: 1.5px; color: #798b9e !important;">Sort</h6>
  <select name="sort" class="form-select mb-4" style="border-radius: 8px; border: 1px solid #e5e7eb; padding: 10px; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); color: #374151;">
    <option value="">Default</option>
    <option value="low-high" <%= query.sort==='low-high'?'selected':'' %>>Price Low → High</option>
    <option value="high-low" <%= query.sort==='high-low'?'selected':'' %>>Price High → Low</option>
    <option value="a-z" <%= query.sort==='a-z'?'selected':'' %>>A-Z</option>
    <option value="z-a" <%= query.sort==='z-a'?'selected':'' %>>Z-A</option>
  </select>


</form>

</div>

<!-- PRODUCTS -->
<div class="col-md-9">

<div class="row" id="product-grid">

<%- include('../partials/user/product-grid') %>

</div>

<!-- PAGINATION -->
<div class="text-center mt-3" id="pagination-container">

<%- include('../partials/user/pagination') %>

</div>

</div>

</div>

</div>


<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- SHOP LOGIC ---
    const filterForm = document.getElementById('filterForm');
    const productGrid = document.getElementById('product-grid');
    const paginationContainer = document.getElementById('pagination-container');

    if (filterForm) {
        filterForm.querySelectorAll('input[type="radio"], input[type="range"], select').forEach(input => {
            input.addEventListener('change', () => {
                updateShop();
            });
        });
    }

    if (paginationContainer) {
        paginationContainer.addEventListener('click', (e) => {
            const link = e.target.closest('.pagination-link');
            if (link) {
                e.preventDefault();
                const page = link.dataset.page;
                updateShop(page);
            }
        });
    }

    async function updateShop(page = 1) {
        if (!productGrid) return;
        productGrid.style.opacity = '0.5';
        productGrid.style.pointerEvents = 'none';

        const formData = new FormData(filterForm);
        const params = new URLSearchParams(formData);
        params.set('page', page);

        try {
            const res = await fetch(`/user/shop?${params.toString()}`, {
                headers: { 'Accept': 'application/json' }
            });
            const data = await res.json();
            if (data.success) {
                productGrid.innerHTML = data.gridHtml;
                paginationContainer.innerHTML = data.paginationHtml;
                const newUrl = `${window.location.pathname}?${params.toString()}`;
                window.history.pushState({ path: newUrl }, '', newUrl);
                window.scrollTo({ top: productGrid.offsetTop - 100, behavior: 'smooth' });
            }
        } catch (err) {
            console.error('Shop update error:', err);
        } finally {
            productGrid.style.opacity = '1';
            productGrid.style.pointerEvents = 'auto';
        }
    }

    // --- WISHLIST & CART FLOW ---
    document.addEventListener('click', async (e) => {
        const wishlistToggle = e.target.closest('.wishlist-toggle');
        if (wishlistToggle) {
            e.preventDefault();
            await handleToggleWishlist(wishlistToggle.dataset.id, wishlistToggle);
        }

        const addToCartBtn = e.target.closest('.add-to-cart-btn');
        if (addToCartBtn) {
            handleAddToCart(addToCartBtn.dataset.id);
        }
    });

    async function handleToggleWishlist(productId, element) {
        try {
            const res = await fetch('/user/wishlist/toggle', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            });
            if (res.status === 401) { window.location.href = '/user/login'; return; }
            const data = await res.json();
            if (data.success) {
                showToast(data.message);
                const icon = element.querySelector('i');
                if (data.message.includes('added')) {
                    icon.classList.replace('fa-regular', 'fa-solid');
                    icon.style.color = '#ef4444';
                } else {
                    icon.classList.replace('fa-solid', 'fa-regular');
                    icon.style.color = '#6b7280';
                }
            }
        } catch (err) { console.error(err); }
    }

    async function handleAddToCart(productId) {
        try {
            const res = await fetch('/user/cart/add/' + productId, {
                headers: { 'Accept': 'application/json' }
            });
            if (res.status === 401) { window.location.href = '/user/login'; return; }
            const data = await res.json();
            if (data.success) {
                showToast('Added to cart!');
                updateCartBadge(data.cartCount);
            } else {
                showToast(data.message || 'Out of stock', 'error');
            }
        } catch (err) { console.error(err); }
    }

    function updateCartBadge(count) {
        const badge = document.getElementById('cart-count-badge');
        if (badge) {
            badge.innerText = count;
            badge.style.display = count > 0 ? 'flex' : 'none';
        }
    }

    function showToast(msg, icon = 'success') {
        Toastify({
            text: msg,
            duration: 3000,
            gravity: "top",
            position: "right",
            style: {
                background: icon === 'success' ? "#c26a00" : "#dc3545",
                borderRadius: "10px",
                boxShadow: "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
            }
        }).showToast();
    }
});
</script>

</body>
</html>
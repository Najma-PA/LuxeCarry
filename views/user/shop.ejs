<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Shop - LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/navbar') %>

<div class="container mt-4">

<!-- HEADER -->
<h3 class="fw-bold">Shop All Bags</h3>
<p class="text-muted">
Discover our curated collection of premium luxury handbags crafted for elegance and timeless style.
</p>

<div class="row mt-4">

<!-- FILTERS -->
<div class="col-md-3">

<form method="GET">

<!-- SEARCH -->
<div class="mb-3">
<input type="text" name="search" value="<%= query.search || '' %>"
  class="form-control" placeholder="Search products...">

<% if(query.search){ %>
  <a href="/user/shop" class="small text-danger">Clear</a>
<% } %>
</div>

<!-- CATEGORY -->
<h6>Category</h6>
<% if(categories && categories.length){ %>
  <% categories.forEach(cat => { %>
    <div class="form-check">
      <input class="form-check-input"
        type="radio"
        name="category"
        value="<%= cat._id %>"
        <%= query.category == cat._id ? 'checked' : '' %>>

      <label class="form-check-label"><%= cat.name %></label>
    </div>
  <% }) %>
<% } %>

<!-- PRICE -->
<h6 class="mt-3">Price Range</h6>
<input type="number" name="minPrice" value="<%= query.minPrice || '' %>"
  class="form-control mb-2" placeholder="Min">

<input type="number" name="maxPrice" value="<%= query.maxPrice || '' %>"
  class="form-control mb-2" placeholder="Max">

<!-- SORT -->
<h6 class="mt-3">Sort</h6>
<select name="sort" class="form-select mb-3">
  <option value="">Default</option>
  <option value="low-high" <%= query.sort==='low-high'?'selected':'' %>>Price Low → High</option>
  <option value="high-low" <%= query.sort==='high-low'?'selected':'' %>>Price High → Low</option>
  <option value="a-z" <%= query.sort==='a-z'?'selected':'' %>>A-Z</option>
  <option value="z-a" <%= query.sort==='z-a'?'selected':'' %>>Z-A</option>
</select>

<button class="btn btn-warning w-100">Apply Filters</button>

</form>

</div>

<!-- PRODUCTS -->
<div class="col-md-9">

<div class="row">

<% if(products && products.length > 0){ %>

  <% products.forEach(p => { %>

  <div class="col-md-4 mb-4">

    <div class="card p-2 product-card">

      <img src="<%= p.images[0] %>" class="img-fluid">

      <h6 class="mt-2"><%= p.name %></h6>

      <p>
        ₹<%= p.finalPrice %>
        <small class="text-muted text-decoration-line-through">
          ₹<%= p.price %>
        </small>
      </p>

      <% if(p.stock === 0){ %>
        <span class="text-danger">Out of Stock</span>
      <% } %>

      <div class="d-flex gap-2">

        <button class="btn btn-sm btn-outline-dark w-50"
          onclick="addToCart('<%= p._id %>')">
          Add to Cart
        </button>

        <a href="/product/<%= p._id %>"
          class="btn btn-warning btn-sm w-50">
          View
        </a>

      </div>

    </div>

  </div>

  <% }) %>

<% } else { %>
  <p>No products found</p>
<% } %>

</div>

<!-- PAGINATION -->
<div class="text-center mt-3">

<% for(let i = 1; i <= totalPages; i++){ %>

  <a href="?page=<%= i %>"
     class="btn btn-sm <%= currentPage === i ? 'btn-warning' : 'btn-light' %>">
     <%= i %>
  </a>

<% } %>

</div>

</div>

</div>

</div>

<%- include('../partials/footer') %>

<script>
async function addToCart(id){
  try{
    const res = await fetch('/cart/add/' + id);
    const data = await res.json();

    if(data.success){
      alert("Added to cart");
    }else{
      alert(data.message);
    }
  }catch(err){
    alert("Error");
  }
}
</script>

</body>
</html>
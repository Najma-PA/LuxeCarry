<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <title>Profile</title>
    <link rel="stylesheet" href="/css/style.css">

 
</head>
<body>

    
<%- include("../partials/user/navbar") %>



<div class="container account-container">

<div class="row">
    <%- include("../partials/user/sidebar",{
        user,activePage:'profile'
    }) %>

<div class="col-lg-9 col-md-8 pt-5">

    <div class="dashboard-page-header">
        <h1 class="dashboard-page-title">
            Profile
        </h1>
        <p class="dashboard-page-subtitle">
            Manage your personal information
        </p>
    </div>

    <div class="account-card p-4 w-100 mb-4" style="max-width: 600px;">

<!-- Avatar Section -->
 
<div class="d-flex align-items-center mb-4 mt-4">
    <div class="me-3">
        <%- include('../partials/user/avatar', { targetUser: user, size: 48, className: 'lc-profile-avatar' }) %>
    </div>

  
    <div>
        <h5 class="mb-1"><%= user.name %></h5>
        <p class="text-muted mb-0 small">User Profile</p>
    </div>
</div>

<div class="mb-3">

<label>Full Name</label>

<input class="form-control" value="<%= user.name %>" disabled>

</div>

<div class="mb-3">

<label>Email Address</label>

<input class="form-control" value="<%= user.email %>" disabled>

</div>
<div class="d-flex justify-content-end gap-3 mt-5">
  <a href="/user/editProfile" class="btn edit-btn">
Edit Profile
</a>

<% if (!user.googleId) { %>
<a href="/user/changePassword" class="btn edit-btn">
Change Password
</a>
<% } %>
</div>
</div>

</div>

</div>

</div>
<%- include("../partials/user/footer-short") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
  window.addEventListener("pageshow", function (event) {
    if (event.persisted || window.performance.navigation.type === 2) {
      window.location.reload();
    }
  });
</script>


</body>
</html>
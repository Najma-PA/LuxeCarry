<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/forgotpswd.css">
</head>

<body>

<div class="header">
<span class="logo"><i class="fa-solid fa-bag-shopping"></i> LuxeCarry</span>
</div>

<div class="page-wrapper">

<div class="auth-card">

<h3>Verify OTP</h3>

<p class="text-muted small">
Enter the verification code sent to your email
</p>

<% if (error) { %>
<div class="alert alert-danger text-center">
  <%= error %>
</div>
<% } %>

<% if (message) { %>
<div class="alert alert-success text-center">
  <%= message %>
</div>
<% } %>

<form action="/user/verifyOtp" method="POST" id="otpForm">

<div class="d-flex justify-content-center mb-3">
  <input type="hidden" name="otp" id="fullOtp">
  <input class="form-control text-center me-1 otp-input" maxlength="1" oninput="moveToNext(this, 0)">
  <input class="form-control text-center me-1 otp-input" maxlength="1" oninput="moveToNext(this, 1)">
  <input class="form-control text-center me-1 otp-input" maxlength="1" oninput="moveToNext(this, 2)">
  <input class="form-control text-center me-1 otp-input" maxlength="1" oninput="moveToNext(this, 3)">
  <input class="form-control text-center me-1 otp-input" maxlength="1" oninput="moveToNext(this, 4)">
  <input class="form-control text-center otp-input" maxlength="1" oninput="moveToNext(this, 5)">
</div>

<button type="submit" class="btn-theme">Verify</button>

</form>

<form action="/user/resendOtp" method="POST" class="mt-2 text-center" id="resendForm">
  <p class="small mb-0">
  Didn't receive code?
  <button type="submit" class="btn btn-link p-0 m-0 align-baseline">Resend</button>
  </p>
</form>

<script>
  function moveToNext(current, index) {
    if (current.value.length === 1) {
      const inputs = document.querySelectorAll('.otp-input');
      if (index < inputs.length - 1) {
        inputs[index + 1].focus();
      }
    }
  }

  document.getElementById('otpForm').addEventListener('submit', function(e) {
    const inputs = document.querySelectorAll('.otp-input');
    let otpValue = '';
    inputs.forEach(input => {
      otpValue += input.value;
    });
    document.getElementById('fullOtp').value = otpValue;
  });
</script>

</div>

</div>

<div class="footer">
© 2026 LUXECARRY INTERNATIONAL. ALL RIGHTS RESERVED.
</div>

</body>
</html>
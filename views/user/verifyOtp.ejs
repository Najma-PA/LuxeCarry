<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/forgotpswd.css">
</head>

<body>

<div class="header">
<span class="logo"><i class="fa-solid fa-bag-shopping"></i> LuxeCarry</span>
</div>

<div class="page-wrapper">

<div class="auth-card">

<h3>Verify OTP</h3>

<p class="text-muted small">
Enter the verification code sent to your email
</p>

<% if (error) { %>
<div class="alert alert-danger text-center">
  <%= error %>
</div>
<% } %>

<% if (message) { %>
<div class="alert alert-success text-center">
  <%= message %>
</div>
<% } %>

<form action="/user/verifyOtp" method="POST" id="otpForm">

<div class="d-flex justify-content-center mb-3">
  <input type="hidden" name="otp" id="fullOtp">
  <input class="form-control text-center me-1 otp-input" maxlength="1">
  <input class="form-control text-center me-1 otp-input" maxlength="1">
  <input class="form-control text-center me-1 otp-input" maxlength="1">
  <input class="form-control text-center me-1 otp-input" maxlength="1">
  <input class="form-control text-center me-1 otp-input" maxlength="1">
  <input class="form-control text-center otp-input" maxlength="1">
</div>

<button type="submit" class="btn-theme">Verify</button>

</form>
 <p id="timer">05:00</p>
 <p id="expiredMsg" class="text-danger small" style="display:none;">
  OTP expired. Please resend.
</p>
<form action="/user/resendOtp" method="POST" class="mt-2 text-center" id="resendForm">
 
  <p class="small mb-0">
  Didn't receive code?
  <button 
  type="submit" 
  id="resendBtn"
  class="btn btn-link p-0 m-0 align-baseline"
  disabled
>
  Resend
</button>
  </p>
</form>

<script>
/*document.addEventListener("DOMContentLoaded", function () {

  function moveToNext(current, index) {
    if (current.value.length === 1) {
      const inputs = document.querySelectorAll('.otp-input');
      if (index < inputs.length - 1) {
        inputs[index + 1].focus();
      }
    }
  }
*/
document.addEventListener("DOMContentLoaded", function () {

  const inputs = document.querySelectorAll('.otp-input');

  // Move forward
  inputs.forEach((input, index) => {
    input.addEventListener('input', () => {
      if (input.value.length === 1 && index < inputs.length - 1) {
        inputs[index + 1].focus();
      }
    });
  });

  // Move backward (backspace)
  inputs.forEach((input, index) => {
    input.addEventListener('keydown', (e) => {
      if (e.key === "Backspace" && input.value === "" && index > 0) {
        inputs[index - 1].focus();
      }
    });
  });

  const otpForm = document.getElementById('otpForm');
  if (otpForm) {
    otpForm.addEventListener('submit', function (e) {
      const fullOtpInput = document.getElementById('fullOtp');
      let otpValue = '';
      inputs.forEach(input => {
        otpValue += input.value;
      });
      fullOtpInput.value = otpValue;
    });
  }

 const expireTime = Number("<%= typeof otpExpire !== 'undefined' ? otpExpire : 0 %>");
  const timerElement = document.getElementById("timer");
  const resendBtn = document.getElementById("resendBtn");

  function updateTimer() {
    const now = Date.now();
    const distance = expireTime - now;

    if (distance <= 0) {
      document.querySelectorAll('.otp-input').forEach(input => {
        input.disabled = true;
      });

      timerElement.innerHTML = "00:00";

      if (resendBtn) {
        resendBtn.disabled = false;
        resendBtn.style.opacity = "1";
        resendBtn.style.cursor = "pointer";
      }

      document.getElementById("expiredMsg").style.display = "block";

      return;
    }

    const minutes = Math.floor(distance / 60000);
    const seconds = Math.floor((distance % 60000) / 1000);

    timerElement.innerHTML =
      String(minutes).padStart(2, '0') + ":" +
      String(seconds).padStart(2, '0');
  }

  updateTimer();

  const interval = setInterval(() => {
    updateTimer();
    if (Date.now() >= expireTime) clearInterval(interval);
  }, 1000);

});
</script>

</div>

</div>

<div class="footer">
© 2026 LUXECARRY INTERNATIONAL. ALL RIGHTS RESERVED.
</div>

</body>
</html>
<!-- views/user/invoicePreview.ejs -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Invoice</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />

  <style>

    body{
      background:#f5f5f5;
      font-family:'Inter',sans-serif;
      color:#222;
    }

    .invoice-wrapper{
      padding:120px 20px 60px;
    }

    .invoice-card{
      max-width:1000px;
      margin:auto;
      background:#fff;
      border-radius:18px;
      padding:45px;
      box-shadow:0 4px 24px rgba(0,0,0,0.08);
    }

    .brand-logo{
      width:52px;
      height:52px;
      object-fit:contain;
    }

    .invoice-badge{
      background:#111;
      color:#fff;
      padding:10px 18px;
      border-radius:30px;
      font-size:13px;
      letter-spacing:.5px;
      font-weight:600;
    }

    .section-title{
      font-size:14px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.8px;
      margin-bottom:15px;
      color:#777;
    }

    .info-card{
      border:1px solid #eee;
      border-radius:14px;
      padding:22px;
      height:100%;
      background:#fafafa;
    }

    .invoice-table{
      margin-top:30px;
    }

    .invoice-table thead{
      background:#111;
      color:#fff;
    }

    .invoice-table th{
      font-size:14px;
      font-weight:600;
      padding:16px;
      border:none;
    }

    .invoice-table td{
      padding:18px 16px;
      vertical-align:middle;
      border-color:#f1f1f1;
    }

    .product-img{
      width:70px;
      height:70px;
      object-fit:cover;
      border-radius:12px;
      border:1px solid #eee;
    }

    .summary-card{
      margin-left:auto;
      width:350px;
      border:1px solid #eee;
      border-radius:16px;
      padding:24px;
      background:#fafafa;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      margin-bottom:14px;
      font-size:15px;
    }

    .grand-total{
      border-top:1px solid #ddd;
      padding-top:18px;
      margin-top:18px;
      font-size:20px;
      font-weight:700;
    }

    .thank-note{
      margin-top:50px;
      text-align:center;
      color:#777;
      font-size:15px;
    }

    .invoice-actions{
      display:flex;
      gap:12px;
      justify-content:flex-end;
      margin-bottom:30px;
    }

    .btn-dark{
      background:#111;
      border:none;
      padding:12px 22px;
      border-radius:10px;
      font-weight:600;
    }

    .btn-outline-dark{
      border-radius:10px;
      padding:12px 22px;
      font-weight:600;
    }

    @media(max-width:768px){

      .invoice-card{
        padding:25px;
      }

      .summary-card{
        width:100%;
      }

      .invoice-actions{
        flex-direction:column;
      }
    }

  </style>
</head>

<body>

<div class="invoice-wrapper">

  <div class="invoice-card">

    <!-- ACTIONS -->

    <div class="invoice-actions">

      <a
        href="/user/orders/invoice/<%= order._id %>/download"
        class="btn btn-dark"
      >
        <i class="fa-solid fa-download me-2"></i>
        Download Invoice
      </a>

      <button
        onclick="window.print()"
        class="btn btn-outline-dark"
      >
        <i class="fa-solid fa-print me-2"></i>
        Print
      </button>

    </div>

    <!-- HEADER -->

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-4">

      <div class="d-flex align-items-center gap-3">

        <img
          src="/images/logo.png"
          class="brand-logo"
        />

        <div>
          <h2 class="fw-bold mb-1">
            LuxeCarry
          </h2>

          <p class="text-muted mb-0">
            Premium Bags Collection
          </p>
        </div>

      </div>

      <div class="text-md-end">

        <span class="invoice-badge">
          INVOICE
        </span>

        <h5 class="mt-3 mb-1 fw-bold">
          #<%= order.orderId || order._id %>
        </h5>

        <p class="text-muted mb-0">
          <%= order.createdAt.toDateString() %>
        </p>

      </div>

    </div>

    <hr class="my-4">

    <!-- DETAILS -->

    <div class="row g-4">

      <!-- CUSTOMER -->

      <div class="col-md-4">

        <div class="info-card">

          <div class="section-title">
            Customer Details
          </div>

          <h6 class="fw-bold mb-2">
            <%= order.userId.name %>
          </h6>

          <p class="text-muted mb-1">
            <%= order.userId.email %>
          </p>

        </div>

      </div>

      <!-- SHIPPING -->

      <div class="col-md-4">

        <div class="info-card">

          <div class="section-title">
            Shipping Address
          </div>

          <p class="mb-1">
            <%= order.address?.name || 'Customer' %>
          </p>

          <p class="text-muted mb-1">
            <%= order.address?.city || '' %>
          </p>

          <p class="text-muted mb-1">
            <%= order.address?.state || '' %>
          </p>

          <p class="text-muted mb-0">
            <%= order.address?.pincode || '' %>
          </p>

        </div>

      </div>

      <!-- PAYMENT -->

      <div class="col-md-4">

        <div class="info-card">

          <div class="section-title">
            Payment Details
          </div>

          <p class="mb-2">
            <strong>Method:</strong>
            <%= order.paymentMethod || 'COD' %>
          </p>

          <p class="mb-0">
            <strong>Status:</strong>

            <span class="badge bg-success">
              <%= order.status %>
            </span>
          </p>

        </div>

      </div>

    </div>

    <!-- PRODUCTS -->

    <table class="table invoice-table align-middle">

      <thead>

        <tr>

          <th>Product</th>

          <th>Variant</th>

          <th>Qty</th>

          <th>Price</th>

          <th>Total</th>

        </tr>

      </thead>

      <tbody>

      <% let subtotal = 0; %>

      <% order.items.forEach(item => {

        const total = item.quantity * item.price;

        subtotal += total;

      %>

        <tr>

          <td>

            <div class="d-flex align-items-center gap-3">

              <img
                src="<%= item.product?.thumbnail?.url || '/images/no-image.png' %>"
                class="product-img"
              />

              <div>

                <h6 class="mb-1 fw-semibold">
                  <%= item.product?.name || item.product?.productName %>
                </h6>

                <small class="text-muted">
                  LuxeCarry Collection
                </small>

              </div>

            </div>

          </td>

          <td>

            <%= item.variantName || 'Standard' %>

          </td>

          <td>

            <%= item.quantity %>

          </td>

          <td>

            ₹<%= item.price %>

          </td>

          <td class="fw-semibold">

            ₹<%= total %>

          </td>

        </tr>

      <% }) %>

      </tbody>

    </table>

    <!-- SUMMARY -->

    <div class="mt-5">

      <div class="summary-card">

        <div class="summary-row">

          <span>Subtotal</span>

          <span>
            ₹<%= subtotal %>
          </span>

        </div>

        <div class="summary-row">

          <span>Shipping</span>

          <span>
            Free
          </span>

        </div>

        <div class="summary-row">

          <span>Discount</span>

          <span>
            ₹<%= order.discountAmount || 0 %>
          </span>

        </div>

        <div class="summary-row grand-total">

          <span>Grand Total</span>

          <span>
            ₹<%= order.totalAmount || subtotal %>
          </span>

        </div>

      </div>

    </div>

    <!-- THANK YOU -->

    <div class="thank-note">

      <p class="mb-1 fw-semibold">
        Thank you for shopping with LuxeCarry
      </p>

      <small>
        For support contact:
        support@luxecarry.com
      </small>

    </div>

  </div>

</div>

</body>
</html>
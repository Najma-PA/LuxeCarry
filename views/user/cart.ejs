<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Shopping Cart - LuxeCarry</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: #fafbfc;">
    <%- include('../partials/navbar') %>

<div class="container my-5 pt-4">

    <!-- Header -->
    <div class="cart-title-container">
        <h1 class="text-serif m-0">Shopping Cart</h1>
        <span class="item-count" id="cart-count">(<%= cart.items.length %> items)</span>
    </div>

    <% if(cart.items.length === 0){ %>
        <div class="text-center py-5">
            <h4 class="text-muted mb-4">Your cart is currently empty.</h4>
            <a href="/user/shop" class="btn-checkout-premium px-5" style="text-decoration: none;">Explore Collection</a>
        </div>
    <% } else { %>

    <div class="row g-4">

        <!-- LEFT: Items -->
        <div class="col-lg-8">
            <div class="d-flex flex-column gap-4">
                <% cart.items.forEach(item => { %>
                    <div class="premium-cart-card d-flex align-items-center <%= !item.isAvailable ? 'opacity-75' : '' %>" id="item-row-<%= item._id %>">
                        
                        <!-- Remove -->
                        <button class="btn-remove-item cart-action-btn" data-action="remove" data-id="<%= item._id %>">
                            <i class="fa-regular fa-trash-can"></i>
                        </button>

                        <!-- Image -->
                        <img src="<%= (item.product && item.product.images) ? item.product.images[0] : '/images/placeholder.jpg' %>" class="cart-item-img" alt="<%= item.product ? item.product.name : 'Unknown' %>">

                        <!-- Info -->
                        <div class="cart-item-info">
                            <h3 class="item-name text-serif"><%= item.product ? item.product.name : 'Product Unavailable' %></h3>
                            
                            <% if(!item.isAvailable) { %>
                                <div id="availability-msg-<%= item._id %>" class="text-danger fw-bold mb-2" style="font-size: 13px;">
                                    <i class="fa-solid fa-triangle-exclamation"></i> This product is currently unavailable and must be removed to checkout.
                                </div>
                            <% } %>

                            <div class="item-attr">
                                <span class="label">Color:</span> <%= item.variantDetail ? item.variantDetail.value : '-' %>
                                <span class="badge bg-light text-dark ms-2" style="font-size: 10px; border: 1px solid #ddd;">Limit: 5 per item</span>
                            </div>

                            <div class="mt-4 d-flex justify-content-between align-items-end">
                                <!-- Qty -->
                                <div class="qty-pill <%= !item.isAvailable ? 'bg-light' : '' %>">
                                    <button id="minus-<%= item._id %>" class="cart-action-btn" data-action="qty-minus" data-id="<%= item._id %>" <%= !item.isAvailable ? 'disabled' : '' %>>-</button>
                                    <span id="qty-<%= item._id %>"><%= item.quantity %></span>
                                    <% 
                                        const availableStock = item.variantDetail ? item.variantDetail.stock : (item.product ? item.product.stock : 0);
                                    %>
                                    <button 
                                        id="plus-<%= item._id %>"
                                        class="cart-action-btn"
                                        data-action="qty-plus"
                                        data-id="<%= item._id %>"
                                        <%= (item.quantity >= 5 || item.quantity >= availableStock || !item.isAvailable) ? 'disabled' : '' %>>
                                        +
                                    </button>
                                </div>

                                <!-- Price -->
                                <div class="pricing-block">
                                    <% if(item.product && item.appliedOffer > 0) { %>
                                        <span class="original-price">₹<%= item.product.price.toLocaleString() %></span>
                                        <span class="discount-tag"><%= item.appliedOffer %>% OFF</span>
                                    <% } %>
                                    <span class="final-price text-serif" id="subtotal-<%= item._id %>">₹<%= (item.itemTotal || 0).toLocaleString() %>.00</span>
                                </div>
                            </div>

                            <% 
                                const currentStock = item.variantDetail ? item.variantDetail.stock : (item.product ? item.product.stock : 0);
                                if(item.isAvailable && currentStock === 0){ 
                            %>
                                <div class="text-danger mt-2 fw-bold" style="font-size: 11px;">Out of Stock</div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- RIGHT: Summary -->
        <div class="col-lg-4">
            <div class="summary-card-premium">
                <h5>Order Summary</h5>
                
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">₹<%= cart.subtotal.toLocaleString() %>.00</span>
                </div>

                <div class="summary-row savings" id="discount-row" style="<%= cart.totalDiscount > 0 ? '' : 'display: none;' %>">
                    <span>Savings</span>
                    <span id="cart-discount">-₹<%= cart.totalDiscount.toLocaleString() %>.00</span>
                </div>

                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="text-success fw-bold">Free</span>
                </div>

                <div class="summary-row total">
                    <span class="fw-bold">Total</span>
                    <span class="price text-serif" id="cart-total">₹<%= cart.total.toLocaleString() %>.00</span>
                </div>

                <% 
                    const hasUnavailable = cart.items.some(i => !i.isAvailable);
                %>
                <button id="proceed-checkout-btn" 
                        class="btn-checkout-premium mt-4 text-center d-block text-decoration-none border-0"
                        <%= hasUnavailable ? 'disabled' : '' %>>
                    Proceed to Checkout
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted" style="font-size: 11px;">
                        Secure checkout. All transactions are encrypted.
                    </small>
                </div>
            </div>
        </div>

    </div>
    <% } %>

</div>

<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script>
document.addEventListener('DOMContentLoaded', () => {
    const cartContainer = document.querySelector('.container.my-5');

    if (!cartContainer) return;
    
    // Polling for item status (Availability, Stock, Price)
    setInterval(async () => {
        try {
            const res = await fetch('/user/cart/items-status');
            const data = await res.json();
            if (data.success) {
                let anyUnavailable = false;
                data.items.forEach(itemStatus => {
                    const row = document.getElementById(`item-row-${itemStatus.id}`);
                    if (!row) return;

                    const msgBox = document.getElementById(`availability-msg-${itemStatus.id}`);
                    const plusBtn = document.getElementById(`plus-${itemStatus.id}`);
                    const minusBtn = document.getElementById(`minus-${itemStatus.id}`);
                    const qtyPill = minusBtn?.parentElement;

                    if (!itemStatus.isAvailable) {
                        anyUnavailable = true;
                        row.classList.add('opacity-75');
                        if (!msgBox) {
                            const infoDiv = row.querySelector('.cart-item-info');
                            const nameEl = infoDiv.querySelector('.item-name');
                            const newMsg = document.createElement('div');
                            newMsg.id = `availability-msg-${itemStatus.id}`;
                            newMsg.className = 'text-danger fw-bold mb-2';
                            newMsg.style.fontSize = '13px';
                            newMsg.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> This product is currently unavailable and must be removed to checkout.';
                            nameEl.after(newMsg);
                        }
                        if (plusBtn) plusBtn.disabled = true;
                        if (minusBtn) minusBtn.disabled = true;
                        if (qtyPill) qtyPill.classList.add('bg-light');
                    } else {
                        // Product is available - remove warning if exists
                        if (msgBox) msgBox.remove();
                        row.classList.remove('opacity-75');
                        if (qtyPill) qtyPill.classList.remove('bg-light');
                        if (minusBtn) minusBtn.disabled = false;
                        if (plusBtn) {
                            plusBtn.disabled = (itemStatus.quantity >= 5 || itemStatus.quantity >= itemStatus.stock);
                        }
                    }

                    // Update subtotal if changed
                    const subtotalEl = document.getElementById(`subtotal-${itemStatus.id}`);
                    if (subtotalEl) subtotalEl.innerText = `₹${itemStatus.itemTotal.toLocaleString()}.00`;
                });

                // Update summary totals
                const checkoutBtn = document.getElementById('proceed-checkout-btn');
                if (checkoutBtn) checkoutBtn.disabled = anyUnavailable;

                const subtotalEl = document.getElementById('cart-subtotal');
                const totalEl = document.getElementById('cart-total');
                const discountSpan = document.getElementById('cart-discount');
                const discountRow = document.getElementById('discount-row');

                if (subtotalEl) subtotalEl.innerText = `₹${data.cartSubtotal.toLocaleString()}.00`;
                if (totalEl) totalEl.innerText = `₹${data.cartTotal.toLocaleString()}.00`;
                if (discountRow && discountSpan) {
                    if (data.cartDiscount > 0) {
                        discountRow.style.display = 'flex';
                        discountSpan.innerText = `-₹${data.cartDiscount.toLocaleString()}.00`;
                    } else {
                        discountRow.style.display = 'none';
                    }
                }
            }
        } catch (err) {
            console.error('Polling failed:', err);
        }
    }, 5000);

    const checkoutBtn = document.getElementById('proceed-checkout-btn');
    if (checkoutBtn) {
        checkoutBtn.addEventListener('click', async () => {
            try {
                const res = await fetch('/user/cart/validate');
                const data = await res.json();
                
                if (data.success) {
                    window.location.href = '/user/checkout';
                } else {
                    const errorMsg = data.errors ? data.errors.join('<br>') : (data.message || 'Validation failed');
                    Swal.fire({
                        icon: 'warning',
                        title: 'Wait!',
                        html: `<div style="text-align: left; font-size: 14px;">${errorMsg}</div>`,
                        confirmButtonColor: '#b78846'
                    });
                }
            } catch (err) {
                showError('Could not validate cart. Please try again.');
            }
        });
    }

    cartContainer.addEventListener('click', async (e) => {
        const btn = e.target.closest('.cart-action-btn');
        if (!btn) return;

        const action = btn.dataset.action;
        const itemId = btn.dataset.id;

        if (action === 'remove') {
            handleRemoveItem(itemId);
        } else if (action === 'qty-plus') {
            handleUpdateQty(itemId, 1);
        } else if (action === 'qty-minus') {
            handleUpdateQty(itemId, -1);
        }
    });

    async function handleRemoveItem(itemId) {
        const result = await Swal.fire({
            title: 'Remove Item?',
            text: 'Are you sure you want to remove this item from your cart?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#b78846',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Yes, remove it!',
            cancelButtonText: 'No, keep it'
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch(`/user/cart/item/${itemId}`, { method: 'DELETE' });
                const data = await res.json();

                if (data.success) {
                    const row = document.getElementById(`item-row-${itemId}`);
                    if (row) {
                        row.style.transition = 'all 0.3s ease';
                        row.style.opacity = '0';
                        row.style.transform = 'translateX(20px)';
                        setTimeout(() => {
                            row.remove();
                            updateCartUI(data);
                            showToast('Item removed from cart');
                        }, 300);
                    }
                } else {
                    showError(data.message || 'Error removing item');
                }
            } catch (err) {
                showError('Something went wrong');
            }
        }
    }

    async function handleUpdateQty(itemId, change) {
        try {
            const res = await fetch(`/user/cart/update/${itemId}?change=${change}`, {
                method: 'PATCH'
            });
            const data = await res.json();

            if (data.success) {
                if (data.newQty === 0) {
                    const row = document.getElementById(`item-row-${itemId}`);
                    if (row) {
                        row.remove();
                    }
                } else {
                    // Update individual item elements
                    const qtyEl = document.getElementById(`qty-${itemId}`);
                    const subtotalEl = document.getElementById(`subtotal-${itemId}`);
                    const plusBtn = document.getElementById(`plus-${itemId}`);

                    if (qtyEl) qtyEl.innerText = data.newQty;
                    if (subtotalEl) subtotalEl.innerText = `₹${data.itemTotal.toLocaleString()}.00`;
                    if (plusBtn) plusBtn.disabled = (data.newQty >= 5);
                }
                updateCartUI(data);
            } else {
                showToast(data.message || 'Update failed', 'warning');
            }
        } catch (err) {
            showError('Something went wrong');
        }
    }

    function updateCartUI(data) {
        // Update Summary
        const subtotalEl = document.getElementById('cart-subtotal');
        const totalEl = document.getElementById('cart-total');
        const countEl = document.getElementById('cart-count');
        const discountRow = document.getElementById('discount-row');
        const discountSpan = document.getElementById('cart-discount');
        const checkoutBtn = document.getElementById('proceed-checkout-btn');

        if (subtotalEl) subtotalEl.innerText = `₹${data.cartSubtotal.toLocaleString()}.00`;
        if (totalEl) totalEl.innerText = `₹${data.cartTotal.toLocaleString()}.00`;
        if (countEl) countEl.innerText = `(${data.itemCount} items)`;

        // Check for remaining unavailable items in the DOM
        if (checkoutBtn) {
            const remainingUnavailable = document.querySelectorAll('[id^="availability-msg-"]').length;
            checkoutBtn.disabled = remainingUnavailable > 0;
        }

        // Update Navbar cart count (global)
        const navCount = document.getElementById('cart-count-badge');
        if (navCount) {
            navCount.innerText = data.cartCount;
            navCount.style.display = data.cartCount > 0 ? 'flex' : 'none';
        }

        if (discountRow && discountSpan) {
            if (data.cartDiscount > 0) {
                discountRow.style.display = 'flex';
                discountSpan.innerText = `-₹${data.cartDiscount.toLocaleString()}.00`;
            } else {
                discountRow.style.display = 'none';
            }
        }

        // If cart empty, show empty state
        if (data.itemCount === 0) {
            const container = document.querySelector('.container.my-5');
            container.innerHTML = `
                <div class="text-center py-5">
                    <h1 class="text-serif m-0 mb-4">Shopping Cart</h1>
                    <h4 class="text-muted mb-4">Your cart is currently empty.</h4>
                    <a href="/user/shop" class="btn-checkout-premium px-5" style="text-decoration: none;">Explore Collection</a>
                </div>
            `;
        }
    }

    function showToast(msg, icon = 'success') {
        Toastify({
            text: msg,
            duration: 3000,
            gravity: "top",
            position: "right",
            style: {
                background: icon === 'success' ? "#c26a00" : "#dc3545",
                borderRadius: "10px",
                boxShadow: "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
            }
        }).showToast();
    }

    function showError(msg) {
        Swal.fire({
            icon: 'error',
            title: 'Oops!',
            text: msg,
            confirmButtonColor: '#b78846'
        });
    }
});
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart - LuxeCarry</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
<div class="container my-5">

  <h3 class="fw-bold mb-4">Shopping Cart</h3>

  <% if(cart.items.length === 0){ %>
    <p>Your cart is empty</p>
  <% } %>

  <div class="row">

    <!-- LEFT -->
    <div class="col-lg-8">

      <% cart.items.forEach(item => { %>

        <% if(item.product && item.product.isActive){ %>

        <div class="cart-card d-flex align-items-center mb-3">

          <img src="<%= item.product.images[0] %>" class="cart-img">

          <div class="flex-grow-1 ms-3">
            <h6><%= item.product.name %></h6>

            <small class="text-muted">
              Color: <%= item.variant?.value || '-' %>
            </small>

            <div class="mt-1">
              ₹<%= item.product.price %> × <%= item.quantity %>
              = <strong>₹<%= item.product.price * item.quantity %></strong>
            </div>

            <% if(item.product.stock === 0){ %>
              <span class="text-danger">Out of Stock</span>
            <% } %>

          </div>

          <!-- QTY -->
          <div class="qty-box">

            <button onclick="updateQty('<%= item._id %>', -1)">-</button>

            <span><%= item.quantity %></span>

            <button 
              onclick="updateQty('<%= item._id %>', 1)"
              <%= item.quantity >= item.product.stock ? 'disabled' : '' %>>
              +
            </button>

          </div>

          <!-- REMOVE -->
          <button class="remove-btn" onclick="removeItem('<%= item._id %>')">✕</button>

        </div>

        <% } %>

      <% }) %>

    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">

      <div class="summary-card">

        <h5>Summary</h5>

        <p>Total: ₹<%= cart.total %></p>

        <% 
          const hasOutOfStock = cart.items.some(i => !i.product || i.product.stock === 0);
        %>

        <button class="btn btn-dark w-100"
          <%= hasOutOfStock ? 'disabled' : '' %>>
          Proceed to Checkout
        </button>

      </div>

    </div>

  </div>

</div>
<script>
async function removeItem(itemId){
  if(confirm('Are you sure you want to remove this item?')){
    try{
      const res = await fetch('/user/cart/remove/' + itemId);
      const data = await res.json();
      if(data.success){
        window.location.reload();
      }else{
        alert(data.message || 'Error removing item');
      }
    }catch(err){
      console.error(err);
    }
  }
}

async function updateQty(itemId, change){
  try{
    const res = await fetch(`/user/cart/update/${itemId}?change=${change}`);
    const data = await res.json();
    if(data.success){
      window.location.reload();
    }else{
      alert(data.message || 'Error updating quantity');
    }
  }catch(err){
    console.error(err);
  }
}
</script>
</body>
</html>
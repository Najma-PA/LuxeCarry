<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= product.name %> - LuxeCarry</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<!-- Modern Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
  :root {
    --gold-primary: #b78846;
    --gold-dark: #9f743a;
    --bg-warm: #f5f5f1;
    --text-main: #272727;
    --text-muted: #7a7a7a;
  }

  body {
    background-color: var(--bg-warm);
    font-family: 'Inter', sans-serif;
    color: var(--text-main);
  }
  
  .heading-serif {
    font-family: 'Playfair Display', serif;
  }
  
  /* Image Gallery */
  .product-gallery {
    position: relative;
  }
  .main-img-container {
    background: #fff;
    border-radius: 24px;
    overflow: hidden;
    height: 550px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    cursor: zoom-in;
  }
  .main-img-container img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.2s ease-out;
    pointer-events: none; /* Let container handle events */
  }
  .main-img-container.zoomed img {
    transform: scale(2.5);
  }
  
  .thumbnails-container {
    display: flex;
    gap: 12px;
    justify-content: flex-start;
    overflow-x: auto;
    padding-bottom: 10px;
  }
  .thumbnail-item {
    width: 90px;
    height: 90px;
    border-radius: 12px;
    background: #fff;
    padding: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .thumbnail-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .thumbnail-item.active {
    border-color: var(--gold-primary);
  }

  /* Product Info */
  .product-title {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
  }
  .product-price {
    font-size: 28px;
    color: var(--gold-primary);
    font-weight: 600;
    margin-bottom: 25px;
  }
  .product-desc {
    color: var(--text-muted);
    line-height: 1.8;
    font-size: 15px;
    margin-bottom: 35px;
  }

  /* Variants */
  .variant-section {
    margin-bottom: 30px;
  }
  .variant-label {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    display: block;
  }
  
  .color-swatches {
    display: flex;
    gap: 12px;
  }
  .color-swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    padding: 2px;
    transition: 0.2s;
    position: relative;
  }
  .color-swatch.active {
    border-color: #3b82f6; /* Blue outline as in mockup */
  }
  .color-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: block;
  }
  
  .size-chips {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .size-chip {
    padding: 8px 18px;
    border-radius: 8px;
    border: 1px solid #ddd;
    background: #fff;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
  }
  .size-chip:hover {
    border-color: var(--gold-primary);
  }
  .size-chip.active {
    background: #eef2ff;
    border-color: #3b82f6;
    color: #3b82f6;
  }
  .size-chip.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Action Buttons */
  .action-wrap {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 40px;
  }
  .qty-selector {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 30px;
    padding: 8px 15px;
    background: #fff;
    gap: 15px;
  }
  .qty-btn {
    border: none;
    background: none;
    color: #888;
    font-size: 16px;
    cursor: pointer;
    padding: 0 5px;
  }
  .btn-buy-now {
    background: var(--gold-primary);
    color: #fff;
    border: none;
    border-radius: 30px;
    padding: 12px 35px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: 0.3s;
  }
  .btn-buy-now:hover {
    background: var(--gold-dark);
    transform: translateY(-2px);
  }
  .btn-add-cart {
    background: transparent;
    color: var(--gold-primary);
    border: 1.5px solid var(--gold-primary);
    border-radius: 30px;
    padding: 12px 35px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: 0.3s;
  }
  .btn-add-cart:hover {
    background: var(--gold-primary);
    color: #fff;
  }
  .btn-heart {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    background: #fff;
    transition: 0.3s;
  }
  .btn-heart:hover {
    color: #ef4444;
    border-color: #ef4444;
  }

  .stock-status {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 5px;
  }
  .stock-status.in-stock { color: #10b981; }
  .stock-status.out-stock { color: #ef4444; }
  .stock-status.low-stock { color: #f59e0b; }

</style>
</head>
<body>

<%- include('../partials/navbar') %>

<% 
  // Pre-process variants for easier UI rendering
  const productVariants = product.variants || [];
  const colors = [...new Set(productVariants.filter(v => v.type === 'Color').map(v => v.value))];
  const sizes = [...new Set(productVariants.filter(v => v.type === 'Size' || v.type === 'Storage').map(v => v.value))];
  // Map hex if possible (dynamic later, for now just simple names or dummy colors)
  const colorMap = {
    'Black': '#000000',
    'White': '#ffffff',
    'Red': '#ef4444',
    'Blue': '#3b82f6',
    'Gold': '#b78846',
    'Orange': '#f97316',
    'Brown': '#78350f',
    'Tan': '#d2b48c'
  };
%>

<div class="container mt-5 mb-5 pb-5">
  
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-5">
    <ol class="breadcrumb" style="font-size: 12px; font-weight: 500; text-transform: capitalize;">
      <li class="breadcrumb-item"><a href="/" class="text-muted text-decoration-none">Home</a></li>
      <li class="breadcrumb-item"><a href="/user/shop" class="text-muted text-decoration-none">Shop</a></li>
      <% if (product.category) { %>
        <li class="breadcrumb-item"><a href="/user/shop?category=<%= product.category._id %>" class="text-muted text-decoration-none"><%= product.category.name %></a></li>
      <% } %>
      <li class="breadcrumb-item active" style="color: #111;"><%= product.name %></li>
    </ol>
  </nav>

  <div class="row g-5">
    
    <!-- Gallery -->
    <div class="col-md-6">
      <div class="product-gallery">
        <div class="main-img-container" id="mainImgContainer">
          <img src="<%= (product.images && product.images[0]) || '/img/placeholder.jpg' %>" id="mainDisplayImg" alt="<%= product.name %>">
        </div>
        
        <div class="thumbnails-container" id="thumbContainer">
          <% (product.images || []).forEach((img, idx) => { %>
            <div class="thumbnail-item <%= idx===0 ? 'active' : '' %>" onclick="updateMainImage(this, '<%= img %>')">
              <img src="<%= img %>" alt="Thumbnail">
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Product Info -->
    <div class="col-md-6 ps-md-5">
      
      <h1 class="product-title heading-serif"><%= product.name %></h1>
      
      <div class="product-price">
        ₹<%= Math.round((product.price || 0) - ((product.price || 0) * (product.offer || 0) / 100)).toLocaleString() %>
        <% if(product.offer > 0) { %>
          <span class="text-muted text-decoration-line-through fs-6 ms-2">₹<%= (product.price || 0).toLocaleString() %></span>
          <span class="badge bg-danger bg-opacity-10 text-danger ms-2" style="font-size: 11px;"><%= product.offer %>% OFF</span>
        <% } %>
      </div>

      <p class="product-desc">
        <%= product.description || 'Elevate your everyday style with this premium handcrafted piece, designed to blend elegance with functionality. Meticulously constructed from high-quality materials to ensure durability and a timeless silhouette.' %>
      </p>

      <form id="addToCartForm">
        <!-- Color Selection -->
        <% if(colors.length > 0) { %>
          <div class="variant-section">
            <span class="variant-label">Color</span>
            <div class="color-swatches">
              <% colors.forEach((color, i) => { %>
                <div class="color-swatch <%= i===0 ? 'active' : '' %>" 
                     data-color="<%= color %>" 
                     onclick="selectColor(this, '<%= color %>')">
                  <span class="color-inner" style="background-color: <%= colorMap[color] || color %>; border: 1px solid #eee;"></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Size Selection -->
        <% if(sizes.length > 0) { %>
          <div class="variant-section">
            <span class="variant-label">Size</span>
            <div class="size-chips">
              <% sizes.forEach((size, i) => { %>
                <div class="size-chip <%= i===0 ? 'active' : '' %>" 
                     data-size="<%= size %>" 
                     onclick="selectSize(this, '<%= size %>')">
                  <%= size %>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Stock Status -->
        <div id="stockInfo" class="stock-status in-stock">
          <!-- Dynamically filled -->
        </div>

        <div class="action-wrap">
          <div class="qty-selector">
            <button type="button" class="qty-btn" onclick="updateQty(-1)">-</button>
            <span id="qtyVal" style="font-weight: 700; min-width: 15px; text-align: center;">1</span>
            <button type="button" class="qty-btn" onclick="updateQty(1)">+</button>
          </div>
          
          <button type="button" onclick="handleBuyNow()" class="btn-buy-now">BUY NOW</button>
          <button type="button" onclick="handleAddToCart()" class="btn-add-cart">ADD TO CART</button>
          
          <a href="javascript:void(0)" onclick="toggleWishlist('<%= product._id %>')" class="btn-heart text-decoration-none">
            <i class="fa-regular fa-heart"></i>
          </a>
        </div>
      </form>

    </div>
  </div>

</div>



  <!-- YOU MAY ALSO LIKE -->
  <% if (typeof relatedProducts !== 'undefined' && relatedProducts.length > 0) { %>
    <div class="container mb-5 pb-5">
      <div class="mt-5 pt-5 border-top" style="border-color: #f1f1f1 !important;">
        <h4 class="fw-bold mb-4 text-center heading-serif" style="color: #111;">You May Also Like</h4>
        <div class="row g-4 mb-5">
          <% relatedProducts.forEach(rel => { %>
            <div class="col-md-3">
              <div class="card h-100 border-0 shadow-sm" style="border-radius: 16px; overflow: hidden; 
              transition: transform 0.3s ease; background: #fff;">
                <div class="position-relative bg-light p-3 text-center" style="min-height: 200px; display: flex;
                 align-items: center; justify-content: center;">
                  <img src="<%= (rel.images && rel.images[0]) || '/img/placeholder.jpg' %>" class="img-fluid" style="max-height: 160px; 
                  object-fit: contain;">
                  <% if(rel.offer > 0) { %>
                    <span class="badge position-absolute" style="top: 15px; left: 15px; background-color: #b78846; 
                    font-size: 9px; padding: 4px 8px;">-<%= rel.offer %>%</span>
                  <% } %>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                  <h6 class="fw-bold mb-2 text-truncate" style="font-size: 14px; color: #111;"><%= rel.name %></h6>
                  <div class="mb-3">
                    <span class="fw-bold" style="color: #b78846; font-size: 15px;">
                      ₹<%= Math.round((rel.price || 0) - ((rel.price || 0) * (rel.offer || 0) / 100)).toLocaleString() %></span>
                    <% if(rel.offer > 0) { %>
                      <small class="text-muted text-decoration-line-through ms-1" style="font-size: 12px;">
                        ₹<%= (rel.price || 0).toLocaleString() %></small>
                    <% } %>
                  </div>
                  <a href="/user/product/<%= rel._id %>" class="btn btn-sm btn-outline-dark rounded-pill 
                    mt-auto fw-bold" style="font-size: 10px; border-color: #ddd; color: #b78846;">View Details</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>

<%- include('../partials/footer') %>

<script>
  const product = <%- JSON.stringify(product) %>;
  let selectedColor = '<%= colors[0] || "" %>';
  let selectedSize = '<%= sizes[0] || "" %>';
  let quantity = 1;

  // Initialize
  window.onload = () => {
    updateStockDisplay();
    // If first color has specific images, load them
    const colVariant = product.variants.find(v => v.type === 'Color' && v.value === selectedColor);
    if(colVariant && colVariant.images && colVariant.images.length > 0) {
        swapGallery(colVariant.images);
    }
    initZoom();
  };

  function initZoom() {
    const container = document.getElementById('mainImgContainer');
    const img = document.getElementById('mainDisplayImg');

    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      
      img.style.transformOrigin = `${x}% ${y}%`;
    });

    container.addEventListener('mouseenter', () => {
      container.classList.add('zoomed');
    });

    container.addEventListener('mouseleave', () => {
      container.classList.add('zoomed'); // Wait, toggle it off!
      container.classList.remove('zoomed');
      img.style.transformOrigin = 'center center';
    });
  }

  function selectColor(el, color) {
    selectedColor = color;
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    
    // Find variant with these images
    const variant = product.variants.find(v => v.type === 'Color' && v.value === color);
    if(variant && variant.images && variant.images.length > 0) {
      swapGallery(variant.images);
    } else {
      // Fallback to base product images
      swapGallery(product.images);
    }
    
    updateStockDisplay();
    updateTitle();
  }

  function selectSize(el, size) {
    selectedSize = size;
    document.querySelectorAll('.size-chip').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    updateStockDisplay();
    updateTitle();
  }

  function updateMainImage(el, src) {
    document.getElementById('mainDisplayImg').src = src;
    document.querySelectorAll('.thumbnail-item').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  function swapGallery(images) {
    const mainImg = document.getElementById('mainDisplayImg');
    const thumbContainer = document.getElementById('thumbContainer');
    
    mainImg.src = images[0];
    
    let html = '';
    images.forEach((img, idx) => {
      html += `
        <div class="thumbnail-item ${idx===0 ? 'active' : ''}" onclick="updateMainImage(this, '${img}')">
          <img src="${img}" alt="Thumbnail">
        </div>
      `;
    });
    thumbContainer.innerHTML = html;
  }

  function getSelectedVariant() {
    if (!product.variants || product.variants.length === 0) return null;

    // Prioritize specific selection. If multiple exist, we pick the one matching current state.
    // In this model, we'll favor Color if both are present, or whichever matches.
    let variant = null;
    if (selectedColor) {
      variant = product.variants.find(v => v.type === 'Color' && v.value === selectedColor);
    }
    
    // If not found by color or color not selected, try size
    if (!variant && selectedSize) {
      variant = product.variants.find(v => (v.type === 'Size' || v.type === 'Storage') && v.value === selectedSize);
    }
    
    return variant;
  }

  function updateStockDisplay() {
    const variant = getSelectedVariant();
    const stockInfo = document.getElementById('stockInfo');
    const stock = variant ? variant.stock : product.stock;

    if(stock <= 0) {
      stockInfo.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> OUT OF STOCK';
      stockInfo.className = 'stock-status out-stock';
    } else if(stock < 5) {
      stockInfo.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ONLY ${stock} LEFT IN STOCK`;
      stockInfo.className = 'stock-status low-stock';
    } else {
      stockInfo.innerHTML = '<i class="fa-solid fa-circle-check"></i> IN STOCK';
      stockInfo.className = 'stock-status in-stock';
    }
  }

  function updateTitle() {
    // Optional: match mockup by adding (Color, Size) to title 
    // const baseName = product.name;
    // document.querySelector('.product-title').innerText = `${baseName} ( ${selectedColor}${selectedSize ? ', ' + selectedSize : ''} )`;
  }

  async function toggleWishlist(productId) {
    try {
      const res = await fetch('/user/wishlist/toggle', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ productId })
      });

      if (res.status === 401) {
        window.location.href = '/user/login';
        return;
      }

      const data = await res.json();
      if (data.success) {
        Swal.fire({
          toast: true,
          position: 'top-end',
          icon: 'success',
          title: data.message,
          showConfirmButton: false,
          timer: 3000
        });
      } else {
        if (data.message === 'Please log in to continue.') {
          window.location.href = '/user/login';
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: data.message || 'Login required'
          });
        }
      }
    } catch (err) {
      console.error(err);
    }
  }

  function updateQty(delta) {
    quantity += delta;
    if(quantity < 1) quantity = 1;
    document.getElementById('qtyVal').innerText = quantity;
  }

  async function handleAddToCart() {
    try {
      const variant = getSelectedVariant();
      const variantId = variant ? variant._id : null;

      const url = `/user/cart/add/${product._id}?qty=${quantity}${variantId ? '&variantId=' + variantId : ''}`;
      const res = await fetch(url, {
        headers: { 'Accept': 'application/json' }
      });

      if (res.status === 401) {
        window.location.href = '/user/login';
        return;
      }

      const data = await res.json();
      if(data.success) {
        Swal.fire({
          title: 'Added to Cart!',
          text: 'This product has been added to your shopping cart.',
          icon: 'success',
          showCancelButton: true,
          confirmButtonColor: '#c26a00',
          cancelButtonColor: '#1a1a1a',
          confirmButtonText: 'Go to Cart',
          cancelButtonText: 'Continue Shopping'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = '/user/cart';
          }
        });
      } else {
        if (data.message === 'Please log in to continue.') {
          window.location.href = '/user/login';
        } else {
          Swal.fire({
            title: 'Error',
            text: data.message || 'Could not add product to cart',
            icon: 'error',
            confirmButtonColor: '#c26a00'
          });
        }
      }
    } catch (err) {
      Swal.fire({
        title: 'Oops!',
        text: 'Something went wrong. Please try again.',
        icon: 'warning',
        confirmButtonColor: '#c26a00'
      });
    }
  }

  function handleBuyNow() {
    handleAddToCart();
  }

</script>

</body>
</html>

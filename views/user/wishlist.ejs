<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - LuxeCarry</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

</head>
<body>

<%- include('../partials/navbar') %>

<div class="container wishlist-container">
    
    <div class="wishlist-header">
        <div>
            <h1 class="heading-serif">My Wishlist</h1>
            <p><%= wishlist.items.length %> items curated in your collection</p>
        </div>
        <a href="javascript:void(0)" class="share-link">
            <i class="fa-solid fa-share-nodes"></i> Share Wishlist
        </a>
    </div>

    <% if(wishlist.items.length === 0) { %>
        <div class="empty-wishlist">
            <i class="fa-regular fa-heart"></i>
            <h2 class="heading-serif">Your wishlist is empty</h2>
            <p class="text-muted">Save your favorite items to keep track of them.</p>
            <a href="/user/shop" class="btn-explore">Explore Collection</a>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% wishlist.items.forEach(item => { %>
                <% if(item.product) { %>
                    <% 
                        const isAvailable = item.product.isActive && item.product.category && item.product.category.isActive && !item.product.category.isDeleted;
                        const linkHref = isAvailable ? `/user/product/${item.product._id}` : 'javascript:void(0)';
                        const linkClass = isAvailable ? '' : 'unavailable-link';
                    %>
                    <div class="col-md-6 col-lg-4" id="item-<%= item.product._id %>">
                        <div class="wishlist-card">
                            <div class="img-wrapper">
                                <a href="<%= linkHref %>" class="<%= linkClass %>" data-id="<%= item.product._id %>">
                                    <img src="<%= item.product.images[0] %>" alt="<%= item.product.name %>">
                                </a>
                                <div class="remove-icon wishlist-action-btn" data-action="remove" data-id="<%= item.product._id %>">
                                    <i class="fa-solid fa-heart"></i>
                                </div>
                                <% if(item.product.offer > 0) { %>
                                    <div class="sale-tag">Sale</div>
                                <% } %>
                            </div>
                            
                            <div class="card-body p-0">
                                <span class="brand-label"><%= (item.product.category && typeof item.product.category === 'object' && item.product.category.name) ? item.product.category.name : 'LuxeCarry' %></span>
                                <h3 class="product-name">
                                    <a href="<%= linkHref %>" class="text-dark text-decoration-none <%= linkClass %>" data-id="<%= item.product._id %>">
                                        <%= item.product.name %>
                                    </a>
                                </h3>
                                
                                <div class="price-section">
                                    <% 
                                        const finalPrice = Math.round(item.product.price - (item.product.price * (item.product.offer || 0) / 100));
                                    %>
                                    <span class="current-price">₹<%= finalPrice.toLocaleString() %></span>
                                    <% if(item.product.offer > 0) { %>
                                        <span class="original-price">₹<%= item.product.price.toLocaleString() %></span>
                                    <% } %>
                                </div>

                                <div id="wishlist-error-<%= item.product._id %>" class="text-danger mb-3" style="font-size: 12px; font-weight: 600; display: none;"></div>

                                <div class="card-actions">
                                    <button class="btn-add-cart wishlist-action-btn <%= linkClass %>" data-action="move-to-cart" data-id="<%= item.product._id %>">Add to Cart</button>
                                    <a href="<%= linkHref %>" class="btn btn-buy-now text-center text-white text-decoration-none <%= linkClass %>" data-id="<%= item.product._id %>">Buy Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            <% }) %>
        </div>
    <% } %>

</div>

<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    // Shared functionality for Shop and Wishlist
    document.addEventListener('click', async (e) => {
        // Handle unavailable links first
        const unavailableLink = e.target.closest('.unavailable-link');
        if (unavailableLink) {
            e.preventDefault();
            e.stopPropagation();
            const productId = unavailableLink.dataset.id;
            const errorBox = document.getElementById(`wishlist-error-${productId}`);
            if (errorBox) {
                errorBox.innerHTML = `<i class="fa-solid fa-circle-exclamation"></i> Product is currently unavailable`;
                errorBox.style.display = 'block';
            }
            return;
        }

        // Toggle Wishlist (Shop/Product Page)
        const wishlistToggle = e.target.closest('.wishlist-toggle');
        if (wishlistToggle) {
            e.preventDefault();
            const productId = wishlistToggle.dataset.id;
            await handleToggleWishlist(productId, wishlistToggle);
        }

        // Wishlist Page Actions
        const wishlistBtn = e.target.closest('.wishlist-action-btn');
        if (wishlistBtn) {
            const action = wishlistBtn.dataset.action;
            const productId = wishlistBtn.dataset.id;
            if (action === 'remove') {
                handleWishlistRemove(productId);
            } else if (action === 'move-to-cart') {
                handleMoveToCart(productId);
            }
        }

        // Add to Cart (Shop Page)
        const addToCartBtn = e.target.closest('.add-to-cart-btn');
        if (addToCartBtn) {
            const productId = addToCartBtn.dataset.id;
            handleAddToCart(productId);
        }
    });

    async function handleToggleWishlist(productId, element) {
        try {
            const res = await fetch('/user/wishlist/toggle', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            });

            if (res.status === 401) {
                window.location.href = '/user/login';
                return;
            }

            const data = await res.json();
            if (data.success) {
                showToast(data.message);
                const icon = element.querySelector('i');
                if (data.message.includes('added')) {
                    icon.classList.replace('fa-regular', 'fa-solid');
                    icon.style.color = '#ef4444';
                } else {
                    icon.classList.replace('fa-solid', 'fa-regular');
                    icon.style.color = '#6b7280';
                }
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function handleWishlistRemove(productId) {
        try {
            const res = await fetch(`/user/wishlist/${productId}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                removeWishlistItemDOM(productId);
                showToast('Removed from wishlist');
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function handleMoveToCart(productId) {
        try {
            const res = await fetch('/user/cart/add/' + productId, {
                headers: { 'Accept': 'application/json' }
            });

            if (res.status === 401) {
                window.location.href = '/user/login';
                return;
            }

            const data = await res.json();
            if (data.success) {
                removeWishlistItemDOM(productId);
                
                // Update global cart badge
                updateCartBadge(data.cartCount);

                Swal.fire({
                    title: 'Moved to Cart!',
                    text: 'Item is now in your shopping cart.',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonColor: '#b78846',
                    cancelButtonColor: '#1a1a1a',
                    confirmButtonText: 'View Cart',
                    cancelButtonText: 'Continue'
                }).then((result) => {
                    if (result.isConfirmed) window.location.href = '/user/cart';
                });
            } else {
                if (data.message === "Please select a variant" || data.message === "Please select a product option") {
                    // Redirect to product page so they can choose their size/color
                    window.location.href = `/user/product/${productId}`;
                    return;
                }
                
                const errorBox = document.getElementById(`wishlist-error-${productId}`);
                if (errorBox) {
                    errorBox.innerHTML = `<i class="fa-solid fa-circle-exclamation"></i> ${data.message || 'Out of stock'}`;
                    errorBox.style.display = 'block';
                } else {
                    showToast(data.message || 'Error moving to cart', 'error');
                }
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function handleAddToCart(productId) {
        try {
            const res = await fetch('/user/cart/add/' + productId, {
                headers: { 'Accept': 'application/json' }
            });

            if (res.status === 401) {
                window.location.href = '/user/login';
                return;
            }

            const data = await res.json();
            if (data.success) {
                showToast('Added to cart!');
                
                // Update global cart badge
                updateCartBadge(data.cartCount);
            } else {
                showToast(data.message || 'Out of stock', 'error');
            }
        } catch (err) {
            console.error(err);
        }
    }

    function removeWishlistItemDOM(productId) {
        const el = document.getElementById(`item-${productId}`);
        if (el) {
            el.style.transition = 'all 0.3s ease';
            el.style.opacity = '0';
            el.style.transform = 'scale(0.9)';
            setTimeout(() => {
                el.remove();
                if (document.querySelectorAll('.wishlist-card').length === 0) {
                    location.reload(); // Fallback to show empty state
                }
            }, 300);
        }
    }

    function updateCartBadge(count) {
        const badge = document.getElementById('cart-count-badge');
        if (badge) {
            badge.innerText = count;
            badge.style.display = count > 0 ? 'flex' : 'none';
        }
    }

    function showToast(msg, type = 'success') {
        Toastify({
            text: msg,
            duration: 2500,
            gravity: "top",
            position: "right",
            background: type === 'success' ? "#b78846" : "#dc3545",
        }).showToast();
    }
});
</script>

</body>
</html>

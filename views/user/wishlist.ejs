<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - LuxeCarry</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

</head>
<body>

<%- include('../partials/navbar') %>

<div class="container wishlist-container">
    
    <div class="wishlist-header">
        <div>
            <h1 class="heading-serif">My Wishlist</h1>
            <p><%= wishlist.items.length %> items curated in your collection</p>
        </div>
        <a href="javascript:void(0)" class="share-link">
            <i class="fa-solid fa-share-nodes"></i> Share Wishlist
        </a>
    </div>

    <% if(wishlist.items.length === 0) { %>
        <div class="empty-wishlist">
            <i class="fa-regular fa-heart"></i>
            <h2 class="heading-serif">Your wishlist is empty</h2>
            <p class="text-muted">Save your favorite items to keep track of them.</p>
            <a href="/user/shop" class="btn-explore">Explore Collection</a>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% wishlist.items.forEach(item => { %>
                <% if(item.product) { %>
                    <div class="col-md-6 col-lg-4" id="item-<%= item.product._id %>">
                        <div class="wishlist-card">
                            <div class="img-wrapper">
                                <a href="/user/product/<%= item.product._id %>">
                                    <img src="<%= item.product.images[0] %>" alt="<%= item.product.name %>">
                                </a>
                                <div class="remove-icon" onclick="removeItem('<%= item.product._id %>')">
                                    <i class="fa-solid fa-heart"></i>
                                </div>
                                <% if(item.product.offer > 0) { %>
                                    <div class="sale-tag">Sale</div>
                                <% } %>
                            </div>
                            
                            <div class="card-body p-0">
                                <span class="brand-label"><%= (item.product.category && typeof item.product.category === 'object' && item.product.category.name) ? item.product.category.name : 'LuxeCarry' %></span>
                                <h3 class="product-name"><%= item.product.name %></h3>
                                
                                <div class="price-section">
                                    <% 
                                        const finalPrice = Math.round(item.product.price - (item.product.price * (item.product.offer || 0) / 100));
                                    %>
                                    <span class="current-price">₹<%= finalPrice.toLocaleString() %></span>
                                    <% if(item.product.offer > 0) { %>
                                        <span class="original-price">₹<%= item.product.price.toLocaleString() %></span>
                                    <% } %>
                                </div>

                                <div class="card-actions">
                                    <button class="btn-add-cart" onclick="addToCart('<%= item.product._id %>')">Add to Cart</button>
                                    <a href="/user/product/<%= item.product._id %>" class="btn btn-buy-now text-center text-white text-decoration-none">Buy Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            <% }) %>
        </div>
    <% } %>

</div>

<%- include('../partials/footer') %>

<script>
    async function removeItem(productId) {
        try {
            const res = await fetch(`/user/wishlist/${productId}`, {
                method: 'DELETE'
            });
            const data = await res.json();
            if(data.success) {
                const el = document.getElementById(`item-${productId}`);
                el.style.opacity = '0';
                setTimeout(() => {
                    el.remove();
                    // If no items left, reload to show empty state
                    if(document.querySelectorAll('.col-md-6').length === 0) {
                        window.location.reload();
                    }
                }, 300);
            }
        } catch(err) {
            console.error(err);
        }
    }

    async function addToCart(id) {
        try {
            const res = await fetch('/user/cart/add/' + id);
            const data = await res.json();
            if(data.success) {
                Swal.fire({
                    title: 'Added to Cart!',
                    text: 'Item moved from wishlist to your shopping cart.',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonColor: '#c26a00',
                    cancelButtonColor: '#1a1a1a',
                    confirmButtonText: 'Go to Cart',
                    cancelButtonText: 'Continue Shopping'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '/user/cart';
                    } else {
                        // Reload to reflect removal from wishlist
                        window.location.reload();
                    }
                });
            } else {
                Swal.fire({
                    title: 'Error',
                    text: data.message || 'Could not add product to cart',
                    icon: 'error'
                });
            }
        } catch(err) {
            console.error(err);
        }
    }
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>My Orders | LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/user/navbar') %>

<div class="orders-page-wrapper">

<div class="container py-5">
    <div class="row">
        <!-- Sidebar -->
        <%- include("../partials/user/sidebar", { user, activePage: 'orders' }) %>

        <!-- Main Content Column -->
        <div class="col-lg-9 col-md-8">

            <!-- Header -->
            <div class="dashboard-page-header">

                <h1 class="dashboard-page-title">
                    My Orders
                </h1>

                <p class="dashboard-page-subtitle">
                    Track and manage your orders
                </p>

            </div>

    <!-- Filters -->
    <div class="orders-filter-bar d-flex align-items-center gap-3 flex-wrap">

        <div class="orders-search-box flex-grow-1" style="min-width: 250px;">

            <input type="text"
                   id="orders-search-input"
                   placeholder="Search by Order ID or Product Name...">

            <i class="fa-solid fa-magnifying-glass"></i>

        </div>

        <div class="d-flex align-items-center gap-2">
            <select id="orders-filter-select" class="orders-filter-select m-0">

                <option value="All">All Orders</option>
                <option value="Pending">Pending</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Shipped">Shipped</option>
                <option value="Out for Delivery">Out for Delivery</option>
                <option value="Delivered">Delivered</option>
                <option value="Cancelled">Cancelled</option>
                <option value="Returned">Returned</option>

            </select>

            <button id="orders-clear-btn" class="btn btn-outline-secondary rounded-pill px-3 py-2" style="font-size: 14px; border: 1px solid #e5e7eb; border-radius: 12px; display: none;">
                Clear
            </button>
        </div>

    </div>
    <div id="orders-list-container">
    <% if(orders.length > 0){ %>
    <% orders.forEach(order => { %>

    <div class="lc-order-group-card">

    <!-- ORDER HEADER -->
    <div class="lc-order-group-header">

        <div>

            <h5 class="mb-1">
                Order #<%= order.orderId %>
            </h5>

            <small class="text-muted">
                <%= new Date(order.createdAt)
                    .toDateString() %>
            </small>

        </div>
        <%
const hasDeliveredItem = order.items.some(
    item => item.status === 'Delivered'
);
%>

<% if (hasDeliveredItem) { %>

<a
    href="/user/orders/invoice/<%= order._id %>"
    class="btn btn-light border btn-sm rounded-pill text-secondary">

    <i class="fa-solid fa-download me-1"></i>

    Invoice

</a>

<% } %>
        <!--<a href="/user/orders/invoice/<%= order._id %>"
            class="btn btn-light border btn-sm rounded-pill text-secondary">
            <i class="fa-solid fa-download me-1"></i>
            Invoice
            
        </a>-->

    </div>

    <!-- PRODUCTS -->
    <div class="d-flex flex-column gap-3">

        <% order.items.forEach(item => { %>

        <div class="lc-product-order-card">

            <!-- LEFT -->
            <div class="d-flex gap-3 align-items-center">

                <img
                    src="<%= item.product?.thumbnail?.url || '/images/no-image.png' %>"
                    class="lc-product-order-image">

                <div>

                    <h6 class="mb-1">
                        <%= item.product?.name %>
                    </h6>

                    <div class="text-muted small mb-1">

                        Variant:
                        <%= item.variantValue || '-' %>

                    </div>

                    <div class="text-muted small">

                        Qty:
                        <%= item.quantity %>

                    </div>

                </div>

            </div>

           <!-- RIGHT -->
<div
    class="d-flex flex-column
    align-items-end
    justify-content-between
    h-100">

   
<div
    class="d-flex
    align-items-center
    gap-3">

    
    <div
        class="lc-order-status-badge
        <%= item.status
            .toLowerCase()
            .replace(/\s+/g,'-') %>">

        <%=item.status %>

    </div>
    <a
        href="/user/orders/<%= order._id %>/product/<%= item.id %>"
        class="btn btn-view-details btn-sm rounded-pill">

        View Details

    </a>

</div>
   

       

    <!-- PRICE -->
    <div class="fw-bold fs-5 mt-4">

        Rs.
        <%= (
            item.totalPrice || (item.price * item.quantity) || 0
        ).toLocaleString() %>

    </div>

</div>

        </div>

        <% }) %>

    </div>

</div>

<% }) %>

           

    <% } else { %>

    <div class="text-center py-5">

        <i class="fa-solid fa-bag-shopping fs-1 text-muted mb-4"></i>

        <h3>No Orders Yet</h3>

        <p class="text-muted">
            Your orders will appear here once you place them.
        </p>

        <a href="/user/shop"
           class="btn-order-primary mt-3">

           Continue Shopping

        </a>

    </div>

    <% } %>
    </div>

        </div>
    </div> 
</div> 
<%- include('../partials/user/footer-short') %>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('orders-search-input');
    const filterSelect = document.getElementById('orders-filter-select');
    const listContainer = document.getElementById('orders-list-container');
    const clearBtn = document.getElementById('orders-clear-btn');

    let debounceTimeout = null;

    const updateClearButtonVisibility = () => {
        if (searchInput.value.trim() !== '' || filterSelect.value !== 'All') {
            clearBtn.style.display = 'inline-block';
        } else {
            clearBtn.style.display = 'none';
        }
    };

    const performFilter = async () => {
        const searchValue = searchInput.value.trim();
        const filterValue = filterSelect.value;
        updateClearButtonVisibility();

        try {
            const response = await fetch(`/user/orders/filter?search=${encodeURIComponent(searchValue)}&status=${encodeURIComponent(filterValue)}`);
            const data = await response.json();

            if (data.success) {
                renderOrders(data.orders);
            }
        } catch (error) {
            console.error('Error fetching filtered orders:', error);
        }
    };

    const renderOrders = (orders) => {
        if (!orders || orders.length === 0) {
            listContainer.innerHTML = `
                <div class="text-center py-5">
                    <i class="fa-solid fa-bag-shopping fs-1 text-muted mb-4"></i>
                    <h3>No matching orders found</h3>
                    <p class="text-muted">Try adjusting your search terms or status filter.</p>
                    <a href="/user/shop" class="btn-order-primary mt-3">Continue Shopping</a>
                </div>
            `;
            return;
        }

        let html = '';
        orders.forEach(order => {
            let itemsHtml = '';
            order.items.forEach(item => {
                const totalPriceVal = item.totalPrice || (item.price * item.quantity) || 0;
                const pName = item.productName || item.product?.name || 'Product';
                const pImage = item.productImage || item.product?.thumbnail?.url || '/images/no-image.png';
                const variantText = item.variantValue || '-';
                const badgeClass = item.status.toLowerCase().replace(/\s+/g, '-');
                const itemId = item._id || item.id;

                itemsHtml += `
                    <div class="lc-product-order-card">
                        <!-- LEFT -->
                        <div class="d-flex gap-3 align-items-center">
                            <img src="${pImage}" class="lc-product-order-image" alt="${pName}">
                            <div>
                                <h6 class="mb-1">${pName}</h6>
                                <div class="text-muted small mb-1">Variant: ${variantText}</div>
                                <div class="text-muted small">Qty: ${item.quantity}</div>
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="d-flex flex-column align-items-end justify-content-between h-100">
                            <div class="d-flex align-items-center gap-3">
                                <div class="lc-order-status-badge ${badgeClass}">
                                    ${item.status}
                                </div>
                                <a href="/user/orders/${order._id}/product/${itemId}" class="btn btn-view-details btn-sm rounded-pill">
                                    View Details
                                </a>
                            </div>

                            <!-- PRICE -->
                            <div class="fw-bold fs-5 mt-4">
                                Rs. ${totalPriceVal.toLocaleString()}
                            </div>
                        </div>
                    </div>
                `;
            });

            const orderDateStr = new Date(order.createdAt).toDateString();

            html += `
                <div class="lc-order-group-card">
                    <!-- ORDER HEADER -->
                    <div class="lc-order-group-header">
                        <div>
                            <h5 class="mb-1">Order #${order.orderId}</h5>
                            <small class="text-muted">${orderDateStr}</small>
                        </div>
                      ${order.items
    .some(item => item.status === 'Delivered')
    ? `
        <a href="/user/orders/invoice/${order._id}"
           class="btn btn-light border btn-sm rounded-pill text-secondary">

            <i class="fa-solid fa-download me-1"></i>

            Invoice

        </a>
    `:''}
                    </div>

                    <!-- PRODUCTS -->
                    <div class="d-flex flex-column gap-3">
                        ${itemsHtml}
                    </div>
                </div>
            `;
        });

        listContainer.innerHTML = html;
    };

    // Event Listeners
    searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimeout);
        debounceTimeout = setTimeout(performFilter, 300);
    });

    filterSelect.addEventListener('change', performFilter);

    if (clearBtn) {
        clearBtn.addEventListener('click', () => {
            searchInput.value = '';
            filterSelect.value = 'All';
            performFilter();
        });
    }
});
</script>

</body>
</html>
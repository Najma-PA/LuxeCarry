<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>My Orders | LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/user/navbar') %>

<div class="orders-page-wrapper">

<div class="container">

    <!-- Header -->
    <div class="orders-page-header">

        <h1 class="orders-page-title">
            My Orders
        </h1>

        <p class="orders-page-subtitle">
            Track and manage your luxury purchases
        </p>

    </div>

    <!-- Filters -->
    <div class="orders-filter-bar">

        <div class="orders-search-box">

            <input type="text"
                   placeholder="Search by Order ID...">

            <i class="fa-solid fa-magnifying-glass"></i>

        </div>

        <select class="orders-filter-select">

            <option>All Orders</option>
            <option>Pending</option>
            <option>Delivered</option>
            <option>Cancelled</option>
            <option>Returned</option>

        </select>

    </div>

    <!-- Orders -->

    <% if(orders.length > 0) { %>

        <% orders.forEach(order => { %>

        <div class="lc-order-card">

            <!-- Header -->
            <div class="lc-order-card-header">

                <div class="lc-order-meta">

                    <div class="lc-order-meta-item">

                        <span>Order ID</span>

                        <strong>
                            #<%= order._id.toString().slice(-6).toUpperCase() %>
                        </strong>

                    </div>

                    <div class="lc-order-meta-item">

                        <span>Date</span>

                        <strong>
                            <%= new Date(order.createdAt)
                            .toLocaleDateString('en-IN',{
                                day:'numeric',
                                month:'short',
                                year:'numeric'
                            }) %>
                        </strong>

                    </div>

                    <div class="lc-order-meta-item">

                        <span>Total</span>

                        <strong>
                            ₹<%= order.totalAmount.toLocaleString() %>
                        </strong>

                    </div>

                </div>

                <div class="d-flex align-items-center gap-3">

                    <span class="order-status-badge
                    <%= order.status === 'Delivered'
                        ? 'order-status-delivered'
                        : order.status === 'Cancelled'
                        ? 'order-status-cancelled'
                        : order.status === 'Returned'
                        ? 'order-status-returned'
                        : 'order-status-pending' %>">

                        <i class="fa-solid fa-circle"></i>

                        <%= order.status %>

                    </span>

                    <a href="/user/orders/<%= order._id %>"
                       class="btn-order-outline">

                       View Details

                    </a>

                </div>

            </div>

            <!-- Products -->
            <div class="lc-order-card-body">

                <% order.items.forEach(item => { %>

                <div class="lc-order-product">

                    <div class="lc-order-product-left">

                        <img
                        src="<%= item.product.productImage?.[0] || '/images/no-image.png' %>"
                        class="lc-order-product-image">

                        <div>

                            <h5 class="lc-order-product-name">
                                <%= item.product.productName %>
                            </h5>

                            <% if(item.variantValue){ %>

                            <div class="lc-order-product-meta">
                                Variant: <%= item.variantValue %>
                            </div>

                            <% } %>

                            <div class="lc-order-product-meta">
                                Qty: <%= item.quantity %>
                            </div>

                        </div>

                    </div>

                    <div class="lc-order-product-price">

                        ₹<%= item.price.toLocaleString() %>

                    </div>

                </div>

                <% }) %>

            </div>

        </div>

        <% }) %>

    <% } else { %>

    <div class="text-center py-5">

        <i class="fa-solid fa-bag-shopping fs-1 text-muted mb-4"></i>

        <h3>No Orders Yet</h3>

        <p class="text-muted">
            Your orders will appear here once you place them.
        </p>

        <a href="/user/shop"
           class="btn-order-primary mt-3">

           Continue Shopping

        </a>

    </div>

    <% } %>

</div>

</div>

<%- include('../partials/footer') %>

</body>
</html>
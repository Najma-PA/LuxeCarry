<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/style.css">


</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<body>

<%- include('../partials/navbar') %>


<!-- HERO -->

<div class="container category-section mt-5">

<div class="hero">

<img src="/images/hero-bag.png">

<div class="hero-text">

<h2>Carry Confidence<br>in Every Style</h2>

<p class="text-muted">
Explore our premium collection of bags and accessories
</p>
<a href="/shop" class="shop-btn">Shop Now</a>
<!--
<button class="shop-btn">Shop Now</button>
-->
</div>

</div>

</div>


<!-- CATEGORY -->

<div class="container mt-5">

<h5 class="text-center mb-4">Shop by Category</h5>

<div class="row g-4">
  <% categories.forEach(cat => { %>

<div class="col-md-6">

<div class="category-card">
<img src="<%= cat.image || '/images/tote.png' %>">


<div class="category-title">
<h5><%= cat.name %></h5>
</div>

<a href="/shop?category=<%= cat._id %>" class="stretched-link"></a>
</div>

</div>
<% }) %>
<!--
<div class="col-md-6">

<div class="category-card">

<img src="/images/sling.png">

<div class="category-title">
<h5>Sling Bags</h5>
</div>

</div>

</div>
-->

</div>

</div>
<!--Dynamic Products-->
<div class="container mt-5">

<div class="d-flex justify-content-between mb-3">

<h5>New Arrivals</h5>

<a href="/user/shop">View All</a>

</div>

<div class="row g-4">

<% products.forEach(p => { %>

<div class="col-md-3">

<div class="product-card">

<img src="<%= p.images[0] %>">

<p class="mt-2"><%= p.name %></p>

<p class="price">
₹<%= p.finalPrice %>
<small class="text-muted text-decoration-line-through">
₹<%= p.price %>
</small>
</p>

<div class="d-flex justify-content-center gap-2 mt-2">

<button class="add-btn" onclick="addToCart('<%= p._id %>')">
Add to Cart
</button>

<a href="/product/<%= p._id %>" class="buy-btn text-decoration-none">
View
</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>

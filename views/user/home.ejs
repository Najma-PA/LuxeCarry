<!-- HERO / BANNER CAROUSEL -->
<div class="container mt-5">
  <% if(typeof banners !== 'undefined' && banners.length > 0) { %>
    <div id="heroCarousel" class="carousel slide rounded-4 overflow-hidden" data-bs-ride="carousel">
      <div class="carousel-indicators">
        <% banners.forEach((banner, idx) => { %>
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= idx %>" class="<%= idx === 0 ? 'active' : '' %>" aria-label="Slide <%= idx + 1 %>"></button>
        <% }) %>
      </div>
      <div class="carousel-inner" >
        <% banners.forEach((banner, idx) => { %>
          <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
            <div class="hero position-relative overflow-hidden rounded-4">
              <img src="<%= banner.image.url %>" class="d-block w-100" style="height: 450px; object-fit: cover;" alt="<%= banner.title %>">
              <div class="hero-text position-absolute top-50 start-0 translate-middle-y ps-5 ms-4">
                <h2 class="text-white" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);"><%= banner.title %></h2>
                <p class="text-white opacity-75" style="max-width: 450px; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);">
                  <%= banner.subtitle %>
                </p>
                <a href="/user/shop" class="shop-btn px-4 py-2 text-decoration-none"><%= banner.buttonText %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <% if(banners.length > 1) { %>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
          <span class="carousel-control-next-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Next</span>
        </button>
      <% } %>
    </div>
  <% } else { %>
    <div class="hero">
      <img src="/images/hero-bag.png" alt="Default Hero">
      <div class="hero-text">
        <h2>Carry Confidence<br>in Every Style</h2>
        <p class="text-muted">Explore our premium collection of bags and accessories</p>
        <a href="/user/shop" class="shop-btn">Shop Now</a>
      </div>
    </div>
  <% } %>
</div>


<!-- CATEGORY -->

<div class="container mt-5">

<h5 class="text-center mb-4">Shop by Category</h5>

<div class="row g-4">
  <% categories.forEach(cat => { %>

<div class="col-md-6">

<div class="category-card">
<img src="<%= (cat.image && cat.image.url) ? cat.image.url : '/images/tote.png'%>">



<div class="category-title">
<h5><%= cat.name %></h5>
</div>

<a href="/user/shop?category=<%= cat._id %>" class="stretched-link"></a>
</div>

</div>
<% }) %>


</div>

</div>

<!--Dynamic Products-->
<div class="container mt-5 mb-5">

<div class="d-flex justify-content-between align-items-center mb-4">

<h3 class="fw-bold mb-0" style="font-family: 'Playfair Display', 'Georgia', serif; color: #161b22; letter-spacing: 0.5px;">New Arrivals</h3>

<a href="/user/shop" class="text-decoration-none fw-bold" style="color: #c26a00; font-size: 13px;">View All Collection</a>

</div>

<div class="row" id="product-grid">

<%- include('../partials/user/product-grid',{isHome:true}) %>

</div>

</div>

<!-- OFFER -->

<div class="container mt-5">

<div class="offer row align-items-center">

<div class="col-md-6">

<h6 class="text-uppercase text-muted">LuxeCarry Sale</h6>

<h3>Limited Time Offer<br>Up to 30% Off</h3>

<p>
Upgrade your wardrobe with our best sellers
</p>

<button class="shop-btn">Shop Now</button>

</div>

<div class="col-md-6 text-center">

<img src="/images/offer.png">

</div>

</div>

</div>



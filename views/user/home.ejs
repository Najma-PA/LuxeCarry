<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/style.css">


</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<body>

<%- include('../partials/navbar') %>


<!-- HERO -->

<div class="container category-section mt-5">

<div class="hero">

<img src="/images/hero-bag.png">

<div class="hero-text">

<h2>Carry Confidence<br>in Every Style</h2>

<p class="text-muted">
Explore our premium collection of bags and accessories
</p>
<a href="/user/shop" class="shop-btn">Shop Now</a>

</div>

</div>

</div>


<!-- CATEGORY -->

<div class="container mt-5">

<h5 class="text-center mb-4">Shop by Category</h5>

<div class="row g-4">
  <% categories.forEach(cat => { %>

<div class="col-md-6">

<div class="category-card">
<img src="<%= cat.image || '/images/tote.png'%>">



<div class="category-title">
<h5><%= cat.name %></h5>
</div>

<a href="/user/shop?category=<%= cat._id %>" class="stretched-link"></a>
</div>

</div>
<% }) %>


</div>

</div>
<!--Dynamic Products-->
<div class="container mt-5 mb-5">

<div class="d-flex justify-content-between align-items-center mb-4">

<h3 class="fw-bold mb-0" style="font-family: 'Playfair Display', 'Georgia', serif; color: #161b22; letter-spacing: 0.5px;">New Arrivals</h3>

<a href="/user/shop" class="text-decoration-none fw-bold" style="color: #c26a00; font-size: 13px;">View All Collection</a>

</div>

<div class="row g-4">

<% products.forEach(p => { %>

<div class="col-md-3">

<div class="new-product-card text-start border-0 bg-transparent">

<div class="product-img-container position-relative mb-3" style="background-color: #f4f6f8; border-radius: 16px; padding: 25px; height: 260px; display: flex; align-items: center; justify-content: center;">
    <div class="position-absolute" style="top: 15px; right: 15px; background: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.06); cursor: pointer; z-index: 2;">
        <i class="far fa-heart" style="color: #a0aec0; font-size: 14px;"></i>
    </div>
    <img src="<%= p.images[0] %>" style="max-height: 100%; max-width: 100%; object-fit: contain;">
</div>

<% if (p.offer > 0 || (p.category && p.category.offer > 0)) { 
    let pOffer = Number(p.offer) || 0;
    let cOffer = (p.category && typeof p.category === 'object') ? (Number(p.category.offer) || 0) : 0;
    let bestOffer = Math.max(pOffer, cOffer);
%>
    <span class="badge bg-danger rounded-pill px-2 py-1 mb-2" style="font-size: 9px; font-weight: 600; letter-spacing: 0.5px;"><%= bestOffer %>% OFF</span>
<% } else { %>
    <div style="height: 22px;" class="mb-2"></div>
<% } %>

<div class="text-uppercase fw-bold mb-1" style="color: #c26a00; font-size: 9px; letter-spacing: 0.8px;">
    <%= (p.category && p.category.name) ? p.category.name : 'LUXECARRY PREMIUM' %>
</div>

<h6 class="mb-1 text-truncate" style="font-family: 'Playfair Display', 'Georgia', serif; font-weight: 600; font-size: 15px; color: #2d3748; letter-spacing: 0.2px;"><%= p.name %></h6>

<div class="mb-2 d-flex align-items-baseline">
    <span class="fw-bold" style="font-size: 15px; color: #1a202c;">₹<%= p.finalPrice %></span>
    <% if (p.price > p.finalPrice) { %>
        <span class="text-muted text-decoration-line-through ms-2" style="font-size: 12px;">₹<%= p.price %></span>
    <% } %>
</div>

<div class="mb-3">
    <i class="fas fa-star" style="color: #dcb360; font-size: 9px;"></i>
    <i class="fas fa-star" style="color: #dcb360; font-size: 9px;"></i>
    <i class="fas fa-star" style="color: #dcb360; font-size: 9px;"></i>
    <i class="fas fa-star" style="color: #dcb360; font-size: 9px;"></i>
    <i class="far fa-star" style="color: #dcb360; font-size: 9px;"></i>
</div>

<div class="d-flex gap-2">
    <button class="btn btn-dark w-50 rounded-pill py-1" style="font-size: 11px; font-weight: 600; background-color: #1a1a1a; border: none; letter-spacing: 0.3px;" onclick="addToCart('<%= p._id %>')">
        Add to Cart
    </button>
    <a href="/user/product/<%= p._id %>" class="btn w-50 rounded-pill py-1" style="font-size: 11px; font-weight: 600; background: transparent; color: #c26a00; border: 1px solid #dfc3a3; text-decoration: none; text-align: center; display: inline-block; letter-spacing: 0.3px;">
        Buy Now
    </a>
</div>

</div>

</div>

<% }) %>

</div>

</div>

<!-- OFFER -->

<div class="container mt-5">

<div class="offer row align-items-center">

<div class="col-md-6">

<h6 class="text-uppercase text-muted">LuxeCarry Sale</h6>

<h3>Limited Time Offer<br>Up to 30% Off</h3>

<p>
Upgrade your wardrobe with our best sellers
</p>

<button class="shop-btn">Shop Now</button>

</div>

<div class="col-md-6 text-center">

<img src="/images/offer.png">

</div>

</div>

</div>


<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
  
  window.history.pushState(null, null, location.href);

  window.addEventListener('popstate', function () {
    window.location.href = '/user/home';  // stay inside app
  });
</script>

<script>
async function addToCart(productId) {
  try {
    const res = await fetch('/user/cart/add/' + productId);

    const data = await res.json();

    if (data.success) {
      window.location.href = '/user/cart';
    } else {
      alert(data.message);
    }

  } catch (err) {
    alert('Error adding to cart');
  }
}
</script>

</body>
</html>
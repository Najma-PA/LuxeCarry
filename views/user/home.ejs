<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/style.css">


</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<body>

<%- include('../partials/navbar') %>


<!-- HERO -->

<div class="container category-section mt-5">

<div class="hero">

<img src="/images/hero-bag.png">

<div class="hero-text">

<h2>Carry Confidence<br>in Every Style</h2>

<p class="text-muted">
Explore our premium collection of bags and accessories
</p>

<button class="shop-btn">Shop Now</button>

</div>

</div>

</div>


<!-- CATEGORY -->

<div class="container mt-5">

<h5 class="text-center mb-4">Shop by Category</h5>

<div class="row g-4">

<div class="col-md-6">

<div class="category-card">

<img src="/images/tote.png">

<div class="category-title">
<h5>Tote Bags</h5>
</div>

</div>

</div>

<div class="col-md-6">

<div class="category-card">

<img src="/images/sling.png">

<div class="category-title">
<h5>Sling Bags</h5>
</div>

</div>

</div>

</div>

</div>


<!-- PRODUCTS -->

<div class="container mt-5">

<div class="d-flex justify-content-between mb-3">

<h5>New Arrivals</h5>

<a href="#">View All</a>

</div>

<div class="row g-4">

<div class="col-md-3">

<div class="product-card">

<img src="/images/product4.png">

<p class="mt-2">The Paris Satchel</p>

<p class="price">₹1,499</p>

<div class="d-flex justify-content-center gap-2 mt-2">

<button class="add-btn">
Add to Cart
</button>

<button class="buy-btn">
Buy Now
</button>

</div>

</div>

</div>

<div class="col-md-3">

<div class="product-card">

<img src="/images/product2.png">

<p class="mt-2">Mini Voyage</p>

<p class="price">₹1,899</p>

<div class="d-flex justify-content-center gap-2 mt-2">

<button class="add-btn">
Add to Cart
</button>

<button class="buy-btn">
Buy Now
</button>

</div>

</div>

</div>

<div class="col-md-3">

<div class="product-card">

<img src="/images/product1.png">

<p class="mt-2">Classic Tote</p>

<p class="price">₹2,999</p>

<div class="d-flex justify-content-center gap-2 mt-2">

<button class="add-btn">
Add to Cart
</button>

<button class="buy-btn">
Buy Now
</button>

</div>

</div>

</div>

<div class="col-md-3">

<div class="product-card">

<img src="/images/product3.png">

<p class="mt-2">Ivory Grace</p>

<p class="price">₹1,999</p>

<div class="d-flex justify-content-center gap-2 mt-2">

<button class="add-btn">
Add to Cart
</button>

<button class="buy-btn">
Buy Now
</button>

</div>

</div>

</div>

</div>

</div>


<!-- OFFER -->

<div class="container mt-5">

<div class="offer row align-items-center">

<div class="col-md-6">

<h6 class="text-uppercase text-muted">LuxeCarry Sale</h6>

<h3>Limited Time Offer<br>Up to 30% Off</h3>

<p>
Upgrade your wardrobe with our best sellers
</p>

<button class="shop-btn">Shop Now</button>

</div>

<div class="col-md-6 text-center">

<img src="/images/offer.png">

</div>

</div>

</div>


<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
  
  window.history.pushState(null, null, location.href);

  window.addEventListener('popstate', function () {
    window.location.href = '/user/home';  // stay inside app
  });
</script>

</body>
</html>
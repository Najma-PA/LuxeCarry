<!-- OFFER -->

<div class="container mt-5">

<div class="offer row align-items-center">

<div class="col-md-6">

<h6 class="text-uppercase text-muted">LuxeCarry Sale</h6>

<h3>Limited Time Offer<br>Up to 30% Off</h3>

<p>
Upgrade your wardrobe with our best sellers
</p>


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - LuxeCarry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

</head>
<body>

<%- include('../partials/user/navbar') %>

<div class="checkout-container">
    <div class="checkout-header">
        <h1>Checkout</h1>
    </div>

    <form id="checkoutForm" action="/user/order-place" method="POST">
        <div class="row g-5">
            <!-- LEFT COLUMN: Shipping & Payment -->
            <div class="col-lg-7">
                
                <!-- Shipping Address -->
                <div class="section-title">
                    <i class="fa-solid fa-location-dot"></i> Shipping Address
                </div>

                <div class="checkout-form-card">
                    <% 
                    const selectedAddress = addresses && addresses.length > 0 
                        ? addresses.find(addr => addr.isDefault) || addresses[0] 
                        : null; 
                    %>
                    <input type="hidden" name="addressId" id="selectedAddressId" value="<%= selectedAddress ? selectedAddress._id : '' %>">

                    <% if (addresses && addresses.length > 0) { %>
                        <div class="address-cards-grid row g-3">
                            <% addresses.forEach(addr => { %>
                                <div class="col-md-6">
                                    <div class="lc-checkout-address-card <%= selectedAddress && selectedAddress._id.toString() === addr._id.toString() ? 'selected' : '' %>" 
                                         data-id="<%= addr._id %>"
                                         onclick="selectCheckoutAddress('<%= addr._id %>')">
                                        <div class="lc-address-card-header d-flex justify-content-between align-items-start">
                                            <h6 class="mb-1 text-truncate fw-bold" style="max-width: 70%;" title="<%= addr.name %>"><%= addr.name %></h6>
                                            <% if (addr.isDefault) { %>
                                                <span class="badge lc-badge-default">Default</span>
                                            <% } %>
                                        </div>
                                        <div class="lc-address-card-body mt-2">
                                            <p class="mb-1 text-muted small"><i class="fa fa-phone me-1"></i> <%= addr.phone %></p>
                                            <p class="mb-1 text-muted small text-truncate"><i class="fa fa-map-marker-alt me-1"></i> <%= addr.street %></p>
                                            <p class="mb-1 text-muted small text-truncate"><%= addr.city %>, <%= addr.state %> - <%= addr.pincode %></p>
                                            <p class="mb-0 text-muted small"><%= addr.country || 'India' %></p>
                                        </div>
                                        <div class="lc-address-card-footer mt-3 pt-2 border-top d-flex justify-content-end">
                                            <a href="/user/editAddress/<%= addr._id %>?redirect=checkout" 
                                               class="btn btn-sm btn-outline-secondary py-1 px-3 rounded-pill fw-bold" 
                                               style="font-size: 11px;"
                                               onclick="event.stopPropagation();">
                                                <i class="fa fa-edit me-1"></i> Edit
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                        <div class="mt-4 pt-2 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <a href="/user/addAddress?redirect=checkout" class="btn btn-theme-premium">
                                <i class="fa fa-plus me-1"></i> Add New Address
                            </a>
                            <a href="/user/addresses?redirect=checkout" class="btn btn-link text-decoration-none text-muted fw-bold" style="font-size: 13px;">
                                <i class="fa-solid fa-location-dot me-1"></i> Manage Addresses
                            </a>
                        </div>
                    <% } else { %>
                        <!-- No Saved Address Scenario -->
                        <div class="text-center py-5">
                            <div class="mb-3 text-muted">
                                <i class="fa-solid fa-map-location-dot" style="font-size: 3.5rem; color: #b78846; opacity: 0.8;"></i>
                            </div>
                            <h5 class="fw-bold mb-2">No saved addresses found</h5>
                            <p class="text-muted small mb-4" style="max-width: 320px; margin: 0 auto;">Please add a shipping address to proceed with your premium order placement.</p>
                            <a href="/user/addAddress?redirect=checkout" class="btn btn-theme-premium px-4">
                                <i class="fa fa-plus me-1"></i> Add Address
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Payment Method -->
                <div class="section-title">
                    <i class="fa-solid fa-credit-card"></i> Payment Method
                </div>

                <div class="checkout-form-card">
                    <div class="payment-selection">
                        
                        <div class="payment-method-item">
                            <input type="radio" name="paymentMethod" id="razorpay" value="razorpay" checked>
                            <label for="razorpay">
                                Razorpay
                                <i class="fa-regular fa-credit-card"></i>
                            </label>
                        </div>

                        <div class="payment-method-item">
                            <input type="radio" name="paymentMethod" id="cod" value="COD">
                            <label for="cod">
                                Cash on Delivery
                                <i class="fa-solid fa-money-bill-transfer"></i>
                            </label>
                        </div>

                        <div class="payment-method-item">
                            <input type="radio" name="paymentMethod" id="wallet" value="Wallet">
                            <label for="wallet">
                                Digital Wallet
                                <i class="fa-solid fa-wallet"></i>
                            </label>
                        </div>

                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN: Order Summary -->
            <div class="col-lg-5">
                <div class="order-summary-card">
                    <h5>Order Summary</h5>

                    <div class="summary-item-list">
                        <% cart.items.forEach(item => { %>
                            <div class="summary-item-row">
                                <img src="<%=item.product?.thumbnail.url || '/images/placeholder.jpg' %>" alt="<%= item.product.name %>">
                                <div class="summary-item-details">
                                    <div class="name"><%= item.product.name %></div>
                                    <div class="attr">
                                        Color: <%= item.variantDetail ? item.variantDetail.value : '-' %> | Qty: <%= item.quantity %>
                                    </div>
                                    <div class="price">₹<%= item.finalPrice.toLocaleString() %></div>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <div class="coupon-section">
                        <div class="form-label">Have a coupon code?</div>
                        <div class="coupon-input-group">
                            <input type="text" id="couponCode" class="form-control" placeholder="WELCOME10">
                            <button type="button" class="btn-apply-coupon">Apply</button>
                        </div>
                        <div class="coupon-message" id="couponMsg">
                            <i class="fa-solid fa-circle-check"></i> Coupon WELCOME10 applied successfully!
                        </div>
                    </div>

                    <div class="summary-totals">
                        <div class="total-row">
                            <span>Subtotal</span>
                            <span>₹<%= cart.subtotal.toLocaleString() %>.00</span>
                        </div>
                        <div class="total-row discount">
                            <span>Discount (WELCOME10)</span>
                            <span>-₹<%= cart.totalDiscount.toLocaleString() %>.00</span>
                        </div>
                        <div class="total-row">
                            <span>Shipping</span>
                            <span class="text-success fw-bold">Free</span>
                        </div>
                        <div class="total-row">
                            <span>Tax</span>
                            <span>₹<%= tax.toLocaleString() %>.00</span>
                        </div>

                        <div class="total-row grand-total">
                            <span>Total</span>
                            <span>₹<%= finalTotal.toLocaleString() %></span>
                        </div>
                    </div>

                    <button type="submit" class="btn-place-order">
                        Place Order <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<%- include('../partials/user/footer-short') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function selectCheckoutAddress(addressId) {
        // Update the hidden input value
        document.getElementById('selectedAddressId').value = addressId;
        
        // Remove selected class from all address cards
        document.querySelectorAll('.lc-checkout-address-card').forEach(card => {
            card.classList.remove('selected');
        });
        
        // Add selected class to the clicked address card
        const selectedCard = document.querySelector(`.lc-checkout-address-card[data-id="${addressId}"]`);
        if (selectedCard) {
            selectedCard.classList.add('selected');
        }
    }

    // Validate shipping address selection on checkout form submission
    document.getElementById('checkoutForm')?.addEventListener('submit', function(e) {
        const addressId = document.getElementById('selectedAddressId').value;
        if (!addressId) {
            e.preventDefault();
            Swal.fire({
                icon: 'warning',
                title: 'Shipping Address Required',
                text: 'Please add and select a shipping address before placing your order.',
                confirmButtonColor: '#b78846'
            });
        }
    });
</script>
</body>
</html>

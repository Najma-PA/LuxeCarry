<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <title>Edit Profile</title>
    <link rel="stylesheet" href="/css/style.css">
    <!-- Cropper.js CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">

    <style> 
     html, body{ 
        height:100%; 
    } 
    body{ 
        display:flex; 
        flex-direction:column; 
        min-height:100vh; 
    } 
    .account-container{ 
        flex:1; 
    }

    /* profile sidebar */ 
    .nav-icon{ 
        font-size:18px; 
        color:#333; 
        position:relative; 
    } 
    .cart-badge{ 
        position:absolute; 
        top:-6px; 
        right:-8px; 
        background:#c26a00; 
        color:white; 
        font-size:11px; 
        padding:2px 6px; 
        border-radius:50%; 
    } 
    .profile-avatar{ 
        width:36px; 
        height:36px; 
        border-radius:50%; 
        object-fit:cover; 
    } 
    .avatar-letter{ 
        width:36px; height:36px; 
        border-radius:50%; 
        background:#c26a00; 
        color:white; display:flex; 
        align-items:center; 
        justify-content:center; 
        font-weight:600; } 
    .profile-menu li{ 
        padding:12px; 
        border-radius:8px; 
        cursor:pointer; } 
    .profile-menu li:hover{ 
        background:#f5f3f0; } 
    .profile-menu .active{ 
        background:#f5f3f0; font-weight:500; 
    } 
    /* avatar */ 
    .avatar-letter{ 
        width:40px; height:40px; border-radius:50%; 
        background:#c26a00; color:white; display:flex; 
        align-items:center; justify-content:center; font-weight:600; } 
        /* profile card */ 
        .profile-card{ background:white; border-radius:15px; 
        box-shadow:0 4px 10px rgba(0,0,0,0.05); } 
    .profile-input{ 
        border-radius:20px; padding:12px; 
        border:1px solid #e6c7a8; } 
    .edit-btn{ background:#c26a00; 
        color:white; border:none; 
        padding:10px 25px; border-radius:20px; } 
    .edit-btn:hover{ 
        background:#a85700; }
    .edit-btn a{
        text-decoration: none;
        color: #fafafa;
    } 
    .profile-footer a:hover{ 
        color:#c26a00; } 
    
    /* Profile Pic Styles */
    .profile-pic-container {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 20px auto;
    }
    .profile-pic-preview {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #f5f3f0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .change-pic-btn {
        position: absolute;
        bottom: 5px;
        right: 5px;
        background: #c26a00;
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid white;
        transition: 0.2s;
    }
    .change-pic-btn:hover {
        background: #a85700;
        transform: scale(1.1);
    }
    .cropper-container {
        max-height: 400px;
        overflow: hidden;
    }
    </style>
</head>
<body>
    


<%- include("../partials/navbar") %>



<div class="container account-container">

<div class="row">

<div class="col-md-3">
    
<div class="p-3">

<div class="d-flex align-items-center mb-4">

<div class="avatar-letter me-2">
<%= user.name.charAt(0).toUpperCase() %>
</div>

<h6 class="mb-0"><%= user.name %></h6>

</div>

<ul class="list-unstyled profile-menu">

<li class="active">
<a href="/user/profile" class="text-decoration-none text-dark">
<i class="fa fa-user me-2"></i> Profile Settings
</a>
</li>

<li>
<a href="/user/orders" class="text-decoration-none text-dark">
<i class="fa fa-box me-2"></i> My Orders
</a>
</li>

<li>
<a href="/user/wishlist" class="text-decoration-none text-dark">
<i class="fa fa-heart me-2"></i> Wishlist
</a>
</li>

<li>
<a href="/user/addresses" class="text-decoration-none text-dark">
<i class="fa fa-location-dot me-2"></i> Addresses
</a>
</li>

<li><i class="fa fa-ticket me-2"></i> Coupons</li>

<li><i class="fa fa-wallet me-2"></i> My Wallet</li>

<li><i class="fa fa-gift me-2"></i> Refer & Earn</li>

</ul>

<hr>

<a href="/user/logout" class="text-danger text-decoration-none">
<i class="fa fa-sign-out me-2"></i> Logout
</a>

</div>
</div>

<div class="col-md-9 d-flex align-items-start pt-5">

<div class="account-card p-4 w-75">

<h4>Edit Profile</h4>

<div class="text-center mt-4">
    <div class="profile-pic-container">
        <% if(user.profilePic) { %>
            <img src="<%= user.profilePic %>" id="profilePicPreview" class="profile-pic-preview">
        <% } else { %>
            <div id="profilePicLetter" class="avatar-letter" style="width: 112px; height: 112px; font-size: 48px; border-radius: 50%;">
                <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <img id="profilePicPreview" class="profile-pic-preview d-none">
        <% } %>
        <label for="profilePicInput" class="change-pic-btn">
            <i class="fa fa-camera"></i>
        </label>
        <input type="file" id="profilePicInput" accept="image/*" class="d-none" onchange="prepareCrop(event)">
    </div>
</div>

<form action="/user/editProfile" method="POST">

<!-- ERROR MESSAGE -->
<% if (typeof error !== "undefined") { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="mb-3 mt-4">
  <label>Full Name</label>
  <input 
    class="form-control profile-input mt-2" 
    name="name" 
    value="<%= user.name %>" 
    required
  >
</div>

<div class="mb-3">
  <label>Email</label>

  <input 
    type="email"
    id="emailField"
    class="form-control profile-input mt-2" 
    name="email" 
    value="<%= user.email %>" 
    <% if (user.googleId) { %> readonly style="background-color: #f8f9fa;" <% } else { %> required <% } %>
  >

  <small class="text-muted">
    <% if (user.googleId) { %>
      Email cannot be changed for Google accounts
    <% } else { %>
      Changing email will require OTP verification
    <% } %>
  </small>
</div>

<div class="d-flex justify-content-end mt-4">
  <button type="submit" class="btn edit-btn">
    Save Changes
  </button>
</div>

</form>
</div>

</div>

</div>

</div>

<footer class="profile-footer border-top mt-5 py-3"> 
    <div class="container d-flex justify-content-between align-items-center flex-wrap"> 
        <div class="d-flex align-items-center gap-2"> 
            <i class="fa-solid fa-bag-shopping" style="color:#c26a00"></i> 
            <span class="fw-bold">LuxeCarry</span> 
        </div> 
        <div class="small text-muted"> © 2026 LuxeCarry. All rights reserved. 

        </div> 
        <div class="small"> 
            <a href="#" class="text-decoration-none text-muted me-3"> Privacy Policy 
                
            </a> <a href="#" class="text-decoration-none text-muted"> Terms of Service 

            </a> 
        </div> 
    </div> 
</footer>
<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adjust Profile Picture</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="cropper-container">
                    <img id="cropperImage" style="max-width: 100%;">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn edit-btn" onclick="performCrop()">Crop & Save</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>

  window.addEventListener("pageshow", function (event) {
    const navEntries = performance.getEntriesByType("navigation");
    const isBackForward = navEntries.length > 0 && navEntries[0].type === "back_forward";
    
    if (event.persisted || window.performance.navigation.type === 2 || isBackForward) {
      window.location.replace('/user/profile');
    }
  });

const form = document.querySelector("form");
const emailField = document.getElementById("emailField");
const originalEmail = "<%= user.email %>";

form.addEventListener("submit", function(e) {
  if (emailField.value !== originalEmail) {
    e.preventDefault();
    Swal.fire({
      title: 'Confirm Email Change',
      text: "You changed your email. OTP will be sent. Continue?",
      icon: 'info',
      showCancelButton: true,
      confirmButtonColor: '#c26a00',
      cancelButtonColor: '#888',
      confirmButtonText: 'Yes, continue'
    }).then((result) => {
      if (result.isConfirmed) {
        form.submit();
      }
    });
  }
});

// CROPPER LOGIC
let cropper;
const cropperModalEl = document.getElementById('cropperModal');
const modal = new bootstrap.Modal(cropperModalEl);
const cropperImage = document.getElementById('cropperImage');

function prepareCrop(event) {
    const file = event.target.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = (e) => {
            cropperImage.src = e.target.result;
            modal.show();
            if (cropper) cropper.destroy();
            setTimeout(() => {
                cropper = new Cropper(cropperImage, {
                    aspectRatio: 1,
                    viewMode: 1,
                    guides: false,
                    autoCropArea: 1,
                    movable: true,
                    zoomable: true,
                    rotatable: false,
                    scalable: false
                });
            }, 500);
        };
        reader.readAsDataURL(file);
    }
}

async function performCrop() {
    if (!cropper) return;
    const canvas = cropper.getCroppedCanvas({
        width: 300,
        height: 300
    });

    canvas.toBlob(async (blob) => {
        const formData = new FormData();
        formData.append('profilePic', blob, 'profile.jpg');

        try {
            const response = await fetch('/user/profile/update-picture', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                modal.hide();
                Swal.fire({
                    icon: 'success',
                    title: 'Updated!',
                    text: 'Profile picture updated successfully',
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    // Update previews
                    const picPreview = document.getElementById('profilePicPreview');
                    const letterAvatar = document.getElementById('profilePicLetter');
                    
                    if(picPreview) {
                        picPreview.src = result.path;
                        picPreview.classList.remove('d-none');
                    }
                    if(letterAvatar) letterAvatar.classList.add('d-none');
                    
                    // Also update sidebar or navbar avatars
                    document.querySelectorAll('.profile-avatar').forEach(img => img.src = result.path);
                });
            } else {
                Swal.fire('Error', result.message || 'Upload failed', 'error');
            }
        } catch (err) {
            console.error(err);
            Swal.fire('Error', 'Server error: ' + err.message, 'error');
        }
    });
}
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Order Details | LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/user/navbar') %>

<div class="order-tracking-wrapper">

<div class="container py-5">
    <div class="row">
        <!-- Sidebar -->
        <%- include("../partials/user/sidebar", { user, activePage: 'orders' }) %>

        <!-- Main Content Column -->
        <div class="col-lg-9 col-md-8">
            <!-- Header -->
            <div class="order-tracking-header d-flex
                        justify-content-between
                        align-items-start
                        flex-wrap gap-3">

        <div>

            <h1 class="order-tracking-title">
                Order Tracking
            </h1>

            <p class="order-tracking-subtitle">

                Order
                #<%= order.orderId %>

                •

                Estimated Delivery:
                <%= new Date(order.createdAt.getTime() + 5*24*60*60*1000)
                .toLocaleDateString('en-IN',{
                    day:'numeric',
                    month:'short',
                    year:'numeric'
                }) %>

            </p>

        </div>
        
        

    </div>

    <!-- Tracking -->
    <div class="order-tracking-card">
        <div class="lc-tracking-steps">

    <!-- Order Placed -->

<div class="lc-tracking-step active">

    <div class="lc-tracking-icon
        <%= item.status === 'Cancelled'
            ? 'bg-danger text-white'
            : item.status === 'Returned'
            ? 'bg-warning text-dark'
            : '' %>">

        <% if(item.status === 'Cancelled'){ %>

            <i class="fa-solid fa-circle-xmark"></i>

        <% } else if(item.status === 'Returned'){ %>

            <i class="fa-solid fa-rotate-left"></i>

        <% } else { %>

            <i class="fa-solid fa-circle-check"></i>

        <% } %>

    </div>

    <div class="lc-tracking-label">

        <% if(item.status === 'Cancelled'){ %>

            Cancelled

        <% } else if(item.status === 'Returned'){ %>

            Returned

        <% } else { %>

            Order Placed

        <% } %>

    </div>

</div>
   
    <!-- Confirmed -->
    <div class="lc-tracking-step
        <%= ['Confirmed','Shipped','Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-box"></i>
        </div>

        <div class="lc-tracking-label">
            Confirmed
        </div>
    </div>

    <!-- Shipped -->
    <div class="lc-tracking-step
        <%= ['Shipped','Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-truck"></i>
        </div>

        <div class="lc-tracking-label">
            Shipped
        </div>
    </div>

    <!-- Out For Delivery -->
    <div class="lc-tracking-step
        <%= ['Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-motorcycle"></i>
        </div>

        <div class="lc-tracking-label">
            Out For Delivery
        </div>
    </div>

    <!-- Delivered -->
    <div class="lc-tracking-step
        <%= item.status === 'Delivered'
            ? 'active'
            : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-house"></i>
        </div>

        <div class="lc-tracking-label">
            Delivered
        </div>
    </div>

</div>

<% if(item.status === 'Cancellation Requested'){ %>

<div class="alert alert-warning mt-3">

Your cancellation request is awaiting admin approval.

</div>

<% } %>

<% if(item.status === 'Return Requested'){ %>

<div class="alert alert-warning mt-3">

Your return request is awaiting admin approval.

</div>

<% } %>

    </div>

   

    
    <div class="lc-order-summary-card">
        <div class="lc-single-product-card">

    <div class="d-flex gap-4 align-items-center">

        <img
            src="<%= item.productImage || item.product?.thumbnail?.url || '/images/no-image.png' %>"
            class="lc-single-product-image">

        <div class="flex-grow-1">

            <h3 class="mb-3">
                <%= item.productName || item.product?.name || 'Product' %>
            </h3>

            <% if(item.variantValue){ %>

            <div class="text-muted mb-2">

                Variant:
                <strong>
                    <%= item.variantValue %>
                </strong>

            </div>

            <% } %>

            <div class="text-muted mb-2">
                Ordered Qty: <strong><%= item.quantity %></strong>
            </div>

            <% if (item.cancelledQty > 0) { %>
            <div class="text-muted mb-2 text-danger">
                Cancelled Qty: <strong><%= item.cancelledQty %></strong>
            </div>
            <% } %>

            <% if (item.returnedQty > 0) { %>
            <div class="text-muted mb-2 text-warning">
                Returned Qty: <strong><%= item.returnedQty %></strong>
            </div>
            <% } %>

            <% const activeQty = item.quantity - (item.cancelledQty || 0) - (item.returnedQty || 0); %>
            <div class="text-muted mb-2 text-success">
                Active Qty: <strong><%= activeQty %></strong>
            </div>

            <div class="fw-bold fs-4 mt-3">
                
                ₹ 
                <%= (
                    item.originalPrice || (item.price * item.quantity) || 0
                ).toLocaleString() %>

            </div>

        </div>

    </div>

</div>


        

    </div>
<div class="mt-4">
    <!-- Info Cards -->
    <div class="row g-4">

        <!-- Address -->
        <div class="col-lg-6">

            <div class="lc-info-card">

                <h4 class="lc-info-title">

                    <i class="fa-solid fa-location-dot"></i>

                    Shipping Address

                </h4>

                <div class="lc-info-text">

                    <strong>
                        <%= order.shippingAddress.name %>
                    </strong>

                    <br>

                    <%= order.shippingAddress.street %>

                    <br>

                    <%= order.shippingAddress.city %>,
                    <%= order.shippingAddress.state %>

                    -
                    <%= order.shippingAddress.pincode %>

                    <br>

                    <%= order.shippingAddress.country %>

                    <br><br>

                    +91 <%= order.shippingAddress.phone %>

                </div>

            </div>

        </div>


        <!-- Payment Summary -->
        <div class="col-lg-6">

            <div class="lc-info-card payment-summary-premium">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="lc-info-title mb-0">
                        <i class="fa-solid fa-wallet"></i>
                        Payment Summary
                    </h4>

                    <!--<span class="payment-status-badge 
                        <%= order.paymentStatus === 'Paid' 
                        ? 'status-paid'
                        : order.paymentStatus === 'Pending'
                        ? 'status-pending'
                        : 'status-failed' %>">
                        <%= order.paymentStatus %>
                    </span>-->
                </div>

                <div class="payment-summary-list">

                    <div class="payment-summary-item">
                        <span>Payment Method</span>
                        <strong><%= order.paymentMethod %></strong>
                    </div>

                    <div class="payment-summary-item">
                        <span>Active Quantity</span>
                        <strong><%= activeQty %></strong>
                    </div>

                    <% 
                        const oPrice = item.originalPrice || item.price || 0;
                        const pDisc = item.productDiscount || 0;
                        const fPrice = item.finalPrice || item.price || 0;
                        const tPrice = fPrice * activeQty;
                    %>

                    <div class="payment-summary-item">
                        <span>Original Price</span>
                        <strong>₹<%= oPrice.toLocaleString() %></strong>
                    </div>

                    <% if(pDisc > 0){ %>
                    <div class="payment-summary-item text-success">
                        <span>Product Discount</span>
                        <strong>- ₹<%= pDisc.toLocaleString() %></strong>
                    </div>
                    <% } %>

                    <div class="payment-summary-item">
                        <span>Final Price (per unit)</span>
                        <strong>₹<%= fPrice.toLocaleString() %></strong>
                    </div>

                    <div class="payment-summary-item grand-total">
                        <span>Total Payable</span>
                        <strong>₹<%= tPrice.toLocaleString() %></strong>
                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

<%
  const pendingCancelQty = item.cancelRequests
    ? item.cancelRequests.filter(r => r.status === 'Pending').reduce((sum, r) => sum + r.quantity, 0)
    : 0;
  const availableCancelQty = item.quantity - (item.cancelledQty || 0) - (item.returnedQty || 0) - pendingCancelQty;
  
  const pendingReturnQty = item.returnRequests
    ? item.returnRequests.filter(r => r.status === 'Pending').reduce((sum, r) => sum + r.quantity, 0)
    : 0;
  const deliveredQty = item.deliveredQty || (item.quantity - (item.cancelledQty || 0));
  const availableReturnQty = deliveredQty - (item.returnedQty || 0) - pendingReturnQty;
%>

<% 
  const allowedCancelStatuses = ['Pending', 'Confirmed', 'Shipped', 'Out for Delivery', 'Cancellation Requested'];
  if (allowedCancelStatuses.includes(item.status) && availableCancelQty > 0) { 
%>
    <div class="d-flex justify-content-end mt-4">
        <button
          class="btn btn-danger px-4 py-2 rounded-pill"
          data-bs-toggle="modal"
          data-bs-target="#cancelOrderModal"
        >
          Cancel Order
        </button>
    </div>
<% } %>
<%  
const deliveredDate= item.deliveredAt? new Date(item.deliveredAt):null;
const today = new Date();

const diffDays = deliveredDate
  ? (today - deliveredDate) / (1000 * 60 * 60 * 24)
  : 999;
%>

<% if (['Delivered', 'Partially Returned', 'Return Requested'].includes(item.status) && diffDays <= 15 && availableReturnQty > 0) { %>
    <div class="d-flex justify-content-end mt-4">
        <button
          class="btn btn-danger px-4 py-2 rounded-pill"
          data-bs-toggle="modal"
          data-bs-target="#returnOrderModal"
        >
          Return Order
        </button>
    </div>
<% } %>

        </div> 
    </div> 
</div> 
<%- include('../partials/user/footer-short') %>
</div>

<!-- Cancel Order Modal -->

<div
    class="modal fade"
    id="cancelOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                id="cancelOrderForm"
                action="/user/orders/<%= order._id %>/items/cancel/<%= item._id %>"
                method="POST"
            >
                <div class="modal-header">

                    <h5 class="modal-title">
                        Cancel Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantity to Cancel</label>
                        <select name="quantity" class="form-select" id="cancelQtySelect" required>
                            <% for(let i = 1; i <= availableCancelQty; i++) { %>
                                <option value="<%= i %>"><%= i %></option>
                            <% } %>
                        </select>
                    </div>

                    <label class="form-label">
                        Cancellation Reason (Optional)
                    </label>

                    <textarea
                        name="reason"
                        class="form-control"
                        rows="4"
                        placeholder="Enter reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-danger"
                    >
                        Confirm Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
<!-- Return Order Modal -->

<div
    class="modal fade"
    id="returnOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                id="returnOrderForm"
                action="/user/orders/<%= order._id %>/items/return/<%= item._id %>"
                method="POST"
            >

                <div class="modal-header">

                    <h5 class="modal-title">
                        Return Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantity to Return</label>
                        <select name="quantity" class="form-select" id="returnQtySelect" required>
                            <% for(let i = 1; i <= availableReturnQty; i++) { %>
                                <option value="<%= i %>"><%= i %></option>
                            <% } %>
                        </select>
                    </div>

                    <label class="form-label">
                        Return Reason
                    </label>

                    <select
                        name="reason"
                        id="returnReasonSelect"
                        class="form-select"
                        required
                    >
                        <option value="">
                            Select Reason
                        </option>

                        <option value="Damaged Product">
                            Damaged Product
                        </option>

                        <option value="Wrong Item Delivered">
                            Wrong Item Delivered
                        </option>

                        <option value="Quality Issue">
                            Quality Issue
                        </option>

                        <option value="Changed Mind">
                            Changed Mind
                        </option>

                        <option value="Ordered By Mistake">
                            Ordered By Mistake
                        </option>

                        <option value="Other">
                            Other
                        </option>
                    </select>

                    <textarea
                        name="customReason"
                        id="customReasonBox"
                        class="form-control mt-3 d-none"
                        rows="4"
                        placeholder="Enter custom reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-warning"
                    >
                        Submit Return
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const reasonSelect = document.getElementById('returnReasonSelect');
    const customReasonBox = document.getElementById('customReasonBox');

    if (reasonSelect && customReasonBox) {
        reasonSelect.addEventListener('change', function () {
            if (this.value === 'Other') {
                customReasonBox.classList.remove('d-none');
                customReasonBox.required = true;
            } else {
                customReasonBox.classList.add('d-none');
                customReasonBox.required = false;
                customReasonBox.value = '';
            }
        });
    }

    // Cancel Order Form Submission
    const cancelForm = document.getElementById('cancelOrderForm');
    if (cancelForm) {
        cancelForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = cancelForm.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.disabled = true;

            const reason = cancelForm.querySelector('textarea[name="reason"]').value;
            const quantity = document.getElementById('cancelQtySelect').value;

            try {
                const response = await fetch(cancelForm.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ reason, quantity })
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message || 'Order cancellation request submitted.',
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Failed',
                        text: data.message || 'Something went wrong.'
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred. Please try again.'
                });
            } finally {
                if (submitBtn) submitBtn.disabled = false;
                // Close the modal
                const modalEl = document.getElementById('cancelOrderModal');
                if (modalEl) {
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                }
            }
        });
    }

    // Return Order Form Submission
    const returnForm = document.getElementById('returnOrderForm');
    if (returnForm) {
        returnForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = returnForm.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.disabled = true;

            const reason = document.getElementById('returnReasonSelect').value;
            const customReason = document.getElementById('customReasonBox').value;
            const quantity = document.getElementById('returnQtySelect').value;

            try {
                const response = await fetch(returnForm.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ reason, customReason, quantity })
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message || 'Order return request submitted.',
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Failed',
                        text: data.message || 'Something went wrong.'
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred. Please try again.'
                });
            } finally {
                if (submitBtn) submitBtn.disabled = false;
                // Close the modal
                const modalEl = document.getElementById('returnOrderModal');
                if (modalEl) {
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                }
            }
        });
    }
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Order Details | LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/user/navbar') %>

<div class="order-tracking-wrapper">

<div class="container">

    <!-- Header -->
    <div class="order-tracking-header d-flex
                justify-content-between
                align-items-start
                flex-wrap gap-3">

        <div>

            <h1 class="order-tracking-title">
                Order Tracking
            </h1>

            <p class="order-tracking-subtitle">

                Order
                #<%= order._id.toString().slice(-6).toUpperCase() %>

                •

                Estimated Delivery:
                <%= new Date(order.createdAt.getTime() + 5*24*60*60*1000)
                .toLocaleDateString('en-IN',{
                    day:'numeric',
                    month:'short',
                    year:'numeric'
                }) %>

            </p>

        </div>

        <button class="btn-order-outline">
            <i class="fa-solid fa-download me-2"></i>
            Download Invoice
        </button>

    </div>

    <!-- Tracking -->
    <div class="order-tracking-card">

        <div class="lc-tracking-steps">

            <div class="lc-tracking-step active">

                <div class="lc-tracking-icon">
                    <i class="fa-solid fa-circle-check"></i>
                </div>

                <div class="lc-tracking-label">
                    Order Placed
                </div>

            </div>

            <div class="lc-tracking-step active">

                <div class="lc-tracking-icon">
                    <i class="fa-solid fa-box"></i>
                </div>

                <div class="lc-tracking-label">
                    Packed
                </div>

            </div>

            <div class="lc-tracking-step active">

                <div class="lc-tracking-icon">
                    <i class="fa-solid fa-truck"></i>
                </div>

                <div class="lc-tracking-label">
                    Shipped
                </div>

            </div>

            <div class="lc-tracking-step
            <%= order.status === 'Delivered'
                ? 'active'
                : '' %>">

                <div class="lc-tracking-icon">
                    <i class="fa-solid fa-motorcycle"></i>
                </div>

                <div class="lc-tracking-label">
                    Out For Delivery
                </div>

            </div>

            <div class="lc-tracking-step
            <%= order.status === 'Delivered'
                ? 'active'
                : '' %>">

                <div class="lc-tracking-icon">
                    <i class="fa-solid fa-house"></i>
                </div>

                <div class="lc-tracking-label">
                    Delivered
                </div>

            </div>

        </div>

        <div class="lc-tracking-note">

            Your order is currently being processed and
            prepared for shipment.

        </div>

    </div>

    <!-- Info Cards -->
    <div class="row g-4">

        <!-- Address -->
        <div class="col-lg-6">

            <div class="lc-info-card">

                <h4 class="lc-info-title">

                    <i class="fa-solid fa-location-dot"></i>

                    Shipping Address

                </h4>

                <div class="lc-info-text">

                    <strong>
                        <%= order.shippingAddress.name %>
                    </strong>

                    <br>

                    <%= order.shippingAddress.street %>

                    <br>

                    <%= order.shippingAddress.city %>,
                    <%= order.shippingAddress.state %>

                    -
                    <%= order.shippingAddress.pincode %>

                    <br>

                    <%= order.shippingAddress.country %>

                    <br><br>

                    +91 <%= order.shippingAddress.phone %>

                </div>

            </div>

        </div>

        <!-- Payment -->
        <div class="col-lg-6">

            <div class="lc-info-card">

                <h4 class="lc-info-title">

                    <i class="fa-solid fa-credit-card"></i>

                    Payment Method

                </h4>

                <div class="lc-info-text">

                    <strong>
                        <%= order.paymentMethod %>
                    </strong>

                    <br><br>

                    Payment Status:
                    <strong>
                        <%= order.paymentStatus %>
                    </strong>

                </div>

            </div>

        </div>

    </div>

    <!-- Order Summary -->
    <div class="lc-order-summary-card">

        <h4 class="order-section-title mb-4">

            Order Summary
            (<%= order.items.length %> Items)

        </h4>

        <% order.items.forEach(item => { %>

        <div class="lc-order-summary-item">

            <div class="lc-order-summary-left">

                <img
                src="<%= item.product?.thumbnail?.url ||item.product?.displayImage|| '/images/placeholder.jpg' %>"
                class="lc-order-summary-image">

                <div>

                    <div class="lc-order-summary-name">
                        <%= item.product?.name %>
                    </div>

                    <% if(item.variantValue){ %>

                    <div class="lc-order-summary-meta">
                        Variant: <%= item.variantValue %>
                    </div>

                    <% } %>

                    <div class="lc-order-summary-qty">
                        Qty: <%= item.quantity %>
                    </div>

                </div>

            </div>

            <div class="lc-order-summary-price">

                ₹<%= item.price.toLocaleString() %>

            </div>

        </div>

        <% }) %>

        <!-- Totals -->
        <div class="order-summary-box mt-4">

            <div class="order-summary-row">

                <span class="order-summary-label">
                    Subtotal
                </span>

                <span class="order-summary-value">
                    ₹<%= order.subtotal.toLocaleString() %>
                </span>

            </div>

            <div class="order-summary-row">

                <span class="order-summary-label">
                    Tax
                </span>

                <span class="order-summary-value">
                    ₹<%= order.tax.toLocaleString() %>
                </span>

            </div>

            <% if(order.discount > 0){ %>

            <div class="order-summary-row">

                <span class="order-summary-label">
                    Discount
                </span>

                <span class="order-summary-value text-success">
                    - ₹<%= order.discount.toLocaleString() %>
                </span>

            </div>

            <% } %>

            <div class="order-summary-row order-grand-total">

                <span class="order-summary-value">
                    Total
                </span>

                <span class="order-summary-value">
                    ₹<%= order.totalAmount.toLocaleString() %>
                </span>

            </div>

        </div>

    </div>
<div class="mt-4">

  <% if(
    order.status === 'Pending' ||
    order.status === 'Confirmed'
  ) { %>

    <button
      class="btn btn-danger"
      data-bs-toggle="modal"
      data-bs-target="#cancelOrderModal"
    >
      Cancel Order
    </button>

  <% } %>

  <% if(order.status === 'Delivered') { %>

    <button
      class="btn btn-warning"
      data-bs-toggle="modal"
      data-bs-target="#returnOrderModal"
    >
      Return Order
    </button>

  <% } %>

</div>
</div>
<%- include('../partials/user/footer-short') %>
</div>

<!-- Cancel Order Modal -->

<div
    class="modal fade"
    id="cancelOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                action="/user/orders/<%= order._id %>/cancel?_method=PATCH"
                method="POST"
            >

                <div class="modal-header">

                    <h5 class="modal-title">
                        Cancel Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">

                    <label class="form-label">
                        Cancellation Reason (Optional)
                    </label>

                    <textarea
                        name="reason"
                        class="form-control"
                        rows="4"
                        placeholder="Enter reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-danger"
                    >
                        Confirm Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
<!-- Return Order Modal -->

<div
    class="modal fade"
    id="returnOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                action="/user/orders/<%= order._id %>/return?_method=PATCH"
                method="POST"
            >

                <div class="modal-header">

                    <h5 class="modal-title">
                        Return Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">

                    <label class="form-label">
                        Return Reason
                    </label>

                    <textarea
                        name="reason"
                        class="form-control"
                        rows="4"
                        required
                        placeholder="Enter return reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-warning"
                    >
                        Submit Return
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
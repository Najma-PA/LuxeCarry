<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Order Details | LuxeCarry</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include('../partials/user/navbar') %>

<div class="order-tracking-wrapper">

<div class="container py-5">
    <div class="row">
        <!-- Sidebar -->
        <%- include("../partials/user/sidebar", { user, activePage: 'orders' }) %>

        <!-- Main Content Column -->
        <div class="col-lg-9 col-md-8">
            <!-- Header -->
            <div class="order-tracking-header d-flex
                        justify-content-between
                        align-items-start
                        flex-wrap gap-3">

        <div>

            <h1 class="order-tracking-title">
                Order Tracking
            </h1>
<!--
            <p class="order-tracking-subtitle">

                Order
                #<%= order.orderId %>

                •

                Estimated Delivery:
                <%= new Date(order.createdAt.getTime() + 5*24*60*60*1000)
                .toLocaleDateString('en-IN',{
                    day:'numeric',
                    month:'short',
                    year:'numeric'
                }) %>

            </p>-->

        </div>
        
        

    </div>

    <!-- Tracking -->
    <div class="order-tracking-card">
        <div class="lc-tracking-steps">

    <!-- Order Placed -->

<div class="lc-tracking-step active">

    <div class="lc-tracking-icon
        <%= item.status === 'Cancelled'
            ? 'bg-danger text-white'
            : item.status === 'Returned'
            ? 'bg-warning text-dark'
            : '' %>">

        <% if(item.status === 'Cancelled'){ %>

            <i class="fa-solid fa-circle-xmark"></i>

        <% } else if(item.status === 'Returned'){ %>

            <i class="fa-solid fa-rotate-left"></i>

        <% } else { %>

            <i class="fa-solid fa-circle-check"></i>

        <% } %>

    </div>

    <div class="lc-tracking-label">

        <% if(item.status === 'Cancelled'){ %>

            Cancelled

        <% } else if(item.status === 'Returned'){ %>

            Returned

        <% } else { %>

            Order Placed

        <% } %>

    </div>

</div>
   
    <!-- Confirmed -->
    <div class="lc-tracking-step
        <%= ['Confirmed','Shipped','Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-box"></i>
        </div>

        <div class="lc-tracking-label">
            Confirmed
        </div>
    </div>

    <!-- Shipped -->
    <div class="lc-tracking-step
        <%= ['Shipped','Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-truck"></i>
        </div>

        <div class="lc-tracking-label">
            Shipped
        </div>
    </div>

    <!-- Out For Delivery -->
    <div class="lc-tracking-step
        <%= ['Out for Delivery','Delivered']
            .includes(item.status) ? 'active' : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-motorcycle"></i>
        </div>

        <div class="lc-tracking-label">
            Out For Delivery
        </div>
    </div>

    <!-- Delivered -->
    <div class="lc-tracking-step
        <%= item.status === 'Delivered'
            ? 'active'
            : '' %>">

        <div class="lc-tracking-icon">
            <i class="fa-solid fa-house"></i>
        </div>

        <div class="lc-tracking-label">
            Delivered
        </div>
    </div>

</div>


        <div class="lc-tracking-note">

            Your order is currently being processed and
            prepared for shipment.

        </div>

    </div>

   

    
    <div class="lc-order-summary-card">
        <div class="lc-single-product-card">

    <div class="d-flex gap-4 align-items-center">

        <img
            src="<%= item.productImage || item.product?.thumbnail?.url || '/images/no-image.png' %>"
            class="lc-single-product-image">

        <div class="flex-grow-1">

            <h3 class="mb-3">
                <%= item.productName || item.product?.name || 'Product' %>
            </h3>

            <% if(item.variantValue){ %>

            <div class="text-muted mb-2">

                Variant:
                <strong>
                    <%= item.variantValue %>
                </strong>

            </div>

            <% } %>

            <div class="text-muted mb-2">

                Quantity:
                <strong>
                    <%= item.quantity %>
                </strong>

            </div>

            <div class="fw-bold fs-4 mt-3">
                
                ₹ 
                <%= (
                    item.originalPrice || (item.price * item.quantity) || 0
                ).toLocaleString() %>

            </div>

        </div>

    </div>

</div>


        

    </div>
<div class="mt-4">
    <!-- Info Cards -->
    <div class="row g-4">

        <!-- Address -->
        <div class="col-lg-6">

            <div class="lc-info-card">

                <h4 class="lc-info-title">

                    <i class="fa-solid fa-location-dot"></i>

                    Shipping Address

                </h4>

                <div class="lc-info-text">

                    <strong>
                        <%= order.shippingAddress.name %>
                    </strong>

                    <br>

                    <%= order.shippingAddress.street %>

                    <br>

                    <%= order.shippingAddress.city %>,
                    <%= order.shippingAddress.state %>

                    -
                    <%= order.shippingAddress.pincode %>

                    <br>

                    <%= order.shippingAddress.country %>

                    <br><br>

                    +91 <%= order.shippingAddress.phone %>

                </div>

            </div>

        </div>


        <!-- Payment Summary -->
        <div class="col-lg-6">

            <div class="lc-info-card payment-summary-premium">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="lc-info-title mb-0">
                        <i class="fa-solid fa-wallet"></i>
                        Payment Summary
                    </h4>

                    <span class="payment-status-badge 
                        <%= order.paymentStatus === 'Paid' 
                        ? 'status-paid'
                        : order.paymentStatus === 'Pending'
                        ? 'status-pending'
                        : 'status-failed' %>">
                        <%= order.paymentStatus %>
                    </span>
                </div>

                <div class="payment-summary-list">

                    <div class="payment-summary-item">
                        <span>Payment Method</span>
                        <strong><%= order.paymentMethod %></strong>
                    </div>

                    <div class="payment-summary-item">
                        <span>Quantity</span>
                        <strong><%= item.quantity %></strong>
                    </div>

                    <% 
                        const oPrice = item.originalPrice || item.price || 0;
                        const pDisc = item.productDiscount || 0;
                        const fPrice = item.finalPrice || item.price || 0;
                        const tPrice = item.totalPrice || (item.price * item.quantity) || 0;
                    %>

                    <div class="payment-summary-item">
                        <span>Original Price</span>
                        <strong>₹<%= oPrice.toLocaleString() %></strong>
                    </div>

                    <% if(pDisc > 0){ %>
                    <div class="payment-summary-item text-success">
                        <span>Product Discount</span>
                        <strong>- ₹<%= pDisc.toLocaleString() %></strong>
                    </div>
                    <% } %>

                    <div class="payment-summary-item">
                        <span>Final Price (per unit)</span>
                        <strong>₹<%= fPrice.toLocaleString() %></strong>
                    </div>

                    <div class="payment-summary-item grand-total">
                        <span>Total Payable</span>
                        <strong>₹<%= tPrice.toLocaleString() %></strong>
                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

<% if (item.status === 'Pending' || item.status === 'Confirmed') { %>
    <div class="d-flex justify-content-end mt-4">
        <button
          class="btn btn-danger px-4 py-2 rounded-pill"
          data-bs-toggle="modal"
          data-bs-target="#cancelOrderModal"
        >
          Cancel Order
        </button>
    </div>
<% } %>

<% if (item.status === 'Delivered') { %>
    <div class="d-flex justify-content-end mt-4">
        <button
          class="btn btn-danger px-4 py-2 rounded-pill"
          data-bs-toggle="modal"
          data-bs-target="#returnOrderModal"
        >
          Return Order
        </button>
    </div>
<% } %>

        </div> <!-- Close col-lg-9 col-md-8 -->
    </div> <!-- Close row -->
</div> <!-- Close container -->
<%- include('../partials/user/footer-short') %>
</div>

<!-- Cancel Order Modal -->

<div
    class="modal fade"
    id="cancelOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                action="/user/orders/<%= order._id %>/items/<%= item._id %>/cancel?_method=PATCH"
                method="POST"
            >

                <div class="modal-header">

                    <h5 class="modal-title">
                        Cancel Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">

                    <label class="form-label">
                        Cancellation Reason (Optional)
                    </label>

                    <textarea
                        name="reason"
                        class="form-control"
                        rows="4"
                        placeholder="Enter reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-danger"
                    >
                        Confirm Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
<!-- Return Order Modal -->

<div
    class="modal fade"
    id="returnOrderModal"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog">

        <div class="modal-content">

            <form
                action="/user/orders/<%= order._id %>/items/<%= item._id  %>/return?_method=PATCH"
                method="POST"
            >

                <div class="modal-header">

                    <h5 class="modal-title">
                        Return Order
                    </h5>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                    ></button>

                </div>

                <div class="modal-body">

                    <label class="form-label">
                        Return Reason
                    </label>

                    <select
                        name="reason"
                        id="returnReasonSelect"
                        class="form-select"
                        required
                    >
                        <option value="">
                            Select Reason
                        </option>

                        <option value="Damaged Product">
                            Damaged Product
                        </option>

                        <option value="Wrong Item Delivered">
                            Wrong Item Delivered
                        </option>

                        <option value="Quality Issue">
                            Quality Issue
                        </option>

                        <option value="Changed Mind">
                            Changed Mind
                        </option>

                        <option value="Ordered By Mistake">
                            Ordered By Mistake
                        </option>

                        <option value="Other">
                            Other
                        </option>
                    </select>

                    <textarea
                        name="customReason"
                        id="customReasonBox"
                        class="form-control mt-3 d-none"
                        rows="4"
                        placeholder="Enter custom reason..."
                    ></textarea>

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal"
                    >
                        Close
                    </button>

                    <button
                        type="submit"
                        class="btn btn-warning"
                    >
                        Submit Return
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const reasonSelect = document.getElementById('returnReasonSelect');
    const customReasonBox = document.getElementById('customReasonBox');

    if (reasonSelect && customReasonBox) {
        reasonSelect.addEventListener('change', function () {
            if (this.value === 'Other') {
                customReasonBox.classList.remove('d-none');
                customReasonBox.required = true;
            } else {
                customReasonBox.classList.add('d-none');
                customReasonBox.required = false;
                customReasonBox.value = '';
            }
        });
    }
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>LuxeCarry Signup</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<link rel="stylesheet" href="/css/login.css">

</head>

<body>

<div class="container">

<div class="logo">
<i class="fa-solid fa-bag-shopping"></i>
<h4>LuxeCarry</h4>
</div>

<div class="login-card mx-auto">

<h4 class="text-center">Create Account</h4>
<p class="text-center text-muted">Join LuxeCarry today</p>

<% if (error) { %>
<div class="alert alert-danger">
  <%= error %>
</div>
<% } %>

<form action="/user/signup" method="POST">

<div class="mb-3">
<label class="form-label">FULL NAME</label>
<input type="text" class="form-control <%=errors.name ? 'is-invalid' : '' %>"  name="name" placeholder="Enter your name" value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>">
<% if(errors.name){%>
  <small class="text-danger"><%= errors.name %></small>
<%} %>
</div>

<div class="mb-3">
<label class="form-label">EMAIL ADDRESS</label>
<input type="email" class="form-control <%= errors.email ? 'is-invalid':''  %>" name="email" placeholder="Enter your email" value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>">
<% if(errors.email){%>
  <small class="text-danger"><%= errors.email %></small>
<%} %>
</div>

<div class="mb-3">
<label class="form-label">PASSWORD</label>

<div class="input-group">
<input type="password" class="form-control <%= errors.password ? 'is-invalid':''  %>" name="password" placeholder="Enter password" value="<%= typeof formData !== 'undefined' && formData.password ? formData.password : '' %>">

<span class="input-group-text" style="cursor: pointer;">
<i class="fa-regular fa-eye toggle-password"></i>
</span>
</div>
<% if(errors.password){%>
  <small class="text-danger"><%= errors.password %></small>
<%} %>
</div>

<div class="mb-3">
<label class="form-label">CONFIRM PASSWORD</label>
<div class="input-group">
<input type="password" class="form-control <%= errors.confirmPassword ? 'is-invalid':''  %>" 
name="confirmPassword" 
placeholder="Confirm password" 
value="<%= typeof formData !== 'undefined' && formData.confirmPassword ? formData.confirmPassword : '' %>">
<span class="input-group-text" style="cursor: pointer;">
<i class="fa-regular fa-eye toggle-password"></i>
</span>
</div>
<% if(errors.confirmPassword){%>
  <small class="text-danger"><%= errors.confirmPassword %></small>
<%} %>
</div>

<div class="mb-3">
<label class="form-label">REFERRAL CODE</label>
<input type="text" class="form-control" name="referralCode" placeholder="Optional" value="<%= typeof formData !== 'undefined' && formData.referralCode ? formData.referralCode : '' %>">
</div>

<button class="login-btn">Create Account</button>

</form>

<hr>

<a href="/user/auth/google" class="google-btn text-decoration-none text-dark">
<img src="https://www.svgrepo.com/show/355037/google.svg" width="18">
Sign up with Google
</a>

</div>

<div class="signup-text">
Already have an account?
<a href="/user/login">Login</a>
</div>

</div>

<script>

  document.querySelectorAll(".toggle-password").forEach(icon => {
    icon.addEventListener("click", function () {
      let input = this.closest(".input-group").querySelector("input");
      if (input.type === "password") {
        input.type = "text";
        this.classList.remove("fa-eye");
        this.classList.add("fa-eye-slash");
      } else {
        input.type = "password";
        this.classList.remove("fa-eye-slash");
        this.classList.add("fa-eye");
      }
    });
  });

  (function () {
    if (window.history.replaceState) {
      window.history.replaceState(null, null, window.location.href);
    }
  })();

  
  document.querySelectorAll("input").forEach(input => {
    input.addEventListener("input", function () {

      const field = this.closest(".mb-3");

      // Remove error text
       field.querySelectorAll(".text-danger").forEach(e=>e.remove());
      

      // Remove red border
      this.classList.remove("is-invalid");
    });
  });


</script>

</body>
</html>

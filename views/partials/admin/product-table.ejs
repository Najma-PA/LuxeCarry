<% if(products && products.length > 0) { %>
  <% products.forEach(p => { %>
  <tr id="row-<%= p._id %>">
    <td>
      <div class="fw-bold" style="color: #1e293b; font-size: 14px;"><%= p.name %></div>
      <div class="text-muted mt-1" style="font-size: 12px;"><%= p.description?.slice(0,40) || 'Premium Collection' %></div>
    </td>
    <td><span style="color: #64748b;"><%= p.category?.name || 'Uncategorized' %></span></td>
    <td><span class="fw-bold" style="color: #1e293b;">₹<%= p.price %></span></td>
    <td><span style="color: #64748b;"><%= p.offer || 0 %>%</span></td>
    <td>
      <% if(p.stock === 0){ %>
        <span class="pill-badge status-out-stock"><span class="badge-dot"></span> Out of stock</span>
      <% } else if(p.stock < 5){ %>
        <span class="pill-badge status-low-stock"><span class="badge-dot"></span> Low: <%= p.stock %> Left</span>
      <% } else { %>
        <span class="pill-badge status-in-stock"><span class="badge-dot"></span> In Stock: <%= p.stock %></span>
      <% } %>
    </td>
    <td>
      <a href="/admin/products/edit/<%= p._id %>" class="btn-action" title="Edit">
        <i class="fa-solid fa-pen" style="font-size: 14px;"></i>
      </a>
      
      <% if (p.isActive) { %>
        <button onclick="deleteProduct('<%= p._id %>')" class="btn-action" title="Delete">
          <i class="fa-regular fa-trash-can" style="font-size: 14px;"></i>
        </button>
      <% } else { %>
        <button onclick="restoreProduct('<%= p._id %>')" class="btn-action text-success" title="Restore">
          <i class="fa-solid fa-trash-arrow-up" style="font-size: 14px;"></i>
        </button>
      <% } %>
    </td>
  </tr>
  <% }) %>
<% } else { %>
  <tr><td colspan="6" class="text-center py-4 text-muted">No products found.</td></tr>
<% } %>

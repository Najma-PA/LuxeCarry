        <% if(currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&status=<%= status %>&search=<%= search %>" class="page-btn pagination-link" data-page="<%= currentPage - 1 %>"><i class="fa-solid fa-chevron-left"></i></a>
        <% } %>
        
        <% for(let i=1; i<=totalPages; i++){ %>
          <a href="?page=<%= i %>&status=<%= status %>&search=<%= search %>" class="page-btn pagination-link <%= currentPage===i?'active':'' %>" data-page="<%= i %>"><%= i %></a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&status=<%= status %>&search=<%= search %>" class="page-btn pagination-link" data-page="<%= currentPage + 1 %>"><i class="fa-solid fa-chevron-right"></i></a>
        <% } %>

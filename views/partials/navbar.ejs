<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg custom-navbar border-bottom">
<div class="container">

<!-- Logo -->
<a class="navbar-brand fw-bold d-flex align-items-center" href="/">
<i class="fa-solid fa-bag-shopping me-2" style="color:#c26a00"></i>
LuxeCarry
</a>

<button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navMenu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="navMenu">

<!-- Center Links -->
<ul class="navbar-nav mx-auto">

<li class="nav-item">
<a class="nav-link" href="/">Home</a>
</li>

<li class="nav-item">
<a class="nav-link " href="/user/shop">Shop</a>
</li>
<!--
<li class="nav-item">
<a class="nav-link" href="/user/new-arrivals">New Arrivals</a>
</li>
-->
<li class="nav-item">
<a class="nav-link" href="/contact">Contact</a>
</li>

</ul>

<!-- Right Side -->
<div class="d-flex align-items-center gap-3">

<!-- Search -->
<form action="/user/shop" method="GET" class="search-box position-relative d-flex align-items-center" id="navSearchForm">
  <input type="text" 
    id="navSearchInput"
    name="search"
    class="form-control rounded-pill ps-4 pe-5"
    placeholder="Search collection..."
    value="<%= locals.query ? query.search || '' : '' %>"
    style="padding-right: 70px !important;">
  
  <div class="position-absolute end-0 d-flex align-items-center me-3 gap-2">
    <!-- Clear Icon -->
    <i class="fa-solid fa-xmark" id="navSearchClear" 
       style="cursor: pointer; color: #999; <%= (locals.query && query.search) ? '' : 'display: none !important;' %>"></i>
    
    <!-- Search Icon Button -->
    <button type="submit" style="background: none; border: none; padding: 0; color: #666;">
       <i class="fa fa-search"></i>
    </button>
  </div>
</form>

<script>
  const navSearchInput = document.getElementById('navSearchInput');
  const navSearchClear = document.getElementById('navSearchClear');

  navSearchInput.addEventListener('input', function() {
    if (this.value) {
      navSearchClear.style.setProperty('display', 'block', 'important');
    } else {
      navSearchClear.style.setProperty('display', 'none', 'important');
    }
  });

  navSearchClear.addEventListener('click', function() {
    navSearchInput.value = '';
    navSearchClear.style.setProperty('display', 'none', 'important');
    navSearchInput.focus();
    
    // If we are on the shop page, we might want to trigger a search with empty string or redirect to shop
    if (window.location.pathname === '/user/shop') {
       window.location.href = '/user/shop';
    }
  });
</script>

<!-- Wishlist -->
<a href="/user/wishlist" class="nav-icon">
<i class="fa-regular fa-heart"></i>
</a>

<!-- Cart -->
<a href="/user/cart" class="nav-icon position-relative">
<i class="fa-solid fa-cart-arrow-down"></i>
<% if(locals.cartCount > 0){ %>
  <span class="cart-badge"><%= cartCount %></span>
<% } %>
</a>

<!-- Login / Profile -->

<% if(!user){ %>

<a href="/user/login" class="btn btn-outline-dark rounded-pill px-3">
Sign In
</a>

<% } else { %>

<a href="/user/profile" style="text-decoration: none;">

<% if(user.profilePic){ %>

<img src="<%= user.profilePic %>"
class="profile-avatar">

<% } else { %>

<div class="avatar-letter">
<%= user.name.charAt(0).toUpperCase() %>
</div>

<% } %>

</a>

<% } %>

</div>

</div>

</div>
</nav>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  // Force reload to prevent BFcache (Back-Forward cache) from bypassing logout
  window.addEventListener("pageshow", function (event) {
    if (event.persisted || window.performance && window.performance.navigation.type === 2) {
      window.location.reload();
    }
  });
</script>
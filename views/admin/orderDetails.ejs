<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Update Order Status</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="d-flex">

<%- include('../partials/admin/sidebar',
{ active:'orders' }) %>

<div class="main-content w-100 p-5">

    <!-- Header -->
    <div class="mb-4">

        <h2 class="fw-bold mb-1"
        style="color:#0f172a;">

            Order Details & Status

        </h2>

        <p class="text-muted mb-0">

            Order ID:
            #<%= order.orderId %>

        </p>

    </div>

    <!-- Top Grid -->
    <div class="admin-order-grid mb-4">

        <!-- Customer & Address Details -->
        <div class="admin-order-detail-card">

            <h3 class="admin-order-card-title">

                Customer & Shipping

            </h3>

            <div class="mb-4">

                <div class="admin-order-label">
                    Customer
                </div>

                <div class="admin-order-text">

                    <strong><%= order.userId?.name || 'Customer' %></strong><br>
                    <%= order.userId?.email || '' %>

                </div>

            </div>

            <div>

                <div class="admin-order-label">
                    Shipping Address
                </div>

                <div class="admin-order-text">

                    <i class="fa-solid fa-location-dot me-2"
                    style="color:#c26a00;"></i>

                    <%= order.shippingAddress.name %><br>
                    <%= order.shippingAddress.street %>,
                    <br>

                    <%= order.shippingAddress.city %>,
                    <%= order.shippingAddress.state %>

                    -
                    <%= order.shippingAddress.pincode %>

                    <br>

                    <%= order.shippingAddress.country %><br>
                    Phone: <%= order.shippingAddress.phone %>

                </div>

            </div>

        </div>

        <!-- Global Order & Payment Summary -->
        <div class="admin-order-detail-card">

            <h3 class="admin-order-card-title">

                Order & Payment Summary

            </h3>

            <div class="mb-3">
                <div class="admin-order-label">Global Order Status</div>
                <div class="d-flex align-items-center justify-content-between mt-1">
                    <span class="order-badge
                        <%= order.orderStatus === 'Pending'
                            ? 'order-pending'
                            : order.orderStatus === 'Confirmed'
                            ? 'order-processing'
                            : order.orderStatus === 'Shipped' || order.orderStatus === 'Out for Delivery'
                            ? 'order-shipped'
                            : order.orderStatus === 'Delivered'
                            ? 'order-delivered'
                            : 'order-cancelled' %>">
                        <%= order.orderStatus %>
                    </span>
                    <form action="/admin/orders/<%= order._id %>/orderStatus" method="POST" class="d-flex gap-1 align-items-center">
                        <select name="orderStatus" class="form-select form-select-sm" style="width: 130px;">
                            <% ['Pending', 'Confirmed', 'Shipped', 'Out for Delivery', 'Delivered', 'Cancelled', 'Returned'].forEach(st => { %>
                                <option value="<%= st %>" <%= order.orderStatus === st ? 'selected' : '' %>><%= st %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-dark">Update</button>
                    </form>
                </div>
            </div>

            <div class="mb-3">
                <div class="admin-order-label">Payment Status</div>
                <div class="d-flex align-items-center justify-content-between mt-1">
                    <span class="badge <%= order.paymentStatus === 'Paid' ? 'bg-success' : order.paymentStatus === 'Pending' ? 'bg-warning text-dark' : 'bg-danger' %>">
                        <%= order.paymentStatus %>
                    </span>
                    <form action="/admin/orders/<%= order._id %>/payment" method="POST" class="d-flex gap-1 align-items-center">
                        <select name="paymentStatus" class="form-select form-select-sm" style="width: 130px;">
                            <% ['Pending', 'Paid', 'Failed', 'Refunded'].forEach(ps => { %>
                                <option value="<%= ps %>" <%= order.paymentStatus === ps ? 'selected' : '' %>><%= ps %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-dark">Update</button>
                    </form>
                </div>
            </div>

            <div class="mb-3">
                <div class="admin-order-label">Payment Method</div>
                <div class="admin-order-text mt-1"><strong><%= order.paymentMethod %></strong></div>
            </div>

            <div>
                <div class="admin-order-label">Total Amount Payable</div>
                <div class="admin-order-text mt-1 fw-bold text-success fs-5">₹<%= order.totalAmount.toLocaleString() %></div>
            </div>

        </div>

    </div>

    <!-- Products Ordered -->
    <div class="admin-order-products-card">

        <div class="admin-order-products-header">

            <div class="admin-order-products-title">

                Products Ordered 

            </div>

            <div class="admin-order-products-count">

                <%= order.items.length %> items total

            </div>

        </div>

        <table class="table admin-order-table align-middle mb-0">

            <thead>

                <tr>

                    <th style="width: 35%;">PRODUCT</th>
                    <th style="width: 8%;">QTY</th>
                    <th style="width: 22%;">PRICE DETAILS</th>
                    <th style="width: 35%;">STATUS & ACTIONS</th>

                </tr>

            </thead>

            <tbody>

            <% order.items.forEach(item => { %>

            <tr>

                <td>

                    <div class="admin-product-info">

                        <img
                        src="<%= item.productImage || '/images/no-image.png' %>"
                        class="admin-product-image" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px;">

                        <div>

                            <div class="admin-product-name fw-bold" style="color: #0f172a;">

                                <%= item.productName %>

                            </div>

                            <% if(item.variantValue){ %>

                            <div class="admin-product-meta text-muted small mt-1">

                                Variant: <strong><%= item.variantValue %></strong>

                            </div>

                            <% } %>

                        </div>

                    </div>

                </td>

                <td class="fw-bold">

                    × <%= item.quantity %>

                </td>

                <td>

                    <% 
                        const oPrice = item.originalPrice || item.price || 0;
                        const pDisc = item.productDiscount || 0;
                        const fPrice = item.finalPrice || item.price || 0;
                        const tPrice = item.totalPrice || (item.price * item.quantity) || 0;
                    %>
                    <div class="small">
                        <div class="text-muted d-flex justify-content-between">Original: <span class="fw-bold text-decoration-line-through">₹<%= oPrice.toLocaleString() %></span></div>
                        <div class="text-success d-flex justify-content-between">Discount: <span>- ₹<%= pDisc.toLocaleString() %></span></div>
                        <div class="text-primary d-flex justify-content-between">Final Price: <span class="fw-bold">₹<%= fPrice.toLocaleString() %></span></div>
                        <hr class="my-1">
                        <div class="fw-bold d-flex justify-content-between text-dark">Total Price: <span>₹<%= tPrice.toLocaleString() %></span></div>
                    </div>

                </td>

                <td>

                    <div class="d-flex flex-column gap-2">
                        <!-- Current status badge -->
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="order-badge
                                <%= item.status === 'Pending'
                                    ? 'order-pending'
                                    : item.status === 'Confirmed'
                                    ? 'order-processing'
                                    : item.status === 'Shipped' || item.status === 'Out for Delivery'
                                    ? 'order-shipped'
                                    : item.status === 'Delivered'
                                    ? 'order-delivered'
                                    : 'order-cancelled' %>">
                                <%= item.status %>
                            </span>
                            <!-- Status change form -->
                            <form action="/admin/orders/<%= order._id %>/items/<%= item._id %>/status" method="POST" class="d-flex gap-1 align-items-center">
                                <select name="status" class="form-select form-select-sm" style="width: 140px;">
                                    <% ['Pending', 'Confirmed', 'Shipped', 'Out for Delivery', 'Delivered', 'Cancelled', 'Returned'].forEach(st => { %>
                                        <option value="<%= st %>" <%= item.status === st ? 'selected' : '' %>><%= st %></option>
                                    <% }) %>
                                </select>
                                <button type="submit" class="btn btn-sm btn-gold">Update</button>
                            </form>
                        </div>

                        <!-- Cancellation Reason -->
                        <% if (item.status === 'Cancelled' && item.cancelReason) { %>
                            <div class="alert alert-danger p-2 mb-0 mt-1 small">
                                <strong>Cancel Reason:</strong> <%= item.cancelReason %>
                                <% if (item.cancelledAt) { %>
                                    <div class="text-muted text-end mt-1" style="font-size: 10px;">At: <%= new Date(item.cancelledAt).toLocaleString() %></div>
                                <% } %>
                            </div>
                        <% } %>

                        <!-- Return Reason -->
                        <% if (item.status === 'Returned' && item.returnReason) { %>
                            <div class="alert alert-warning p-2 mb-0 mt-1 small text-dark">
                                <strong>Return Reason:</strong> <%= item.returnReason %>
                                <% if (item.returnedAt) { %>
                                    <div class="text-muted text-end mt-1" style="font-size: 10px;">At: <%= new Date(item.returnedAt).toLocaleString() %></div>
                                <% } %>
                            </div>
                        <% } %>

                        <!-- Refund Manager 
                        <div class="bg-light p-2 rounded mt-1 border">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small text-muted">Refund Amount:</span>
                                <span class="fw-bold small text-dark">₹<%= (item.refundAmount || 0).toLocaleString() %></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small text-muted">Refund Status:</span>
                                <span class="badge bg-secondary mb-1" style="font-size: 10px;"><%= item.refundStatus %></span>
                            </div>
                            <form action="/admin/orders/<%= order._id %>/items/<%= item._id %>/refund" method="POST" class="d-flex gap-1 align-items-center mt-1">
                                <input type="number" name="refundAmount" value="<%= item.refundAmount || 0 %>" class="form-control form-control-sm" style="width: 70px;" placeholder="Amount">
                                <select name="refundStatus" class="form-select form-select-sm" style="width: 110px; font-size: 11px;">
                                    <% ['Not Requested', 'Pending', 'Processed', 'Completed'].forEach(rs => { %>
                                        <option value="<%= rs %>" <%= item.refundStatus === rs ? 'selected' : '' %>><%= rs %></option>
                                    <% }) %>
                                </select>
                                <button type="submit" class="btn btn-sm btn-dark" style="font-size: 11px;">Save</button>
                            </form>
                        </div>-->
                    </div>

                </td>

            </tr>

            <% }) %>

            </tbody>

        </table>

        <!-- Dynamic Totals Summary -->
        <% 
            const dynamicSubtotal = order.items.reduce((sum, item) => sum + ((item.originalPrice || item.price || 0) * item.quantity), 0);
            const dynamicDiscount = order.items.reduce((sum, item) => sum + ((item.productDiscount || 0) * item.quantity), 0);
        %>
        <div class="admin-order-total-section">

            <div class="admin-order-total-box">

                <div class="admin-order-total-row">

                    <span class="admin-order-total-label">
                        Original Subtotal
                    </span>

                    <span class="admin-order-total-value">

                        ₹<%= dynamicSubtotal.toLocaleString() %>

                    </span>

                </div>

                <div class="admin-order-total-row text-success">

                    <span class="admin-order-total-label">
                        Product Discount
                    </span>

                    <span class="admin-order-total-value">

                        - ₹<%= dynamicDiscount.toLocaleString() %>

                    </span>

                </div>

                <div class="admin-order-total-row
                admin-order-grand">

                    <span class="admin-order-total-label">
                        Grand Total
                    </span>

                    <span class="admin-order-total-value">

                        ₹<%= order.totalAmount
                        .toLocaleString() %>

                    </span>

                </div>

            </div>

        </div>

    </div>

</div>

</div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Update Order Status</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="d-flex">

<%- include('../partials/admin/sidebar',
{ active:'orders' }) %>

<div class="main-content w-100 p-5">

    <!-- Header -->
    <div class="mb-4">

        <h2 class="fw-bold mb-1"
        style="color:#0f172a;">

            Order Details & Status

        </h2>

        <p class="text-muted mb-0">

            Order ID:
            #<%= order.orderId %>

        </p>

    </div>

    <!-- Top Grid -->
    <div class="row g-4 mb-4">
    <!-- Products Ordered -->
    <div class="col-lg-9">
    <div class="admin-order-products-card h-100">

        <div class="admin-order-products-header">

            <div class="admin-order-products-title">

                Products Ordered 

            </div>

            <div class="admin-order-products-count">

                <%= order.items.length %> items total

            </div>

        </div>

        <table class="table admin-order-table align-middle mb-0">

            <thead>

                <tr>

                    <th style="width: 35%;">PRODUCT</th>
                    <th style="width: 8%;">QTY</th>
                    <th style="width: 22%;">PRICE </th>
                    <th style="width: 35%;">STATUS & ACTIONS</th>

                </tr>

            </thead>

            <tbody>

            <% order.items.forEach(item => { %>

            <tr>

                <td>

                    <div class="admin-product-info">

                        <img
                        src="<%= item.productImage || '/images/no-image.png' %>"
                        class="admin-product-image" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px;">

                        <div>

                            <div class="admin-product-name fw-bold" style="color: #0f172a;">

                                <%= item.productName %>

                            </div>

                            <% if(item.variantValue){ %>

                            <div class="admin-product-meta text-muted small mt-1">

                                Variant: <strong><%= item.variantValue %></strong>

                            </div>

                            <% } %>

                        </div>

                    </div>

                </td>

                <td class="fw-bold">

                    × <%= item.quantity %>

                </td>

                <td>

                    <% 
                        const oPrice = item.originalPrice || item.price || 0;
                        const pDisc = item.productDiscount || 0;
                        const fPrice = item.finalPrice || item.price || 0;
                        const tPrice = item.totalPrice || (item.price * item.quantity) || 0;
                    %>
                    <div class="small">
                        <div class="fw-bold d-flex justify-content-between text-dark"><span>₹<%= fPrice.toLocaleString() %></span></div>
                    </div>
                   

                </td>
                
                <td>

                    <div class="d-flex flex-column gap-2">
                        <!-- Current status badge -->
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="order-badge
                                <%= item.status === 'Pending'
                                    ? 'order-pending'
                                    : item.status === 'Confirmed'
                                    ? 'order-processing'
                                    : item.status === 'Shipped' || item.status === 'Out for Delivery'
                                    ? 'order-shipped'
                                    : item.status === 'Delivered'
                                    ? 'order-delivered'
                                    : 'order-cancelled' %>">
                                <%= item.status %>
                            </span>
                            <!-- NORMAL STATUS UPDATE -->
                            <%
                            const isLockedStatus =
                                item.status === 'Cancelled' ||
                                item.status === 'Returned';
                            %>

                            <% if (!isLockedStatus &&
                                   item.status !== 'Cancellation Requested' &&
                                   item.status !== 'Return Requested') { %>

                            <form
                                action="/admin/orders/<%= order._id %>/items/<%= item._id %>/status"
                                method="POST"
                                class="d-flex gap-1 align-items-center">

                                <select
                                    name="status"
                                    class="form-select form-select-sm"
                                    style="width: 160px;">

                                    <% [
                                        'Pending',
                                        'Confirmed',
                                        'Shipped',
                                        'Out for Delivery',
                                        'Delivered'
                                    ].forEach(st => { %>

                                        <option
                                            value="<%= st %>"
                                            <%= item.status === st ? 'selected' : '' %>>

                                            <%= st %>

                                        </option>

                                    <% }) %>

                                </select>

                                <button
                                    type="submit"
                                    class="btn btn-sm btn-gold">

                                    Update

                                </button>

                            </form>

                            <% } else if (isLockedStatus) { %>

                            <button
                                type="button"
                                class="btn btn-sm btn-secondary"
                                disabled
                                style="opacity:0.6; cursor:not-allowed;">
                                Update 
                            </button>

                            <% } %>
                           <!-- CANCELLATION REQUEST -->
                            <% if(item.status === 'Cancellation Requested') { %>

                            <div class="alert alert-warning mt-2 mb-0 small">

                                <strong>
                                    Cancellation Request
                                </strong>

                                <% if(item.cancelReason) { %>

                                    <div class="mt-1">

                                        Reason:
                                        <%= item.cancelReason %>

                                    </div>

                                <% } %>

                                <div class="d-flex gap-2 mt-2">

                                    <!-- APPROVE -->
                                    <form
                                        action="/admin/orders/<%= order._id %>/item/<%= item._id %>/approve"
                                        method="POST">

                                        <button
                                            type="submit"
                                            class="btn btn-success btn-sm">

                                            Accept

                                        </button>

                                    </form>

                                    <!-- REJECT -->
                                    <form
                                        action="/admin/orders/<%= order._id %>/item/<%= item._id %>/reject"
                                        method="POST">

                                        <button
                                            type="submit"
                                            class="btn btn-danger btn-sm">

                                            Reject

                                        </button>

                                    </form>

                                </div>

                            </div>

                            <% } %>
                            <!-- RETURN REQUEST -->
                            <% if(item.status === 'Return Requested') { %>

                            <div class="alert alert-info mt-2 mb-0 small text-dark">

                                <strong>
                                    Return Request
                                </strong>

                                <% if(item.returnReason) { %>

                                    <div class="mt-1">

                                        Reason:
                                        <%= item.returnReason %>

                                    </div>

                                <% } %>

                                <!-- DAMAGE LABEL -->
                                <% if(
                                    item.returnReason &&
                                    item.returnReason.toLowerCase().includes('damage')
                                ) { %>

                                    <div class="text-danger fw-bold mt-1">

                                        Damaged Return
                                        → Stock will NOT increase

                                    </div>

                                <% } %>

                                <div class="d-flex gap-2 mt-2">

                                    <!-- APPROVE -->
                                    <form
                                        action="/admin/orders/<%= order._id %>/item/<%= item._id %>/approve"
                                        method="POST">

                                        <button
                                            type="submit"
                                            class="btn btn-success btn-sm">

                                            Accept

                                        </button>

                                    </form>

                                    <!-- REJECT -->
                                    <form
                                        action="/admin/orders/<%= order._id %>/item/<%= item._id %>/reject"
                                        method="POST">

                                        <button
                                            type="submit"
                                            class="btn btn-danger btn-sm">

                                            Reject

                                        </button>

                                    </form>

                                </div>

                            </div>

                            <% } %>
                            
                        </div>

                        <!-- Cancellation Reason -->
                        <% if (item.status === 'Cancelled' && item.cancelReason) { %>
                            <div class="alert alert-danger p-2 mb-0 mt-1 small">
                                <strong>Cancel Reason:</strong> <%= item.cancelReason %>
                                <% if (item.cancelledAt) { %>
                                    <div class="text-muted text-end mt-1" style="font-size: 10px;">At: <%= new Date(item.cancelledAt).toLocaleString() %></div>
                                <% } %>
                            </div>
                        <% } %>

                        <!-- Return Reason -->
                        <% if (item.status === 'Returned' && item.returnReason) { %>
                            <div class="alert alert-warning p-2 mb-0 mt-1 small text-dark">
                                <strong>Return Reason:</strong> <%= item.returnReason %>
                                <% if (item.returnedAt) { %>
                                    <div class="text-muted text-end mt-1" style="font-size: 10px;">At: <%= new Date(item.returnedAt).toLocaleString() %></div>
                                <% } %>
                            </div>
                        <% } %>

                        <!-- Refund Manager 
                        <div class="bg-light p-2 rounded mt-1 border">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small text-muted">Refund Amount:</span>
                                <span class="fw-bold small text-dark">₹<%= (item.refundAmount || 0).toLocaleString() %></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small text-muted">Refund Status:</span>
                                <span class="badge bg-secondary mb-1" style="font-size: 10px;"><%= item.refundStatus %></span>
                            </div>
                            <form action="/admin/orders/<%= order._id %>/items/<%= item._id %>/refund" method="POST" class="d-flex gap-1 align-items-center mt-1">
                                <input type="number" name="refundAmount" value="<%= item.refundAmount || 0 %>" class="form-control form-control-sm" style="width: 70px;" placeholder="Amount">
                                <select name="refundStatus" class="form-select form-select-sm" style="width: 110px; font-size: 11px;">
                                    <% ['Not Requested', 'Pending', 'Processed', 'Completed'].forEach(rs => { %>
                                        <option value="<%= rs %>" <%= item.refundStatus === rs ? 'selected' : '' %>><%= rs %></option>
                                    <% }) %>
                                </select>
                                <button type="submit" class="btn btn-sm btn-dark" style="font-size: 11px;">Save</button>
                            </form>
                        </div>-->
                    </div>

                </td>

            </tr>

            <% }) %>
            <tr class="border-0">

    <td></td>

    <td></td>

    <!-- BELOW PRICE COLUMN -->
    <td colspan="2"class="pt-4">

        <div class="d-flex
                    justify-content-end
                    align-items-center
                    gap-4
                    fw-bold fs-5">

            <div>

                Grand Total :

                <span class="ms-1 text-dark">

                    ₹<%= order.totalAmount.toLocaleString() %>

                </span>

            </div>

           <!-- <span class="
                badge
                <%= order.orderStatus === 'Delivered'
                    ? 'bg-success'
                    : 'bg-warning text-dark' %>">

                <%= order.orderStatus === 'Delivered'
                    ? 'Paid'
                    : 'Pending' %>

            </span>-->

        </div>

    </td>

</tr>


            </tbody>

        </table>

       
    </div>
    </div>
    <!--customer details-->
     <div class="col-lg-3">
        <div class="admin-order-detail-card h-100 ">
            
            <h3 class="admin-order-card-title">

                Customer & Shipping

            </h3>

            <div class="mb-4">

                <div class="admin-order-label">
                    Customer
                </div>

                <div class="admin-order-text">

                    <strong><%= order.userId?.name || 'Customer' %></strong><br>
                    <%= order.userId?.email || '' %>

                </div>

            </div>

            <div>

                <div class="admin-order-label">
                    Shipping Address
                </div>

                <div class="admin-order-text">

                    <i class="fa-solid fa-location-dot me-2"
                    style="color:#c26a00;"></i>

                    <%= order.shippingAddress.name %><br>
                    <%= order.shippingAddress.street %>,
                    <br>

                    <%= order.shippingAddress.city %>,
                    <%= order.shippingAddress.state %>

                    -
                    <%= order.shippingAddress.pincode %>

                    <br>

                    <%= order.shippingAddress.country %><br>
                    Phone: <%= order.shippingAddress.phone %>

                </div>

            </div>

        </div>

    </div>

    </div>

</div>

</div>

</body>
</html>
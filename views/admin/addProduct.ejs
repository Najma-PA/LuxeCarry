<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product | LuxeCarry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"/>
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .image-slot {
            width: 100%;
            aspect-ratio: 4/5;
            border: 2px dashed #ddd;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            overflow: hidden;
            background: #fff;
            position: relative;
            transition: all 0.3s ease;
        }
        .image-slot:hover {
            border-color: #ca8a04;
            background: #fffbeb;
        }
        .image-slot img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }
        .image-slot .slot-placeholder {
            text-align: center;
            color: #94a3b8;
        }
        .image-slot .slot-placeholder i {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        .image-slot.has-image .slot-placeholder {
            display: none;
        }
        .image-slot.has-image img {
            display: block;
        }
    </style>
</head>

<body>
<div class="main-content p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0">Add Product</h4>
        <a href="/admin/products" class="btn btn-outline-secondary btn-sm">Back to List</a>
    </div>

    <form id="productForm" enctype="multipart/form-data">

        <div class="row">
            <!-- LEFT: General Info -->
            <div class="col-md-7">
                <div class="card p-4 mb-4 shadow-sm border-0">
                    <h6 class="fw-bold mb-3 border-bottom pb-2">General Information</h6>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Product Name</label>
                        <input type="text" name="name" class="form-control" placeholder="Enter product name" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Category</label>
                        <select name="category" class="form-select" required>
                            <option value="" disabled selected>Select Category</option>
                            <% categories.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Base Price (₹)</label>
                            <input type="number" name="price" class="form-control" placeholder="0.00" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Discount (%)</label>
                            <input type="number" name="offer" class="form-control" placeholder="0" min="0" max="99">
                        </div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label text-muted small fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="4" placeholder="Briefly describe the product..."></textarea>
                    </div>
                </div>

                <!-- VARIANTS -->
                <div class="card p-4 shadow-sm border-0">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold m-0 border-bottom pb-2 flex-grow-1">Product Variants</h6>
                        <button type="button" onclick="addVariant()" class="btn btn-gold btn-sm ms-3">+ Add</button>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="small py-2">Type</th>
                                    <th class="small py-2">Value</th>
                                    <th class="small py-2">Stock</th>
                                    <th class="small py-2 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody id="variantTable"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Images -->
            <div class="col-md-5">
                <div class="card p-4 shadow-sm border-0">
                    <h6 class="fw-bold mb-3 border-bottom pb-2">Product Images</h6>
                    <p class="text-muted small mb-3">Upload at least 3 high-quality images. Recommended aspect ratio 4:5.</p>
                    
                    <div class="row g-3">
                        <!-- Slot 1 -->
                        <div class="col-6">
                            <div class="image-slot" id="slot1" onclick="triggerFileInput(1)">
                                <div class="slot-placeholder">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <div class="small">Main Image</div>
                                </div>
                                <img id="img1" src="" alt="">
                                <input type="file" id="input1" accept="image/*" hidden onchange="handleFileSelect(event, 1)">
                            </div>
                        </div>
                        <!-- Slot 2 -->
                        <div class="col-6">
                            <div class="image-slot" id="slot2" onclick="triggerFileInput(2)">
                                <div class="slot-placeholder">
                                    <i class="fas fa-plus"></i>
                                    <div class="small">Image 2</div>
                                </div>
                                <img id="img2" src="" alt="">
                                <input type="file" id="input2" accept="image/*" hidden onchange="handleFileSelect(event, 2)">
                            </div>
                        </div>
                        <!-- Slot 3 -->
                        <div class="col-6">
                            <div class="image-slot" id="slot3" onclick="triggerFileInput(3)">
                                <div class="slot-placeholder">
                                    <i class="fas fa-plus"></i>
                                    <div class="small">Image 3</div>
                                </div>
                                <img id="img3" src="" alt="">
                                <input type="file" id="input3" accept="image/*" hidden onchange="handleFileSelect(event, 3)">
                            </div>
                        </div>
                        <!-- Slot 4 -->
                        <div class="col-6">
                            <div class="image-slot" id="slot4" onclick="triggerFileInput(4)">
                                <div class="slot-placeholder">
                                    <i class="fas fa-plus"></i>
                                    <div class="small">Image 4</div>
                                </div>
                                <img id="img4" src="" alt="">
                                <input type="file" id="input4" accept="image/*" hidden onchange="handleFileSelect(event, 4)">
                            </div>
                        </div>
                    </div>

                    <div id="imageError" class="text-danger small mt-2 d-none">Please upload at least 3 images.</div>

                    <button type="submit" class="btn btn-gold w-100 mt-4 py-2 fw-bold">SAVE PRODUCT</button>
                    <div id="submitSpinner" class="text-center mt-2 d-none">
                        <div class="spinner-border spinner-border-sm text-warning" role="status"></div>
                        <span class="small ms-1">Saving...</span>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

<!-- CROPPING MODAL -->
<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crop Image (4:5 Ratio)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="img-container" style="max-height: 500px">
                    <img id="cropperImage" src="" style="max-width: 100%">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="cropButton" class="btn btn-gold">Crop & Save</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>
    let cropper;
    let currentSlot = null;
    let croppedBlobs = [null, null, null, null];
    const cropModal = new bootstrap.Modal(document.getElementById('cropModal'));

    function addVariant() {
        const row = `
            <tr class="variant-row">
                <td><input name="variantType[]" value="Color" class="form-control form-control-sm border-0 bg-light"></td>
                <td><input name="variantValue[]" class="form-control form-control-sm" placeholder="e.g. Black"></td>
                <td><input type="number" name="variantStock[]" class="form-control form-control-sm" value="0"></td>
                <td class="text-end"><button type="button" onclick="this.closest('tr').remove()" class="btn btn-sm btn-light text-danger">X</button></td>
            </tr>
        `;
        document.getElementById('variantTable').insertAdjacentHTML('beforeend', row);
    }

    // Initial variant
    addVariant();

    function triggerFileInput(slot) {
        document.getElementById(`input${slot}`).click();
    }

    function handleFileSelect(event, slot) {
        const file = event.target.files[0];
        if (!file) return;

        currentSlot = slot;
        const reader = new FileReader();
        reader.onload = (e) => {
            const img = document.getElementById('cropperImage');
            img.src = e.target.result;
            cropModal.show();
        };
        reader.readAsDataURL(file);
    }

    // Initialize Cropper when modal opens
    document.getElementById('cropModal').addEventListener('shown.bs.modal', function () {
        cropper = new Cropper(document.getElementById('cropperImage'), {
            aspectRatio: 4 / 5,
            viewMode: 2,
            autoCropArea: 1
        });
    });

    // Cleanup Cropper when modal hides
    document.getElementById('cropModal').addEventListener('hidden.bs.modal', function () {
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }
        // Reset file input so same file can be chosen again
        document.getElementById(`input${currentSlot}`).value = "";
    });

    document.getElementById('cropButton').onclick = function () {
        if (!cropper) return;

        cropper.getCroppedCanvas({
            width: 800,
            height: 1000
        }).toBlob((blob) => {
            croppedBlobs[currentSlot - 1] = blob;
            
            // Show preview
            const previewImg = document.getElementById(`img${currentSlot}`);
            previewImg.src = URL.createObjectURL(blob);
            document.getElementById(`slot${currentSlot}`).classList.add('has-image');
            
            cropModal.hide();
        }, 'image/jpeg', 0.9);
    };

    // FORM SUBMISSION
    document.getElementById('productForm').onsubmit = async function(e) {
        e.preventDefault();

        // Validate images (count non-null blobs)
        const totalImages = croppedBlobs.filter(b => b !== null).length;
        if (totalImages < 3) {
            document.getElementById('imageError').classList.remove('d-none');
            Swal.fire('Wait!', 'Please upload at least 3 images.', 'warning');
            return;
        }
        document.getElementById('imageError').classList.add('d-none');

        // Show spinner
        document.getElementById('submitSpinner').classList.remove('d-none');
        const submitBtn = e.target.querySelector('button[type="submit"]');
        submitBtn.disabled = true;

        const formData = new FormData(this);
        
        // Remove standard 'images' files if any (we are using blobs)
        formData.delete('images');

        // Append cropped blobs
        croppedBlobs.forEach((blob, index) => {
            if (blob) {
                formData.append('images', blob, `product-${index + 1}.jpg`);
            }
        });

        try {
            const response = await fetch('/admin/products/add', {
                method: 'POST',
                body: formData
            });

            if (response.redirected) {
                window.location.href = response.url;
            } else {
                const result = await response.text();
                // If it's not a redirect, it might be an error message
                Swal.fire('Error', result || 'Something went wrong', 'error');
            }
        } catch (err) {
            console.error(err);
            Swal.fire('Error', 'Server communication failed', 'error');
        } finally {
            document.getElementById('submitSpinner').classList.add('d-none');
            submitBtn.disabled = false;
        }
    };
</script>

</body>
</html>
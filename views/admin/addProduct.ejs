<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/admin.css">

</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<body>
 <div class="main-content p-4">

<h4 class="fw-bold">Add Product</h4>

<form method="POST" enctype="multipart/form-data">

<div class="row">

<!-- LEFT -->
<div class="col-md-7">

  <div class="card p-3 mb-3">
    <h6>General Information</h6>

    <input type="text" name="name" class="form-control mb-2" placeholder="Product Name">

    <select name="category" class="form-select mb-2">
      <% categories.forEach(c => { %>
        <option value="<%= c._id %>"><%= c.name %></option>
      <% }) %>
    </select>

    <div class="d-flex gap-2">
      <input type="number" name="price" class="form-control" placeholder="Base Price">
      <input type="number" name="offer" class="form-control" placeholder="Discount">
    </div>

    <textarea name="description" class="form-control mt-2"
      placeholder="Description"></textarea>

  </div>

</div>

<!-- RIGHT -->
<div class="col-md-5">

  <div class="card p-3">

    <h6>Product Images</h6>

    <input type="file" name="images" multiple class="form-control mb-2">

    <small class="text-muted">Min 3 images required</small>

  </div>

</div>

</div>

<!-- VARIANTS -->
<div class="card p-3 mt-3">

  <div class="d-flex justify-content-between">
    <h6>Product Variants</h6>
    <button type="button" onclick="addVariant()">+ Add Variant</button>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Type</th>
        <th>Value</th>
        <th>Stock</th>
        <th></th>
      </tr>
    </thead>

    <tbody id="variantTable"></tbody>
  </table>

</div>

<button class="btn btn-warning text-white mt-3">Save Product</button>

</form>
</div>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function addVariant() {
  const row = `
    <tr>
      <td><input name="variantType[]" value="Color" class="form-control"></td>
      <td><input name="variantValue[]" class="form-control"></td>
      <td><input name="variantStock[]" class="form-control"></td>
      <td><button onclick="this.closest('tr').remove()">X</button></td>
    </tr>
  `;
  document.getElementById('variantTable').innerHTML += row;
}
</script>

</body>
</html>
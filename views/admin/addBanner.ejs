<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Banner - LuxeCarry Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .banner-card {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
    .upload-box {
      border: 2px dashed #cbd5e1;
      border-radius: 10px;
      padding: 40px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
      height: 300px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background-color: #f8fafc;
    }
    .upload-box:hover {
      border-color: #c26a00;
      background-color: #fffaf0;
    }
    .upload-icon {
      font-size: 48px;
      color: #94a3b8;
      margin-bottom: 15px;
      background: #f1f5f9;
      width: 80px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
    }
    .preview-img {
      max-width: 100%;
      max-height: 250px;
      border-radius: 8px;
      display: none;
      object-fit: cover;
    }
    .form-label-custom {
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 8px;
    }
    .form-control-custom {
      border-radius: 8px;
      border: 1px solid #e2e8f0;
      padding: 12px;
    }
    .btn-save {
      background: #c26a00;
      color: white;
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-weight: 600;
      transition: all 0.3s;
    }
    .btn-save:hover {
      background: #a85700;
      transform: translateY(-2px);
    }
    .status-switch {
      width: 50px;
      height: 24px;
    }
    .cropper-container {
      max-height: 400px;
      overflow: hidden;
    }
    #cropperImage {
      max-width: 100%;
      display: block;
    }
  </style>
</head>
<body style="background-color: #f1f5f9;">

<div class="d-flex">
  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'banners' }) %>

  <!-- Main Content -->
  <div class="flex-grow-1 p-5">
    
    <div class="mb-4">
      <h2 class="fw-bold mb-1">Add Banner</h2>
      <p class="text-muted">Create homepage promotional banner.</p>
    </div>

    <form id="addBannerForm" enctype="multipart/form-data">
      <div class="banner-card">
        <div class="row g-4">
          
          <!-- Form Fields -->
          <div class="col-md-7">
            <div class="mb-3">
              <label class="form-label-custom">Banner Title</label>
              <input type="text" name="title" class="form-control form-control-custom" placeholder="e.g. Summer Collection 2024" required>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Subtitle</label>
              <input type="text" name="subtitle" class="form-control form-control-custom" placeholder="e.g. Get up to 50% off on all luxury items">
            </div>

            <div class="row mb-3">
              <div class="col-md-8">
                <label class="form-label-custom">Button Text</label>
                <input type="text" name="buttonText" class="form-control form-control-custom" value="Shop Now">
              </div>
              <div class="col-md-4">
                <label class="form-label-custom">Status</label>
                <div class="form-check form-switch mt-2">
                  <input class="form-check-input status-switch" type="checkbox" name="status" checked>
                  <label class="form-check-label ms-2 mt-1 fw-bold">Active</label>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Redirect URL</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0">https://</span>
                <input type="text" name="link" class="form-control form-control-custom border-start-0" placeholder="luxecarry.com/summer-sale">
              </div>
            </div>
          </div>

          <!-- Image Upload -->
          <div class="col-md-5">
            <label class="form-label-custom">Banner Image Preview</label>
            <div class="upload-box" id="uploadBox" onclick="document.getElementById('bannerImage').click()" style="height: 250px; position: relative; overflow: hidden; border-radius: 15px; border: 2px dashed #c26a00;">
              <div id="uploadPlaceholder" style="z-index: 1;">
                <div class="upload-icon mx-auto" style="width: 60px; height: 60px; font-size: 32px;">
                  <i class="fa-solid fa-cloud-arrow-up"></i>
                </div>
                <p class="fw-bold mb-1">Click to upload</p>
                <small class="text-muted">Aspect Ratio: 1320x450 (Recommended)</small>
              </div>
              <img id="imagePreview" class="preview-img" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;">
              <input type="file" name="image" id="bannerImage" hidden accept="image/*">
            </div>
          </div>

        </div>

        <hr class="my-4" style="color: #e2e8f0;">

        <div class="d-flex justify-content-end gap-3">
          <a href="/admin/banners" class="btn btn-light px-4">Cancel</a>
          <button type="submit" class="btn btn-save" id="submitBtn">
            <i class="fa-solid fa-floppy-disk me-2"></i> Save Banner
          </button>
        </div>
      </div>
    </form>

  </div>
</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Crop Banner Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="cropper-container">
          <img id="cropperImage" src="" alt="Image to crop">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-save" id="cropButton">Crop & Save</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script>
  let cropper;
  let croppedBlob;
  const cropperModal = new bootstrap.Modal(document.getElementById('cropperModal'));
  const cropperImage = document.getElementById('cropperImage');
  const bannerImage = document.getElementById('bannerImage');
  const imagePreview = document.getElementById('imagePreview');
  const uploadPlaceholder = document.getElementById('uploadPlaceholder');

  // Image Selection
  bannerImage.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
    if (!allowedTypes.includes(file.type)) {
      Swal.fire('Error', 'Invalid image format', 'error');
      this.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = function(ev) {
      cropperImage.src = ev.target.result;
      cropperModal.show();
    };
    reader.readAsDataURL(file);
  });

  // Initialize Cropper
  document.getElementById('cropperModal').addEventListener('shown.bs.modal', function () {
    cropper = new Cropper(cropperImage, {
      aspectRatio: 1320 / 450,
      viewMode: 2,
      autoCropArea: 1,
    });
  });

  // Destroy Cropper
  document.getElementById('cropperModal').addEventListener('hidden.bs.modal', function () {
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
  });

  // Handle Crop Button
  document.getElementById('cropButton').addEventListener('click', function() {
    const canvas = cropper.getCroppedCanvas({
      width: 1320,
      height: 450,
    });

    canvas.toBlob((blob) => {
      croppedBlob = blob;
      const url = URL.createObjectURL(blob);
      
      imagePreview.src = url;
      imagePreview.style.display = 'block';
      uploadPlaceholder.style.display = 'none';
      
      cropperModal.hide();
    }, 'image/jpeg', 0.9);
  });

  // Form Submit
  document.getElementById('addBannerForm').onsubmit = async function(e) {
    e.preventDefault();
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Saving...';

    const formData = new FormData(this);
    if (croppedBlob) {
      formData.set('image', croppedBlob, 'banner.jpg');
    }

    try {
      const response = await fetch('/admin/banners/add', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success!',
          text: result.message,
          confirmButtonColor: '#c26a00'
        }).then(() => {
          window.location.href = result.redirectUrl;
        });
      } else {
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: result.message
        });
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk me-2"></i> Save Banner';
      }
    } catch (err) {
      console.error(err);
      Swal.fire({ icon: 'error', title: 'Error', text: 'Server communication failed' });
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk me-2"></i> Save Banner';
    }
  };
</script>

</body>
</html>

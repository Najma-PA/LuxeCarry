<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Category</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="d-flex">

  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'categories' }) %>

  <!-- MAIN -->
  <div class="flex-grow-1 main-content p-4">

    <!-- Header -->
    <div class="d-flex align-items-center mb-4">
      <a href="/admin/categories" class="me-2 text-dark">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <h5 class="fw-bold m-0">Add Category</h5>
    </div>

    <!-- CARD -->
    <div class="category-card">

      <h6 class="fw-bold">Category Information</h6>
      <p class="text-muted small mb-4">
        Provide the details for your product category.
      </p>

      <form id="addCategoryForm" enctype="multipart/form-data">

        <!-- Name -->
        <div class="mb-3">
          <label class="form-label-custom">Category Name</label>
          <input type="text" name="name" class="form-control-custom" id="catName">
          <div id="nameError" class="text-danger small mt-1 d-none"></div>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label-custom">Description</label>
          <textarea name="description" class="form-control-custom" rows="4" id="catDesc"></textarea>
        </div>

        <!-- Upload -->
        <div class="mb-3">
          <label class="form-label-custom">Category Image</label>

          <div class="upload-area" onclick="this.querySelector('input').click()">

            <div class="text-center" id="uploadPlaceholder">
              <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
              <p class="mb-1">Click to upload or drag and drop</p>
              <small class="text-muted">PNG, JPG (Max. 2MB)</small>
            </div>

            <input type="file" name="image" hidden id="catImage">

          </div>

          <!-- Preview -->
          <div class="mt-2 d-none" id="previewContainer">
            <img id="previewImg" class="preview-img">
          </div>
        </div>

        <!-- Offer -->
        <div class="mb-4">
          <label class="form-label-custom">Category Offer (%)</label>
          <input type="number" name="offer" class="form-control-custom" id="catOffer">
          <div id="offerError" class="text-danger small mt-1 d-none"></div>
        </div>

        <!-- Buttons -->
        <div class="d-flex justify-content-end gap-2">
          <a href="/admin/categories" class="btn btn-light">Cancel</a>
          <button type="submit" class="btn-primary-custom" id="submitBtn">
            <span id="btnText">💾 Save Category</span>
            <span id="btnSpinner" class="spinner-border spinner-border-sm d-none"></span>
          </button>
        </div>

      </form>

    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>

<script>
// Error helpers
function setFieldError(id, msg) {
  const el = document.getElementById(id);
  if (el) {
    el.innerText = msg;
    el.classList.remove('d-none');
  }
}

function clearFieldError(id) {
  const el = document.getElementById(id);
  if (el) el.classList.add('d-none');
}

// Clear errors
document.querySelectorAll('input, textarea').forEach(el => {
  el.addEventListener('input', () => {
    if (el.id === 'catName') clearFieldError('nameError');
    if (el.id === 'catOffer') clearFieldError('offerError');
  });
});

// Image preview
document.getElementById('catImage').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;

  const allowedTypes = ['image/jpeg','image/jpg','image/png','image/webp'];
  if (!allowedTypes.includes(file.type)) {
    Swal.fire('Error','Invalid image format','error');
    this.value = '';
    return;
  }

  const reader = new FileReader();
  reader.onload = function(ev) {
    document.getElementById('previewImg').src = ev.target.result;
    document.getElementById('previewContainer').classList.remove('d-none');
    document.getElementById('uploadPlaceholder').style.display = 'none';
  };
  reader.readAsDataURL(file);
});

// Submit
document.getElementById('addCategoryForm').onsubmit = async function(e) {
  e.preventDefault();

  clearFieldError('nameError');
  clearFieldError('offerError');

  const btn = document.getElementById('submitBtn');
  const text = document.getElementById('btnText');
  const spinner = document.getElementById('btnSpinner');

  btn.disabled = true;
  text.classList.add('d-none');
  spinner.classList.remove('d-none');

  const formData = new FormData(this);

  try {
    const res = await fetch('/admin/categories/add', {
      method: 'POST',
      body: formData
    });

    const result = await res.json();

    if (result.success) {
      Swal.fire('Success', result.message, 'success')
        .then(() => window.location.href = '/admin/categories');
    } else {
      if (result.errors) {
        if (result.errors.name) setFieldError('nameError', result.errors.name);
        if (result.errors.offer) setFieldError('offerError', result.errors.offer);
      } else {
        Swal.fire('Error', result.message, 'error');
      }
    }

  } catch (err) {
    Swal.fire('Error','Server error','error');
  } finally {
    btn.disabled = false;
    text.classList.remove('d-none');
    spinner.classList.add('d-none');
  }
};
</script>

</body>
</html>
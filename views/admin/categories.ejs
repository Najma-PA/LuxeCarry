<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories - LuxeCarry Admin</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/admin.css">

</head>
<body>
<div class="d-flex">
  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'categories' }) %>

  <!-- Main -->
  <div class="main-content p-5 w-100">
    <% const currentStatus = typeof status !== 'undefined' ? status : 'active'; %>

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-bold mb-1" style="color: #0f172a;">Categories</h2>
        <p class="text-muted mb-0" style="font-size: 15px;">Manage and organize your luxury product collection</p>
      </div>

      <div class="d-flex gap-3 align-items-center">
        <!-- Search -->
        <form method="GET" class="search-bar-wrapper position-relative">
          <i class="fa-solid fa-magnifying-glass" style="color: #94a3b8; font-size: 14px;"></i>
          <input type="hidden" name="status" value="<%= typeof status !== 'undefined' ? status : 'active' %>">
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search" class="ms-2 pe-4" onchange="this.form.submit()">
          <% if (search) { %>
            <a href="/admin/categories?status=<%= typeof status !== 'undefined' ? status : 'active' %>" class="position-absolute" style="right: 12px; top: 50%; transform: translateY(-50%); color: #dc2626; text-decoration: none;" title="Clear Search">
              <i class="fa-solid fa-circle-xmark fs-6"></i>
            </a>
          <% } %>
        </form>

        <!-- Add Button -->
        <a href="/admin/categories/add" class="btn-gold d-flex align-items-center gap-2">
        
          <i class="fa-solid fa-plus text-white" style="font-size: 13px;"></i> Add Category
        </a>

      </div>
    </div>

    <!-- Table Card -->
    <div class="card-shadow">

      <!-- Tabs -->
      <div class="d-flex justify-content-between align-items-center px-4 pt-3 pb-0 border-bottom" style="border-color: #f1f5f9 !important;">
        <div class="tab-nav d-flex gap-4">
          <a href="?status=active&search=<%= search %>" class="pb-2 text-decoration-none <%= currentStatus === 'active' ? 'active-tab' : 'text-muted' %>" style="<%= currentStatus === 'active' ? 'border-bottom: 2px solid #c26a00; color: #c26a00 !important; font-weight: 600;' : '' %>">Active Categories</a>
          <a href="?status=archived&search=<%= search %>" class="pb-2 text-decoration-none <%= currentStatus === 'archived' ? 'active-tab' : 'text-muted' %>" style="<%= currentStatus === 'archived' ? 'border-bottom: 2px solid #c26a00; color: #c26a00 !important; font-weight: 600;' : '' %>">Archived</a>
        </div>
      </div>

      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>CATEGORY NAME</th>
            <th>OFFER</th>
            <th>PRODUCT COUNT</th>
            <th>STATUS</th>
            <th>ACTIONS</th>
          </tr>
        </thead>
        <tbody>
          <% if(categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
              <tr>
                <td><span class="fw-bold" style="color: #1e293b;"><%= cat.name %></span></td>
                <td><span style="color: #475569; font-weight: 500;"><%= cat.offer || 0 %>%</span></td>
                <td><span style="color: #475569;"><%= cat.productCount || 0 %></span></td>
                <td>
                  <% if(cat.isActive){ %>
                    <span class="pill-badge status-active px-3 py-1">Active</span>
                  <% } else { %>
                    <span class="pill-badge status-inactive px-3 py-1">Inactive</span>
                  <% } %>
                </td>
                <td>
                  <% if (currentStatus !== 'archived') { %>
                    <a href="/admin/categories/edit/<%= cat._id %>" class="btn-action" title="Edit">
                      <i class="fa-solid fa-pen" style="font-size: 14px;"></i>
                    </a>
                    <% if (cat.isActive) { %>
                      <button onclick="toggleStatus('<%= cat._id %>', 'unlist')" class="btn-action" title="Unlist">
                        <i class="fa-solid fa-eye-slash" style="font-size: 14px; color: #dc2626;"></i>
                      </button>
                    <% } else { %>
                      <button onclick="toggleStatus('<%= cat._id %>', 'list')" class="btn-action" title="List">
                        <i class="fa-solid fa-eye" style="font-size: 14px; color: #16a34a;"></i>
                      </button>
                    <% } %>
                    <button onclick="deleteCategory('<%= cat._id %>')" class="btn-action" title="Delete">
                      <i class="fa-solid fa-trash" style="font-size: 14px; color: #64748b;"></i>
                    </button>
                  <% } else { %>
                    <button onclick="restoreCategory('<%= cat._id %>')" class="btn-action" title="Restore" style="color: #16a34a;">
                      <i class="fa-solid fa-trash-arrow-up" style="font-size: 14px;"></i> Restore
                    </button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="5" class="text-center py-5 text-muted">No categories found.</td></tr>
          <% } %>
        </tbody>
      </table>

      <!-- Pagination -->
      <div class="pagination-wrapper">
        <% if(currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&search=<%= search %>&status=<%= currentStatus %>" class="page-btn"><i class="fa-solid fa-chevron-left" style="font-size: 12px;"></i></a>
        <% } %>
        
        <% for(let i=1; i<=totalPages; i++){ %>
          <a href="?page=<%= i %>&search=<%= search %>&status=<%= currentStatus %>" class="page-btn <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&search=<%= search %>&status=<%= currentStatus %>" class="page-btn"><i class="fa-solid fa-chevron-right" style="font-size: 12px;"></i></a>
        <% } %>
      </div>

    </div>

  </div>
</div>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function toggleStatus(id, action) {
  const isUnlisting = action === 'unlist';
  Swal.fire({
    title: isUnlisting ? 'Unlist Category?' : 'List Category?',
    text: isUnlisting 
      ? "Unlisting this category will hide it and its products from customers." 
      : "Listing this category will make it and its products visible to customers.",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: isUnlisting ? '#dc2626' : '#16a34a',
    cancelButtonColor: '#64748b',
    confirmButtonText: isUnlisting ? 'Yes, unlist it!' : 'Yes, list it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        console.log('Toggling status for ID:', id);
        const res = await fetch(`/admin/categories/toggle/${id}`, {
          method: 'PATCH'
        });

        if (!res.ok) {
          const contentType = res.headers.get('content-type');
          if (contentType && contentType.includes('application/json')) {
            const errorData = await res.json();
            throw new Error(errorData.message || `Server returned ${res.status}`);
          } else {
            const errorText = await res.text();
            console.error('Non-JSON Error Response:', errorText);
            throw new Error(`Server returned ${res.status}`);
          }
        }

        const data = await res.json();
        if (data.success) {
          Swal.fire(isUnlisting ? 'Unlisted!' : 'Listed!', data.message, 'success')
            .then(() => location.reload());
        } else {
          Swal.fire('Error', data.message || 'Action failed', 'error');
        }
      } catch (err) {
        console.error('Toggle Status Error:', err);
        Swal.fire('Error', err.message || 'Something went wrong', 'error');
      }
    }
  });
}

async function deleteCategory(id) {
  Swal.fire({
    title: 'Archive Category?',
    text: "This category will be moved to the archived list.",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc2626',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Yes, archive it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const res = await fetch(`/admin/categories/${id}`, {
          method: 'DELETE'
        });
        const data = await res.json();
        if (data.success) {
          Swal.fire('Archived!', data.message, 'success').then(() => location.reload());
        } else {
          Swal.fire('Error', data.message || 'Action failed', 'error');
        }
      } catch (err) {
        Swal.fire('Error', 'Something went wrong', 'error');
      }
    }
  });
}

async function restoreCategory(id) {
  Swal.fire({
    title: 'Restore Category?',
    text: "This category will be moved back to the active list.",
    icon: 'question',
    showCancelButton: true,
    confirmButtonColor: '#16a34a',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Yes, restore it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const res = await fetch(`/admin/categories/restore/${id}`, {
          method: 'PATCH'
        });
        const data = await res.json();
        if (data.success) {
          Swal.fire('Restored!', data.message, 'success').then(() => location.reload());
        } else {
          Swal.fire('Error', data.message || 'Action failed', 'error');
        }
      } catch (err) {
        Swal.fire('Error', 'Something went wrong', 'error');
      }
    }
  });
}
</script>

</body>
</html>
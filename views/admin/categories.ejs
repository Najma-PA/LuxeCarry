<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories - LuxeCarry Admin</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/admin.css">

</head>
<body>
<div class="d-flex">
  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'categories' }) %>

  <!-- Main -->
  <div class="main-content p-5 w-100">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-bold mb-1" style="color: #0f172a;">Categories</h2>
        <p class="text-muted mb-0" style="font-size: 15px;">Manage and organize your luxury product collection</p>
      </div>

      <div class="d-flex gap-3 align-items-center">
        <!-- Search -->
        <form method="GET" class="search-bar-wrapper position-relative">
          <i class="fa-solid fa-magnifying-glass" style="color: #94a3b8; font-size: 14px;"></i>
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search" class="ms-2 pe-4" onchange="this.form.submit()">
          <% if (search) { %>
            <a href="/admin/categories" class="position-absolute" style="right: 12px; top: 50%; transform: translateY(-50%); color: #dc2626; text-decoration: none;" title="Clear Search">
              <i class="fa-solid fa-circle-xmark fs-6"></i>
            </a>
          <% } %>
        </form>

        <!-- Add Button -->
        <a href="/admin/categories/add" class="btn-gold d-flex align-items-center gap-2">
        
          <i class="fa-solid fa-plus text-white" style="font-size: 13px;"></i> Add Category
        </a>

      </div>
    </div>

    <!-- Table Card -->
    <div class="card-shadow">

      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>CATEGORY NAME</th>
            <th>OFFER</th>
            <th>PRODUCT COUNT</th>
            <th>STATUS</th>
            <th>ACTIONS</th>
          </tr>
        </thead>
        <tbody>
          <% if(categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
              <tr>
                <td><span class="fw-bold" style="color: #1e293b;"><%= cat.name %></span></td>
                <td><span style="color: #475569; font-weight: 500;"><%= cat.offer || 0 %>%</span></td>
                <td><span style="color: #475569;"><%= cat.productCount || 0 %></span></td>
                <td>
                  <% if(cat.isActive){ %>
                    <span class="pill-badge status-active px-3 py-1">Active</span>
                  <% } else { %>
                    <span class="pill-badge status-inactive px-3 py-1">Inactive</span>
                  <% } %>
                </td>
                <td>
                  <a href="/admin/categories/edit/<%= cat._id %>" class="btn-action" title="Edit">
                    <i class="fa-solid fa-pen" style="font-size: 14px;"></i>
                  </a>
                  <button onclick="deleteCategory('<%= cat._id %>')" class="btn-action" title="Delete">
                    <i class="fa-regular fa-trash-can" style="font-size: 14px;"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="5" class="text-center py-5 text-muted">No categories found.</td></tr>
          <% } %>
        </tbody>
      </table>

      <!-- Pagination -->
      <div class="pagination-wrapper">
        <% if(currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&search=<%= search %>" class="page-btn"><i class="fa-solid fa-chevron-left" style="font-size: 12px;"></i></a>
        <% } %>
        
        <% for(let i=1; i<=totalPages; i++){ %>
          <a href="?page=<%= i %>&search=<%= search %>" class="page-btn <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&search=<%= search %>" class="page-btn"><i class="fa-solid fa-chevron-right" style="font-size: 12px;"></i></a>
        <% } %>
      </div>

    </div>

  </div>
</div>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function deleteCategory(id) {
  Swal.fire({
    title: 'Delete Category?',
    text: "Deactivating this category will affect all associated products.",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc2626',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Yes, delete it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      const res = await fetch(`/admin/categories/delete/${id}`);
      if (res.ok) {
        Swal.fire('Deleted!', '', 'success').then(() => location.reload());
      } else {
        Swal.fire('Error', 'Failed to delete category.', 'error');
      }
    }
  });
}
</script>

</body>
</html>
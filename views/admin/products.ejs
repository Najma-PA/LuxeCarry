<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products Inventory</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/admin.css">

</head>
<body>
<div class="d-flex">
  <%- include('../partials/admin/sidebar', { active: 'inventory' }) %>

  <div class="main-content p-5 w-100">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-bold mb-1" style="color: #0f172a;">Products</h2>
        <p class="text-muted mb-0" style="font-size: 15px;">Manage your handbag inventory and stock levels.</p>
      </div>

      <div class="d-flex gap-3">
        <!-- Search -->
        <form method="GET" class="search-bar-wrapper position-relative" style="min-width: 320px;">
          <i class="fa-solid fa-magnifying-glass" style="color: #94a3b8; font-size: 14px;"></i>
          <input type="hidden" name="status" value="<%= status %>">
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search products..." class="ms-2 w-100 pe-5" style="border: none; outline: none;">
          <div class="position-absolute d-flex gap-2" style="right: 12px; top: 50%; transform: translateY(-50%);">
            <% if (search) { %>
              <a href="/admin/products?status=<%= status %>" class="text-decoration-none" style="color: #94a3b8;" title="Clear Search">
                <i class="fa-solid fa-circle-xmark fs-6"></i>
              </a>
            <% } %>
            <button type="submit" class="border-0 bg-transparent p-0" style="color: #c26a00;">
              <i class="fa-solid fa-arrow-right-long fs-6"></i>
            </button>
          </div>
        </form>

        <a href="/admin/products/add" class="btn-gold d-flex align-items-center gap-2">
          <i class="fa-solid fa-plus text-white" style="font-size: 12px;"></i> Add Product
        </a>
      </div>
    </div> 

    <!-- Main Card -->
    <div class="card-shadow mb-4">

      <!-- Tabs & Toolbar -->
      <div class="d-flex justify-content-between align-items-center px-4 pt-3 pb-0 border-bottom" style="border-color: #f1f5f9 !important;">
        <div class="tab-nav d-flex gap-4">
          <a href="?status=all&search=<%= search %>" class="<%= status==='all'?'active':'' %>">All Products</a>
          <a href="?status=active&search=<%= search %>" class="<%= status==='active'?'active':'' %>">Active</a>
          <a href="?status=low&search=<%= search %>" class="<%= status==='low'?'active':'' %>">Low Stock <span class="low-dot"></span></a>
          <a href="?status=archived&search=<%= search %>" class="<%= status==='archived'?'active':'' %>">Archived</a>
        </div>
      
      </div>

      <!-- Table -->
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>PRODUCTS</th>
            <th>CATEGORY</th>
            <th>PRICE</th>
            <th>OFFER</th>
            <th>STOCK STATUS</th>
            <th>ACTIONS</th>
          </tr>
        </thead>
        <tbody>
          <% if(products && products.length > 0) { %>
            <% products.forEach(p => { %>
            <tr id="row-<%= p._id %>">
              <td>
                <div class="fw-bold" style="color: #1e293b; font-size: 14px;"><%= p.name %></div>
                <div class="text-muted mt-1" style="font-size: 12px;"><%= p.description?.slice(0,40) || 'Premium Collection' %></div>
              </td>
              <td><span style="color: #64748b;"><%= p.category?.name || 'Uncategorized' %></span></td>
              <td><span class="fw-bold" style="color: #1e293b;">₹<%= p.price %></span></td>
              <td><span style="color: #64748b;"><%= p.offer || 0 %>%</span></td>
              <td>
                <% if(p.stock === 0){ %>
                  <span class="pill-badge status-out-stock"><span class="badge-dot"></span> Out of stock</span>
                <% } else if(p.stock < 10){ %>
                  <span class="pill-badge status-low-stock"><span class="badge-dot"></span> <%= p.stock %> in stock</span>
                <% } else { %>
                  <span class="pill-badge status-in-stock"><span class="badge-dot"></span> <%= p.stock %> in stock</span>
                <% } %>
              </td>
              <td>
                <a href="/admin/products/edit/<%= p._id %>" class="btn-action" title="Edit">
                  <i class="fa-solid fa-pen" style="font-size: 14px;"></i>
                </a>
                
                <% if (p.isActive) { %>
                  <button onclick="deleteProduct('<%= p._id %>')" class="btn-action" title="Delete">
                    <i class="fa-regular fa-trash-can" style="font-size: 14px;"></i>
                  </button>
                <% } else { %>
                  <button onclick="restoreProduct('<%= p._id %>')" class="btn-action text-success" title="Restore">
                    <i class="fa-solid fa-trash-arrow-up" style="font-size: 14px;"></i>
                  </button>
                <% } %>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="6" class="text-center py-4 text-muted">No products found.</td></tr>
          <% } %>
        </tbody>
      </table>

      <!-- Pagination -->
      <div class="pagination-wrapper d-flex gap-1 align-items-center">
        <% if(currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&status=<%= status %>&search=<%= search %>" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
        <% } else { %>
          <span class="page-btn text-muted" style="background:#f8fafc;"><i class="fa-solid fa-chevron-left"></i></span>
        <% } %>
        
        <% for(let i=1; i<=totalPages; i++){ %>
          <a href="?page=<%= i %>&status=<%= status %>&search=<%= search %>" class="page-btn <%= currentPage===i?'active':'' %>"><%= i %></a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&status=<%= status %>&search=<%= search %>" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
        <% } else { %>
          <span class="page-btn text-muted" style="background:#f8fafc;"><i class="fa-solid fa-chevron-right"></i></span>
        <% } %>
      </div>

    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-3">
      
      <div class="col-md-4">
        <div class="summary-card">
          <div class="icon-container ic-blue"><i class="fa-solid fa-box"></i></div>
          <div>
            <div class="text-muted" style="font-size: 13px; font-weight: 500;">Total SKUs</div>
            <div class="fw-bold" style="font-size: 24px; color: #0f172a;"><%= typeof totalSKUs !== 'undefined' ? totalSKUs : 0 %></div>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="summary-card">
          <div class="icon-container ic-orange"><i class="fa-solid fa-triangle-exclamation"></i></div>
          <div>
            <div class="text-muted" style="font-size: 13px; font-weight: 500;">Low Stock Alerts</div>
            <div class="fw-bold" style="font-size: 24px; color: #0f172a;"><%= typeof lowStockCount !== 'undefined' ? lowStockCount : 0 %></div>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="summary-card">
          <div class="icon-container ic-purple"><i class="fa-solid fa-money-bill-wave"></i></div>
          <div>
            <div class="text-muted" style="font-size: 13px; font-weight: 500;">Inventory Value</div>
            <% let displayVal = '₹0';
               if(typeof inventoryValue !== 'undefined' && inventoryValue > 0) {
                 displayVal = inventoryValue >= 1000 ? '₹' + (inventoryValue/1000).toFixed(1) + 'K' : '₹' + inventoryValue;
               }
            %>
            <div class="fw-bold" style="font-size: 24px; color: #0f172a;"><%= displayVal %></div>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function deleteProduct(id) {
  Swal.fire({
    title: 'Archive product?',
    text: "This product will be moved to the archived list.",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc2626',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Yes, archive it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const response = await fetch(`/admin/products/${id}`, {
          method: 'DELETE'
        });
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        const data = await response.json();
        if (data.success) {
          Swal.fire({
            icon: 'success',
            title: 'Archived!',
            text: 'Product has been moved to archive.',
            timer: 1500,
            showConfirmButton: false
          });
          const row = document.getElementById(`row-${id}`);
          if (row) row.remove();

          // Check if table is empty
          const tbody = document.querySelector('table tbody');
          if (tbody.children.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-muted">No products found.</td></tr>';
          }
        } else {
          Swal.fire('Error', data.message || 'Failed to archive', 'error');
        }
      } catch (err) {
        console.error('Delete Error:', err);
        Swal.fire('Error', `Fetch Error: ${err.message}`, 'error');
      }
    }
  });
}

function restoreProduct(id) {
  Swal.fire({
    title: 'Restore product?',
    text: "Move this product back to the active list?",
    icon: 'question',
    showCancelButton: true,
    confirmButtonColor: '#10b981',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Yes, restore it!'
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const response = await fetch(`/admin/products/restore/${id}`, {
          method: 'PATCH'
        });
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        const data = await response.json();
        if (data.success) {
          Swal.fire({
            icon: 'success',
            title: 'Restored!',
            text: 'Product is now active.',
            timer: 1500,
            showConfirmButton: false
          });
          const row = document.getElementById(`row-${id}`);
          if (row) row.remove();

          // Check if table is empty
          const tbody = document.querySelector('table tbody');
          if (tbody.children.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-muted">No products found.</td></tr>';
          }
        } else {
          Swal.fire('Error', data.message || 'Failed to restore', 'error');
        }
      } catch (err) {
        console.error('Restore Error:', err);
        Swal.fire('Error', `Fetch Error: ${err.message}`, 'error');
      }
    }
  });
}
</script>

</body>
</html>
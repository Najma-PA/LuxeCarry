<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/admin.css">

</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<body>
    <div class="d-flex">
  <%- include('../partials/admin/sidebar', { active: 'dashboard' }) %>

  
  <div class="main-content p-4 w-100">
    
    <h3 class="fw-bold">Welcome back, Admin !!</h3>
<p class="text-muted">Here is what's happening with LuxeCarry today.</p>

<!-- Stats -->
<div class="row g-3 mt-3">

  <div class="col-md-3">
    <div class="card stat-card">
      <p>Total Revenue</p>
      <h5>₹124,500.00</h5>
      <span class="text-success">+12.5%</span>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card stat-card">
      <p>Total Orders</p>
      <h5>1,240</h5>
      <span class="text-success">+8.2%</span>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card stat-card">
      <p>New Customers</p>
      <h5>312</h5>
      <span class="text-success">+15.3%</span>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card stat-card">
      <p>Conversion Rate</p>
      <h5>3.42%</h5>
      <span class="text-success">+0.8%</span>
    </div>
  </div>

</div>

<!-- Recent Orders -->
<div class="card mt-4 p-3">
  <h5>Recent Orders</h5>

  <table class="table mt-3 align-middle">
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Handbag Model</th>
        <th>Date</th>
        <th>Total</th>
        <th>Status</th>
      </tr>
    </thead>

    <tbody>
      <tr>
        <td>#LX-9281</td>
        <td>Jane Doe</td>
        <td>Birkin Edition - Black</td>
        <td>Oct 24, 2023</td>
        <td>₹1,200.00</td>
        <td><span class="badge bg-success">Shipped</span></td>
      </tr>

      <tr>
        <td>#LX-9280</td>
        <td>Michael Smith</td>
        <td>Mini Tote Elite - Emerald</td>
        <td>Oct 24, 2023</td>
        <td>₹850.00</td>
        <td><span class="badge bg-warning text-dark">Pending</span></td>
      </tr>

      <tr>
        <td>#LX-9279</td>
        <td>Robert Wilson</td>
        <td>Clutch Midnight - Silver</td>
        <td>Oct 23, 2023</td>
        <td>₹420.00</td>
        <td><span class="badge bg-primary">Processing</span></td>
      </tr>
    </tbody>
  </table>
</div>


  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

  <!-- Your CSS -->
  <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="d-flex">

  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'inventory' }) %>

  <!-- Main Content -->
  <div class="flex-grow-1 p-4 main-content">

    <h3 class="fw-bold">Edit Product</h3>
    <p class="text-muted">Products › Edit Product</p>

    <div class="card-shadow p-4 mt-3">

      <form method="POST" enctype="multipart/form-data">

        <div class="row">

          <!-- LEFT -->
          <div class="col-md-6">

            <div class="mb-3">
              <label class="label">Product Name</label>
              <input class="form-control" name="name" value="<%= product.name %>">
            </div>

            <div class="mb-3">
              <label class="label">Category</label>
              <select class="form-control" name="category">
                <% categories.forEach(c => { %>
                  <option value="<%= c._id %>"
                    <%= c._id.toString() === product.category.toString() ? 'selected':'' %>>
                    <%= c.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="label">Base Price (₹)</label>
                <input class="form-control" type="number" name="price" value="<%= product.price %>">
              </div>

              <div class="col-md-6 mb-3">
                <label class="label">Discount (%)</label>
                <input class="form-control" type="number" name="offer" value="<%= product.offer %>">
              </div>
            </div>

          </div>

          <!-- RIGHT -->
          <div class="col-md-6">

            <label class="label">Product Images</label>

            <div class="d-flex gap-3 mb-3">

              <% product.images.forEach(img => { %>
                <img src="<%= img %>" class="product-img">
              <% }) %>

              <div class="upload-box" onclick="this.querySelector('input').click()">
                + Add Image
                <input type="file" name="images" multiple hidden>
              </div>

            </div>

            <div>
              <label class="label">Product Description</label>
              <textarea class="form-control" rows="6" name="description"><%= product.description %></textarea>
            </div>

          </div>

        </div>

        <!-- VARIANTS -->
        <hr class="my-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="fw-bold">Product Variants</h6>
          <button type="button" onclick="addVariant()" class="btn btn-outline-warning btn-sm">
            + Add Variant
          </button>
        </div>

        <!-- Variant Container -->
        <div id="variantContainer">
          <% product.variants.forEach(v => { %>
            <div class="row mb-2 align-items-center variant-row">
              <div class="col-md-3">
                <input name="variantType[]" class="form-control" value="<%= v.type %>">
              </div>
              <div class="col-md-5">
                <input name="variantValue[]" class="form-control" value="<%= v.value %>">
              </div>
              <div class="col-md-3">
                <input name="variantStock[]" class="form-control" value="<%= v.stock %>">
              </div>
              <div class="col-md-1 text-end">
                <button type="button" class="btn btn-light" onclick="this.closest('.variant-row').remove()">🗑</button>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- BUTTONS -->
        <div class="text-end mt-4">
          <button type="button" class="btn btn-light me-2">Cancel</button>
          <button type="submit" class="btn-gold px-4">Update Product</button>
        </div>

      </form>

    </div>

  </div>

</div>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function addVariant() {
  const row = `
    <div class="row mb-2 align-items-center variant-row">
      <div class="col-md-3">
        <input name="variantType[]" class="form-control" value="Color">
      </div>
      <div class="col-md-5">
        <input name="variantValue[]" class="form-control" placeholder="e.g. Black">
      </div>
      <div class="col-md-3">
        <input name="variantStock[]" type="number" class="form-control" placeholder="0">
      </div>
      <div class="col-md-1 text-end">
        <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.variant-row').remove()">X</button>
      </div>
    </div>
  `;

  document.getElementById('variantContainer').insertAdjacentHTML('beforeend', row);
}
</script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<link rel="stylesheet" href="/css/admin.css">

</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<body>
  <form method="POST" action="/admin/products/edit/<%= product._id %>" enctype="multipart/form-data">

<input type="text" name="name" value="<%= product.name %>">

<select name="category">
  <% categories.forEach(c => { %>
    <option value="<%= c._id %>"
      <%= c._id.toString() === (product.category?._id || product.category)?.toString() ? 'selected':'' %>>
      <%= c.name %>
    </option>
  <% }) %>
</select>

<input type="number" name="price" value="<%= product.price %>">
<input type="number" name="offer" value="<%= product.offer %>">

<textarea name="description"><%= product.description %></textarea>

<!-- Existing Images -->
<div>
  <% product.images.forEach(img => { %>
    <img src="<%= img %>" width="80">
  <% }) %>
</div>

<input type="file" name="images" multiple class="mt-2 mb-3">

<hr>

<div class="card p-3 mt-3 mb-4 border-0 bg-light">
  <div class="d-flex justify-content-between">
    <h6>Product Variants (Stock Control)</h6>
    <button type="button" class="btn btn-sm btn-outline-dark" onclick="addVariant()">+ Add Variant</button>
  </div>

  <table class="table mt-3 bg-transparent">
    <thead>
      <tr>
        <th>Type</th>
        <th>Value</th>
        <th>Stock</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="variantTable">
      <% if(product.variants && product.variants.length > 0) { %>
        <% product.variants.forEach(variant => { %>
          <tr>
            <td><input name="variantType[]" value="<%= variant.type %>" class="form-control"></td>
            <td><input name="variantValue[]" value="<%= variant.value %>" class="form-control"></td>
            <td><input name="variantStock[]" value="<%= variant.stock %>" type="number" class="form-control"></td>
            <td><button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">X</button></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<button class="btn  w-100 fw-bold">Update Product</button>

</form>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function addVariant() {
  const row = `
    <tr>
      <td><input name="variantType[]" value="Color" class="form-control"></td>
      <td><input name="variantValue[]" class="form-control" placeholder="e.g. Black"></td>
      <td><input name="variantStock[]" type="number" class="form-control" placeholder="0"></td>
      <td><button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">X</button></td>
    </tr>
  `;
  document.getElementById('variantTable').insertAdjacentHTML('beforeend', row);
}
</script>
  
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



</body>
</html>

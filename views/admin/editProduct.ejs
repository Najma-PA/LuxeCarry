<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product | LuxeCarry</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"/>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .image-slot {
      width: 100%;
      aspect-ratio: 4/5;
      border: 2px dashed #ddd;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      overflow: hidden;
      background: #fff;
      position: relative;
      transition: all 0.3s ease;
    }
    .image-slot:hover {
      border-color: #ca8a04;
      background: #fffbeb;
    }
    .image-slot img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
    }
    .image-slot .slot-placeholder {
      text-align: center;
      color: #94a3b8;
    }
    .image-slot.has-image .slot-placeholder {
      display: none;
    }
    .image-slot.has-image img {
      display: block;
    }
    .remove-img-btn {
      position: absolute;
      top: 5px;
      right: 5px;
      background: rgba(255, 255, 255, 0.8);
      border-radius: 50%;
      width: 24px;
      height: 24px;
      display: none;
      align-items: center;
      justify-content: center;
      color: #dc3545;
      border: 1px solid #dc3545;
      font-size: 12px;
      z-index: 10;
    }
    .image-slot.has-image:hover .remove-img-btn {
      display: flex;
    }
  </style>
</head>

<body>

<div class="d-flex">
  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'inventory' }) %>

  <!-- Main Content -->
  <div class="flex-grow-1 p-4 main-content">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h3 class="fw-bold m-0">Edit Product</h3>
        <p class="text-muted small m-0">Products › Edit Product</p>
      </div>
      <a href="/admin/products" class="btn btn-outline-secondary btn-sm">Back to Inventory</a>
    </div>

    <div class="card-shadow p-4 shadow-sm border-0">

      <form id="editProductForm" enctype="multipart/form-data">

        <div class="row">

          <!-- LEFT -->
          <div class="col-md-6">
            <h6 class="fw-bold mb-3 border-bottom pb-2">Basic Details</h6>

            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Product Name</label>
              <input class="form-control" name="name" value="<%= product.name %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Category</label>
              <select class="form-select" name="category" required>
                <% categories.forEach(c => { %>
                  <option value="<%= c._id %>"
                    <%= c._id.toString() === product.category.toString() ? 'selected':'' %>>
                    <%= c.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small fw-bold">Base Price (₹)</label>
                <input class="form-control" type="number" name="price" value="<%= product.price %>" required>
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small fw-bold">Discount (%)</label>
                <input class="form-control" type="number" name="offer" value="<%= product.offer %>" min="0" max="99">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Product Description</label>
              <textarea class="form-control" rows="6" name="description" placeholder="Describe your product..."><%= product.description %></textarea>
            </div>

          </div>

          <!-- RIGHT -->
          <div class="col-md-6">
            <h6 class="fw-bold mb-3 border-bottom pb-2">Product Images</h6>
            <p class="text-muted small mb-3">Replace or add images. Minimum 3 required.</p>

            <div class="row g-3 mb-4">
              <% for(let i=0; i<4; i++) { %>
                <div class="col-6">
                  <div class="image-slot <%= product.images[i] ? 'has-image' : '' %>" id="slot<%= i+1 %>" onclick="triggerFileInput(<%= i+1 %>)">
                    <div class="slot-placeholder">
                      <i class="fas <%= i===0 ? 'fa-star' : 'fa-plus' %> mb-2"></i>
                      <div class="small"><%= i===0 ? 'Main Image' : 'Add Image' %></div>
                    </div>
                    <img id="img<%= i+1 %>" src="<%= product.images[i] || '' %>" alt="">
                    <input type="file" id="input<%= i+1 %>" accept="image/*" hidden onchange="handleFileSelect(event, <%= i+1 %>)">
                    
                    <% if(product.images[i]) { %>
                      <button type="button" class="remove-img-btn" onclick="removeImage(event, <%= i+1 %>)">
                        <i class="fas fa-times"></i>
                      </button>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

        </div>

        <!-- VARIANTS -->
        <hr class="my-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="fw-bold m-0 flex-grow-1 border-bottom pb-2">Product Variants</h6>
          <button type="button" onclick="addVariant()" class="btn btn-outline-warning btn-sm ms-3">
            + Add Variant
          </button>
        </div>

        <!-- Variant Container -->
        <div id="variantContainer">
          <% product.variants.forEach(v => { %>
            <div class="row mb-2 align-items-center variant-row">
              <div class="col-md-3">
                <input name="variantType[]" class="form-control" value="<%= v.type %>">
              </div>
              <div class="col-md-5">
                <input name="variantValue[]" class="form-control" value="<%= v.value %>">
              </div>
              <div class="col-md-3">
                <input name="variantStock[]" type="number" class="form-control" value="<%= v.stock %>">
              </div>
              <div class="col-md-1 text-end">
                <button type="button" class="btn btn-light text-danger" onclick="this.closest('.variant-row').remove()">🗑</button>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- BUTTONS -->
        <div class="text-end mt-4 pt-3 border-top">
          <a href="/admin/products" class="btn btn-light me-2">Cancel</a>
          <button type="submit" class="btn btn-gold px-5 fw-bold">UPDATE PRODUCT</button>
        </div>
        
        <div id="submitSpinner" class="text-center mt-2 d-none">
          <div class="spinner-border spinner-border-sm text-warning" role="status"></div>
          <span class="small ms-1">Saving changes...</span>
        </div>

      </form>

    </div>

  </div>

</div>

<!-- CROPPING MODAL -->
<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crop Image (4:5 Ratio)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="img-container" style="max-height: 500px">
                    <img id="cropperImage" src="" style="max-width: 100%">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="cropButton" class="btn btn-gold">Crop & Save</button>
            </div>
        </div>
    </div>
</div>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>
let cropper;
let currentSlot = null;
const cropModal = new bootstrap.Modal(document.getElementById('cropModal'));

// Data structures to track current state
// existingImages stores URLs for slots that haven't been replaced by new uploads
let existingImages = [
    "<%= product.images[0] || '' %>",
    "<%= product.images[1] || '' %>",
    "<%= product.images[2] || '' %>",
    "<%= product.images[3] || '' %>"
];
let newBlobs = [null, null, null, null];

function triggerFileInput(slot) {
  document.getElementById(`input${slot}`).click();
}

function removeImage(event, slot) {
    event.stopPropagation();
    existingImages[slot-1] = "";
    newBlobs[slot-1] = null;
    
    document.getElementById(`img${slot}`).src = "";
    document.getElementById(`slot${slot}`).classList.remove('has-image');
    
    // Remove the button if it exists
    const btn = document.getElementById(`slot${slot}`).querySelector('.remove-img-btn');
    if(btn) btn.remove();
}

function handleFileSelect(event, slot) {
  const file = event.target.files[0];
  if (!file) return;

  currentSlot = slot;
  const reader = new FileReader();
  reader.onload = (e) => {
    document.getElementById('cropperImage').src = e.target.result;
    cropModal.show();
  };
  reader.readAsDataURL(file);
}

document.getElementById('cropModal').addEventListener('shown.bs.modal', function () {
  cropper = new Cropper(document.getElementById('cropperImage'), {
    aspectRatio: 4 / 5,
    viewMode: 2,
    autoCropArea: 1
  });
});

document.getElementById('cropModal').addEventListener('hidden.bs.modal', function () {
  if (cropper) {
    cropper.destroy();
    cropper = null;
  }
  document.getElementById(`input${currentSlot}`).value = "";
});

document.getElementById('cropButton').onclick = function () {
  if (!cropper) return;
  cropper.getCroppedCanvas({ width: 800, height: 1000 }).toBlob((blob) => {
    newBlobs[currentSlot - 1] = blob;
    existingImages[currentSlot - 1] = ""; // Mark as replaced
    
    const previewImg = document.getElementById(`img${currentSlot}`);
    previewImg.src = URL.createObjectURL(blob);
    document.getElementById(`slot${currentSlot}`).classList.add('has-image');
    
    // Ensure remove button is visible if it wasn't there
    let btn = document.getElementById(`slot${currentSlot}`).querySelector('.remove-img-btn');
    if(!btn) {
        document.getElementById(`slot${currentSlot}`).insertAdjacentHTML('beforeend', `
            <button type="button" class="remove-img-btn" onclick="removeImage(event, ${currentSlot})">
                <i class="fas fa-times"></i>
            </button>
        `);
    }

    cropModal.hide();
  }, 'image/jpeg', 0.9);
};

function addVariant() {
  const row = `
    <div class="row mb-2 align-items-center variant-row">
      <div class="col-md-3">
        <input name="variantType[]" class="form-control" value="Color">
      </div>
      <div class="col-md-5">
        <input name="variantValue[]" class="form-control" placeholder="e.g. Black">
      </div>
      <div class="col-md-3">
        <input name="variantStock[]" type="number" class="form-control" placeholder="0">
      </div>
      <div class="col-md-1 text-end">
        <button type="button" class="btn btn-light text-danger" onclick="this.closest('.variant-row').remove()">🗑</button>
      </div>
    </div>
  `;
  document.getElementById('variantContainer').insertAdjacentHTML('beforeend', row);
}

document.getElementById('editProductForm').onsubmit = async function(e) {
    e.preventDefault();

    // Validate images: combine existing + new
    const finalImageCount = existingImages.filter(img => img !== "").length + newBlobs.filter(b => b !== null).length;
    
    if (finalImageCount < 3) {
        Swal.fire('Wait!', 'A minimum of 3 images are required for each product.', 'warning');
        return;
    }

    document.getElementById('submitSpinner').classList.remove('d-none');
    const submitBtn = this.querySelector('button[type="submit"]');
    submitBtn.disabled = true;

    const formData = new FormData(this);
    
    // Clear standard 'images' field
    formData.delete('images');

    // Add existingImages to keep
    existingImages.forEach(url => {
        if(url) formData.append('existingImages', url);
    });

    // Add new cropped blobs
    newBlobs.forEach((blob, idx) => {
        if(blob) {
            formData.append('images', blob, `update-${idx}.jpg`);
        }
    });

    try {
        const response = await fetch('/admin/products/edit/<%= product._id %>', {
            method: 'POST',
            body: formData
        });

        if (response.redirected) {
            window.location.href = response.url;
        } else {
            const msg = await response.text();
            Swal.fire('Error', msg || 'Update failed', 'error');
        }
    } catch (err) {
        console.error(err);
        Swal.fire('Error', 'Communication error', 'error');
    } finally {
        document.getElementById('submitSpinner').classList.add('d-none');
        submitBtn.disabled = false;
    }
};
</script>

</body>
</html>
</html>
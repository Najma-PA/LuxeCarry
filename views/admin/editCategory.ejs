<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Category</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .cropper-container {
      max-height: 400px;
      overflow: hidden;
    }
    #cropperImage {
      max-width: 100%;
      display: block;
    }
  </style>
</head>

<body>

<div class="d-flex">

  <!-- Sidebar -->
  <%- include('../partials/admin/sidebar', { active: 'categories' }) %>

  <!-- MAIN -->
  <div class="flex-grow-1 main-content p-4">

    <!-- Header -->
    <div class="d-flex align-items-center mb-4">
      <a href="/admin/categories" class="me-2 text-dark">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <h5 class="fw-bold m-0">Edit Category</h5>
    </div>

    <!-- CARD -->
    <div class="category-card">

      <h6 class="fw-bold">Category Information</h6>
      <p class="text-muted small mb-4">
        Provide the details for your product category.
      </p>

      <form id="editCategoryForm" enctype="multipart/form-data">

        <!-- Name -->
        <div class="mb-3">
          <label class="form-label-custom">Category Name</label>
          <input type="text" name="name" class="form-control-custom" value="<%= category.name %>" id="catName">
          <div id="nameError" class="text-danger small mt-1 d-none"></div>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label-custom">Description</label>
          <textarea name="description" class="form-control-custom" rows="4" id="catDesc"><%= category.description %></textarea>
        </div>

        <!-- Upload -->
        <div class="mb-3">
          <label class="form-label-custom">Category Image</label>

          <div class="upload-area" onclick="this.querySelector('input').click()">

            <div class="text-center">
              <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
              <p class="mb-1">Click to upload or drag and drop</p>
              <small class="text-muted">PNG, JPG (Max. 2MB)</small>
            </div>

            <input type="file" name="image" hidden id="catImage">

          </div>

          <% if(category.image && category.image.url) { %>
            <div class="mt-2" id="currentImage">
              <img src="<%= category.image.url %>" class="preview-img">
            </div>
          <% } %>
        </div>

        <!-- Offer -->
        <div class="mb-4">
          <label class="form-label-custom">Category Offer (%)</label>
          <input type="number" name="offer" class="form-control-custom" value="<%= category.offer %>" id="catOffer" min="0" max="99">
          <div id="offerError" class="text-danger small mt-1 d-none"></div>
        </div>

        <!-- Buttons -->
        <div class="d-flex justify-content-end gap-2">
          <a href="/admin/categories" class="btn btn-light">Cancel</a>
          <button type="submit" class="btn-primary-custom" id="submitBtn">
             <span id="btnText">💾 Save Category</span>
             <span id="btnSpinner" class="spinner-border spinner-border-sm d-none"></span>
          </button>
        </div>

      </form>

    </div>

  </div>

</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1" aria-labelledby="cropperModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="cropperModalLabel">Crop Category Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="cropper-container">
          <img id="cropperImage" src="" alt="Image to crop">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="cropButton">Crop & Save</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>
let cropper;
let croppedBlob;
const cropperModal = new bootstrap.Modal(document.getElementById('cropperModal'));
const cropperImage = document.getElementById('cropperImage');

// Helper to show error
function setFieldError(id, msg) {
  const errEl = document.getElementById(id);
  if (errEl) {
    errEl.innerText = msg;
    errEl.classList.remove('d-none');
  }
}

// Helper to clear error
function clearFieldError(id) {
  const errEl = document.getElementById(id);
  if (errEl) {
    errEl.classList.add('d-none');
  }
}

// Attach listeners to clear errors on input
document.querySelectorAll('input, textarea').forEach(el => {
  el.addEventListener('input', () => {
    const errorId = el.id === 'catName' ? 'nameError' : (el.id === 'catOffer' ? 'offerError' : '');
    if (errorId) clearFieldError(errorId);
  });
});

// Image selection
document.getElementById('catImage').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;

  const allowedTypes = ['image/jpeg','image/jpg','image/png','image/webp'];
  if (!allowedTypes.includes(file.type)) {
    Swal.fire('Error','Invalid image format','error');
    this.value = '';
    return;
  }

  const reader = new FileReader();
  reader.onload = function(ev) {
    cropperImage.src = ev.target.result;
    cropperModal.show();
  };
  reader.readAsDataURL(file);
});

// Initialize Cropper
document.getElementById('cropperModal').addEventListener('shown.bs.modal', function () {
  cropper = new Cropper(cropperImage, {
    aspectRatio: 1,
    viewMode: 2,
    autoCropArea: 1,
  });
});

// Destroy Cropper
document.getElementById('cropperModal').addEventListener('hidden.bs.modal', function () {
  if (cropper) {
    cropper.destroy();
    cropper = null;
  }
});

// Handle Crop
document.getElementById('cropButton').addEventListener('click', function() {
  const canvas = cropper.getCroppedCanvas({
    width: 600,
    height: 600,
  });

  canvas.toBlob((blob) => {
    croppedBlob = blob;
    const url = URL.createObjectURL(blob);
    
    // Update preview
    const currentWrapper = document.getElementById('currentImage');
    if (currentWrapper) {
      currentWrapper.querySelector('img').src = url;
    } else {
      // If no current image, we need a way to show preview
      // (Simplified for this update)
    }
    
    cropperModal.hide();
  }, 'image/jpeg', 0.9);
});

document.getElementById('editCategoryForm').onsubmit = async function(e) {
  e.preventDefault();

  // Reset errors
  clearFieldError('nameError');
  clearFieldError('offerError');

  // Show loading
  const btnText = document.getElementById('btnText');
  const btnSpinner = document.getElementById('btnSpinner');
  const submitBtn = document.getElementById('submitBtn');
  
  submitBtn.disabled = true;
  btnText.classList.add('d-none');
  btnSpinner.classList.remove('d-none');

  const formData = new FormData(this);
  if (croppedBlob) {
    formData.set('image', croppedBlob, 'category.jpg');
  }

  try {
    const response = await fetch('/admin/categories/edit/<%= category._id %>', {
      method: 'POST',
      body: formData
    });

    const result = await response.json();

    if (result.success) {
      Swal.fire({
        icon: 'success',
        title: 'Success!',
        text: result.message,
        confirmButtonColor: '#000'
      }).then(() => {
        window.location.href = result.redirectUrl || '/admin/categories';
      });
    } else {
      if (result.errors) {
        if (result.errors.name) setFieldError('nameError', result.errors.name);
        if (result.errors.offer) setFieldError('offerError', result.errors.offer);
      } else {
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: result.message || 'Something went wrong',
          confirmButtonColor: '#000'
        });
      }
    }
  } catch (err) {
    console.error(err);
    Swal.fire({
      icon: 'error',
      title: 'Error',
      text: 'Server communication failed',
      confirmButtonColor: '#000'
    });
  } finally {
    submitBtn.disabled = false;
    btnText.classList.remove('d-none');
    btnSpinner.classList.add('d-none');
  }
};
</script>

</body>
</html>
